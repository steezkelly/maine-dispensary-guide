{
  "name": "@network/maine-cannabis",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "node -e \"require('fs').rmSync('.vercel/output',{recursive:true,force:true})\" && astro build && node -e \"const fs=require('fs');const src='.vercel/output/static';const dst='../../dist';if(fs.existsSync(src)){fs.rmSync(dst,{recursive:true,force:true});fs.cpSync(src,dst,{recursive:true});console.log('Copied clean output to '+dst);}\"",
    "preview": "astro preview",
    "typecheck": "astro check",
    "health-check": "node ./scripts/health-check.cjs",
    "check:hrefs": "node ./scripts/content/check-malformed-hrefs.cjs",
    "check:hrefs:test": "node ./scripts/content/check-malformed-hrefs.test.cjs",
    "check:directory-coverage:test": "node ./scripts/content/check-directory-coverage.test.cjs",
    "check:build-warnings": "node ./scripts/build/check-build-warnings.cjs",
    "check:content-health": "node ./scripts/content/check-content-health.cjs",
    "check:content-health:test": "node ./scripts/content/check-content-health.test.cjs",
    "ci-check": "node ./scripts/ci-checks.cjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.2",
    "@astrojs/mdx": "^5.0.1",
    "@astrojs/sitemap": "^3.7.1",
    "@astrojs/vercel": "^10.0.1",
    "@fal-ai/client": "^1.9.5",
    "@network/config": "*",
    "@network/content-types": "*",
    "@network/design-system": "*",
    "@network/layouts": "*",
    "@network/ui": "*",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^6.0.5",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3"
  }
}
