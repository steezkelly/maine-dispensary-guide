          </section>

          <section class="dir-category">
            <div class="category-header">
              <h3>🏗️ Construction & Buildout</h3>
              <span class="category-sponsor">Sponsored by Pine State Builders</span>
            </div>
            <div class="dir-list">
              <div class="dir-card">
                <div class="dir-card-header">
