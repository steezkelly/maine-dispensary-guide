                <p><strong>Location:</strong> Brunswick, ME</p>
                <p><strong>Note:</strong> Experienced with Bowdoin College area locations.</p>
                <a href="mailto:build@mainedispensaryguide.com" class="dir-contact">Email Coastal Construction →</a>
              </div>
            </div>
          </section>
        </div>

        <section class="add-listing">
          <h3>Are You a Maine Cannabis Professional?</h3>
          <p>If you serve dispensary operators and want to be featured in this directory, contact our partnership team for listing criteria and pricing.</p>
          <a href="/contact" class="btn-featured">Get Your Business Featured →</a>
        </section>
      </div>
    </div>
  </div>

  <script is:inline>
    const GATE_CODE = 'maine2026';
    const STORAGE_KEY = 'maine_dir_access';
    
    function checkAccess() {
      const access = sessionStorage.getItem(STORAGE_KEY);
      if (access === GATE_CODE) {
        document.getElementById('gate-locked').classList.add('hidden');
        document.getElementById('gate-unlocked').classList.remove('hidden');
      }
    }
    
    function lockDirectory() {
      sessionStorage.removeItem(STORAGE_KEY);
      document.getElementById('gate-unlocked').classList.add('hidden');
      document.getElementById('gate-locked').classList.remove('hidden');
    }
    
    window.lockDirectory = lockDirectory;
    
    document.getElementById('access-form').addEventListener('submit', function(e) {
      e.preventDefault();
      const email = document.getElementById('access-email').value;
      const password = document.getElementById('access-password').value;
      
      if (password === GATE_CODE && email.includes('@')) {
        sessionStorage.setItem(STORAGE_KEY, GATE_CODE);
        document.getElementById('gate-locked').classList.add('hidden');
        document.getElementById('gate-unlocked').classList.remove('hidden');
      } else if (password !== GATE_CODE) {
        alert('Invalid access code. Contact admin@mainedispensaryguide.com for access.');
      }
    });
    
    checkAccess();
  </script>

  
</Layout>
