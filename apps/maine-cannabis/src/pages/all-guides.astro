const totalGuides = categories.reduce((sum, cat) => sum + cat.guides.length, 0);
---

<Layout 
  title="Maine Cannabis Resource Library — 95+ Expert Guides" 
  description="Complete index of 95+ technical guides for Maine cannabis operators. Business licensing, compliance, city guides, and operational resources."
  heroImage="/images/heroes/all-guides.jpg"
  article={{ author: "Steve Kelly", authorId: "steve-kelly", authorTitle: "Founder & Publisher", publishDate: "2026-01-05", modifiedDate: "2026-05-14", section: "Reference" }}
>
  <style>

  .page-header {
    text-align: center;
    margin-bottom: 5rem;
    padding-top: 2rem;
  }

  .hero-badge {
    display: inline-block;
    background: var(--color-primary);
    color: var(--color-background);
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .page-header h1 {
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.25rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto;
  }

  .library-intro {
    max-width: 720px;
    margin: 0 auto 4rem;
    padding: 2rem;
    background: rgba(88, 129, 87, 0.05);
    border-radius: 1.5rem;
    border-left: 4px solid var(--color-primary);
  }

  .library-intro p {
    margin-bottom: 1.5rem;
    line-height: 1.7;
    font-size: 1.05rem;
  }

  .library-intro p:last-child {
    margin-bottom: 0;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 5rem;
  }

  .category-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    padding: 2rem;
    transition: all 0.2s;
  }

  .category-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 8px 24px rgba(13, 78, 80, 0.08);
  }

  .cat-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .cat-icon {
    font-size: 1.5rem;
    color: var(--color-primary);
    font-style: normal;
  }

  .cat-header h2 {
    margin: 0;
    font-size: 1.2rem;
    color: var(--color-primary);
  }

  .guide-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .guide-list li {
    margin-bottom: 0.65rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }

  .guide-list li:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .guide-list a {
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.2s;
    line-height: 1.4;
  }

  .guide-list a:hover {
    color: var(--color-accent);
  }

  .view-all {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .view-all a {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .view-all a:hover {
    text-decoration: underline;
  }

  [data-theme="dark"] .category-card {
    background: var(--color-surface);
    border-color: var(--color-border);
  }

  [data-theme="dark"] .category-card:hover {
    border-color: var(--color-primary);
  }

  [data-theme="dark"] .cat-header {
    border-bottom-color: var(--color-border);
  }

  [data-theme="dark"] .guide-list li {
    border-bottom-color: rgba(255,255,255,0.05);
  }

  [data-theme="dark"] .guide-list a {
    color: var(--color-text-light);
  }

  [data-theme="dark"] .guide-list a:hover {
    color: var(--color-accent);
  }

</style>
<section class="page-header">
    <div class="hero-badge">{totalGuides} Expert Guides</div>
    <h1>Maine Cannabis Resource Library</h1>
    <p class="lead">Everything you need to open, operate, and scale a compliant cannabis business in the Pine Tree State.</p>
  </section>

  <section class="library-intro">
    <p>This library covers every phase of the Maine cannabis business lifecycle — from navigating the Maine Office of Cannabis Policy (OCP) application process and securing municipal authorization, to day-to-day operations including Metrc inventory tracking, compliance reporting, and staff management.</p>
    <p>City and town guides provide granular market analysis for 40+ Maine municipalities, from Portland's competitive landscape to underserved opportunities in rural towns with no dispensaries. Technical guides address specific operational challenges including POS system selection, banking access, 280E tax strategy, edibles manufacturing, and delivery logistics.</p>
    <p>New to Maine cannabis? Start with our <a href="/launch-checklist">2026 Launch Checklist</a> — a step-by-step roadmap from entity formation to your first day of sales — or browse the <a href="/start-here">Start Here</a> page for a visual phase-by-phase timeline.</p>
  </section>

  <div class="category-grid">
    {categories.map(cat => (
      <div class="category-card">
        <div class="cat-header">
          <span class="cat-icon">{cat.icon}</span>
          <h2>{cat.name}</h2>
        </div>
        <ul class="guide-list">
          {cat.guides.map(g => (
            <li><a href={g.href}>{g.title}</a></li>
          ))}
        </ul>
        {cat.name === "City & Regional Guides" && (
          <div class="view-all">
            <a href="/guides">See all 40+ town & regional guides →</a>
          </div>
        )}
        {cat.name === "Additional Technical Guides" && (
          <div class="view-all">
            <a href="/guides">Browse all technical guides →</a>
          </div>
        )}
      </div>
    ))}
  </div>

  <Callout title="Start with the Launch Checklist" type="info">
    New to Maine cannabis? Begin with our <a href="/launch-checklist">2026 Launch Checklist</a> — a step-by-step roadmap from entity formation to your first day of sales.
  </Callout>
</Layout>