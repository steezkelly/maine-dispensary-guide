const allGuides = guideRegions.flatMap((region) => region.guides);

const directoryJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Maine dispensary guide directory',
  description: 'Directory of Maine city, town, and regional dispensary guides with map search links.',
  numberOfItems: allGuides.length,
  itemListElement: allGuides.map((guide, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `https://mainedispensaryguide.com${guide.href}`,
    name: `${guide.name} Dispensary Guide`,
  })),
};
---

<Layout
  title="Find a Maine Dispensary Guide by Town or City"
  description="Browse 50 Maine city, town, and regional dispensary guides with local market notes, map search links, and internal guide links."
  heroImage="/images/heroes/find-a-dispensary.jpg"
  article={{ author: "Steve Kelly", authorId: "steve-kelly", authorTitle: "Founder & Publisher", publishDate: "2026-01-10", modifiedDate: "2026-05-14", section: "Reference" }}
>
  <style>
    .directory-header { text-align: center; margin-bottom: 4rem; }
    .hero-badge { display: inline-block; background: var(--color-accent); color: var(--color-background); padding: 0.5rem 1rem; border-radius: 2rem; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem; }
    .lead { font-size: 1.25rem; color: var(--color-text-light); max-width: 760px; margin: 0 auto; }
    .market-overview { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 2rem; padding: 3rem; margin-bottom: 5rem; }
    .market-overview h2 { font-family: var(--font-serif); font-size: 1.75rem; color: var(--color-primary); margin-top: 0; margin-bottom: 1.5rem; }
    .market-overview p { font-size: 1rem; color: var(--color-text-light); line-height: 1.8; margin-bottom: 1rem; }
    .market-overview p:last-child { margin-bottom: 0; }
    .region-directory { display: flex; flex-direction: column; gap: 4.5rem; margin-bottom: 6rem; }
    .region-section h2 { margin: 0 0 1.5rem; padding-bottom: 1rem; border-bottom: 2px solid var(--color-border); font-family: var(--font-serif); font-size: 2rem; color: var(--color-primary); }
    .guide-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; }
    .guide-card { background: var(--color-surface); padding: 1.5rem; border-radius: 1.25rem; border: 1px solid var(--color-border); box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02); }
    .guide-card h3 { margin-top: 0; margin-bottom: 0.75rem; font-family: var(--font-serif); color: var(--color-primary); }
    .guide-card p { color: var(--color-text-light); line-height: 1.6; margin-bottom: 1.25rem; }
    .guide-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .btn-map, .btn-guide { display: inline-flex; align-items: center; justify-content: center; min-height: 2.5rem; padding: 0.65rem 0.85rem; border-radius: 0.75rem; font-weight: 700; text-decoration: none; font-size: 0.85rem; }
    .btn-guide { background: var(--color-primary); color: var(--color-background); }
    .btn-map { border: 1px solid var(--color-primary); color: var(--color-primary); }
    [data-theme="dark"] .guide-card, [data-theme="dark"] .market-overview { background: var(--color-surface); }
  </style>

  <section class="directory-header">
    <div class="hero-badge">50 Maine Local Guides</div>
    <h1>Find a Maine Dispensary Guide by Town or City</h1>
    <p class="lead">Use this directory to jump into the local guide for each Maine town, city, or region where Maine Dispensary Guide has published coverage. Every card links to a real guide page and a map search for that local market.</p>
  </section>

  <section class="market-overview">
    <h2>Maine's Dispensary Landscape</h2>
    <p>Maine's cannabis market is local and uneven: Greater Portland, York County, the Sebago corridor, western mountain towns, and midcoast communities each behave differently. This page is a guide index, not a paid store ranking, so it avoids dead menu CTAs and points readers toward the local context pages that already exist.</p>
    <p>Use the guide links for editorial context and the map links for live location searches. Store hours, menus, and licensing status can change; verify directly before visiting.</p>
  </section>

  <div class="region-directory">
    {guideRegions.map((region) => (
      <section class="region-section" aria-labelledby={`region-${region.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>
        <h2 id={`region-${region.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>{region.name}</h2>
        <div class="guide-grid">
          {region.guides.map((guide) => (
            <article class="guide-card">
              <h3>{guide.name}</h3>
              <p>{guide.summary}</p>
              <div class="guide-actions">
                <a href={guide.href} class="btn-guide">Read guide</a>
                <a href={guide.mapUrl} class="btn-map" target="_blank" rel="noopener noreferrer">Map search</a>
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>

  <Callout title="Own or operate a Maine dispensary?" type="tip">
    If your local guide needs an update, use the <a href="/contact">contact form</a> with the town, license name, and source link. We prioritize corrections that can be verified against public records or operator-owned pages.
  </Callout>
</Layout>

<script type="application/ld+json" set:text={JSON.stringify(directoryJsonLd)}></script>
