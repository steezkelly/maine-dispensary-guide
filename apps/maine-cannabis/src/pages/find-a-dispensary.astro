const directoryJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  'itemListElement': cities.flatMap((city, ci) =>
    city.stores.map((store, si) => ({
      '@type': 'ListItem',
      'position': ci * 10 + si + 1,
      'item': {
        '@type': 'LocalBusiness',
        'name': store.name,
        'address': {
          '@type': 'PostalAddress',
          'streetAddress': store.address,
          'addressLocality': city.name,
          'addressRegion': 'ME',
          'addressCountry': 'US'
        },
        'aggregateRating': {
          '@type': 'AggregateRating',
          'ratingValue': store.rating,
          'ratingCount': 100
        }
      }
    }))
  ),
  'numberOfItems': cities.reduce((a, c) => a + c.stores.length, 0)
};
---

<Layout 
  title="Maine Dispensary Directory" 
  description="Curated directory of the highest-rated adult-use and medical cannabis dispensaries in Maine, sorted by city and verified for quality."
  heroImage="/images/heroes/find-a-dispensary.jpg"
  article={{ author: "Steve Kelly", authorId: "steve-kelly", authorTitle: "Founder & Publisher", publishDate: "2026-01-10", modifiedDate: "2026-05-14", section: "Reference" }}
>
  <style>

  .directory-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .hero-badge {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .lead {
    font-size: 1.25rem;
    color: var(--color-text-light);
    max-width: 700px;
    margin: 0 auto;
  }

  .market-overview {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    padding: 3rem;
    margin-bottom: 6rem;
  }

  .market-overview h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    color: var(--color-primary);
    margin-top: 0;
    margin-bottom: 1.5rem;
  }

  .market-overview p {
    font-size: 1.0rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .market-overview p:last-child { margin-bottom: 0; }

  .city-directory {
    display: flex;
    flex-direction: column;
    gap: 6rem;
    margin-bottom: 8rem;
  }

  .city-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2.5rem;
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 1rem;
  }

  .city-title-row h2 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 2.5rem;
    color: var(--color-primary);
  }

  .guide-link {
    font-weight: 700;
    text-decoration: none;
    color: var(--color-accent);
  }

  .store-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .store-card {
    background: var(--color-surface);
    padding: 2.5rem;
    border-radius: 2rem;
    border: 1px solid var(--color-border);
    box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    position: relative;
    transition: all 0.3s;
  }

  .store-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-primary);
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
  }

  .store-rating {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: rgba(88, 129, 87, 0.1);
    color: var(--color-accent);
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-weight: 800;
    font-size: 0.8rem;
  }

  .store-card h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-family: var(--font-serif);
    color: var(--color-primary);
  }

  .store-highlight {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-accent);
    margin-bottom: 1rem !important;
  }

  .store-address {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 2rem !important;
  }

  .store-actions {
    display: flex;
    gap: 1rem;
  }

  .btn-map, .btn-guide {
    flex: 1;
    text-align: center;
    padding: 0.75rem;
    border-radius: 0.75rem;
    font-weight: 700;
    text-decoration: none;
    font-size: 0.85rem;
  }

  .btn-map {
    background: var(--color-background);
    color: var(--color-primary);
  }

  .btn-guide {
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
  }

  @media (max-width: 600px) {
    .city-title-row { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .store-card { padding: 1.5rem; }
  }

  [data-theme="dark"] .city-guide-card {
    background: var(--color-surface);
  }

  [data-theme="dark"] .store-card {
    background: var(--color-surface);
  }

</style>
<section class="directory-header">
    <div class="hero-badge">Curated by Experts</div>
    <h1>Maine Dispensary Directory</h1>
    <p class="lead">We've audited the local market to find the most professional, high-quality cannabis storefronts in the state. This directory is updated quarterly and verified against Maine OCP public licensee records.</p>
  </section>

  <section class="market-overview">
    <h2>Maine's Dispensary Landscape</h2>
    <p>Maine's adult-use market has matured significantly since retail launch in 2020. With 169 active stores as of early 2026, the market generates over $246 million in annual sales. Stores are distributed across the state, with the highest concentration in York and Cumberland counties, but rural operators in Aroostook, Washington, and Piscataquis counties report less competition and strong tourist traffic during peak seasons.</p>
    <p>Our directory highlights stores that maintain professional standards: compliant packaging, knowledgeable staff, clean facility environments, and accurate inventory. We exclude any establishment with active OCP compliance actions on record.</p>
  </section>

  <div class="city-directory">
    {cities.map(city => (
      <div class="city-section">
        <div class="city-title-row">
          <h2>{city.name}</h2>
          <a href={`/guides/${city.slug}-dispensary-guide/`} class="guide-link">View {city.name} Guide &rarr;</a>
        </div>
        <div class="store-grid">
          {city.stores.map(store => {
            const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(store.address + ', ' + city.name + ', ME')}`;
            const guideUrl = `/guides/${city.slug}-dispensary-guide/`;
            return (
              <div class="store-card">
                <div class="store-rating">★ {store.rating}</div>
                <h3>{store.name}</h3>
                <p class="store-highlight">{store.highlight}</p>
                <p class="store-address">{store.address}, {city.name}, ME</p>
                <div class="store-actions">
                  <a href={mapsUrl} class="btn-map" target="_blank" rel="noopener noreferrer">Directions</a>
                  <a href={guideUrl} class="btn-guide">Full Guide</a>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    ))}
  </div>

  <Callout title="Are you a Store Owner?" type="tip">
    Want your shop to be featured at the top of your city? We offer **Verified Listings** for professional Maine dispensaries. <a href="/contact">Contact our team</a> to learn more about our audit process.
  </Callout>
</Layout>

<script type="application/ld+json" set:text={JSON.stringify(directoryJsonLd)}></script>
