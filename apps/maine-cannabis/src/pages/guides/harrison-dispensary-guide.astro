<article>
  <div class="article-header">
    <h1>Harrison, ME Dispensary Guide</h1>
    <p class="subtitle">Cannabis dispensaries near Harrison, Maine — Sebago Lakes Region</p>
  </div>

  <section class="fact-box">
    <h2>Harrison at a Glance</h2>
    <table aria-label="Harrison cannabis market overview">
      <thead><tr><th scope="col">Fact</th><th scope="col">Details</th></tr></thead>
      <tbody>
