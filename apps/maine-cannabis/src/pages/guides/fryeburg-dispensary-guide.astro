  publishDate: "2026-05-13",
  modifiedDate: "2026-05-13",
  section: "City Guides"
};

const topics = ["city", "market"];

const faqPageJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How many dispensaries are in Fryeburg, Maine?", "acceptedAnswer": { "@type": "Answer", "text": "Fryeburg has 4+ active dispensaries including White Mountain Craft Cannabis (recreational at 285 Main St), The Glass Cook (recreational + glassblowing at 295 Bridgton Rd), Above All Greenery (medical at 299 Main St), and The Great Atlantic Puffin Company (medical at 235 Bridgton Rd)." }},
    { "@type": "Question", "name": "Is Fryeburg opted in to recreational cannabis?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Fryeburg has authorized recreational cannabis dispensaries. The town is notable for having the first recreational dispensary in western Maine, White Mountain Craft Cannabis at 285 Main St." }},
    { "@type": "Question", "name": "Why is Fryeburg significant for cannabis retail?", "acceptedAnswer": { "@type": "Answer", "text": "Fryeburg's location on the New Hampshire border captures cross-state traffic from NH residents who cannot legally purchase cannabis in their home state. Additionally, the Fryeburg Fair draws 200,000+ visitors annually, creating a massive seasonal surge." }},
    { "@type": "Question", "name": "What makes The Glass Cook unique?", "acceptedAnswer": { "@type": "Answer", "text": "The Glass Cook at 295 Bridgton Rd combines a recreational cannabis dispensary with an on-site glassblowing studio, offering a unique experiential retail environment that differentiates it from typical dispensaries." }}
  ]
});
---

<Layout title="Fryeburg, ME Dispensary Guide — 4+ Cannabis Dispensaries 2026" description="Fryeburg, Maine dispensary guide. 4+ dispensaries including recreational and medical. White Mountain Craft Cannabis, The Glass Cook, and more in Oxford County for 2026." heroImage="/images/heroes/fryeburg-dispensary-guide.jpg" article={article} topics={topics} >
<style>
  article { max-width: 720px; margin: 0 auto; }
  .article-header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }
  .subtitle { font-size: 1.125rem; color: var(--color-text-light); }
  section { margin-bottom: 2.5rem; }
  section h2, section h3 { margin-top: 1.5rem; }
  section h2:first-child { margin-top: 0; }
  table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
  th, td { padding: 0.6rem 0.75rem; text-align: left; border-bottom: 1px solid var(--color-border); }
  th { background: var(--color-background); }
  ul, ol { padding-left: 1.5rem; }
