  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Are there any cannabis dispensaries in Waterboro, Maine?", "acceptedAnswer": { "@type": "Answer", "text": "Waterboro has two medical cannabis operations: Joey Nugz (207-432-8863, appointment-based, joeynugz207.com, largest menu in Maine) and The Garden (MMMP caregiver, cash only). Both are medical-only. Waterboro has not opted in to adult-use recreational cannabis." }},
    { "@type": "Question", "name": "Does Waterboro allow recreational cannabis dispensaries?", "acceptedAnswer": { "@type": "Answer", "text": "No. Waterboro has NOT opted in to adult-use cannabis retail. No recreational cannabis stores can operate within Waterboro town limits. Medical cannabis patients with valid MMMP cards are served by Joey Nugz and The Garden." }},
    { "@type": "Question", "name": "What are the hours for Joey Nugz?", "acceptedAnswer": { "@type": "Answer", "text": "Joey Nugz is appointment-based — 24-hour notice preferred, same-day available upon availability. Call 207-432-8863 to schedule. Owner-operated, cash only. Deals include $50-$150/oz flower and $20 full-gram carts." }},
    { "@type": "Question", "name": "What is Waterboro Maine known for?", "acceptedAnswer": { "@type": "Answer", "text": "Waterboro is a York County town of approximately 7,800 residents, one of the larger towns in the region. It has not opted in to recreational cannabis but supports an active medical cannabis community with two dispensary operations." }}
  ]
});
---

<Layout title="Waterboro, ME Dispensary Guide — Medical Cannabis 2026" description="Waterboro, Maine cannabis guide. Joey Nugz (largest medical menu in Maine) and The Garden serve medical patients. No recreational dispensaries — not opted in." heroImage="/images/heroes/naples-dispensary-guide.jpg" article={article} topics={topics} >
<style>
