  author: "Steve Kelly",
  authorId: "steve-kelly",
  authorTitle: "Founder & Publisher",
  publishDate: "2026-05-14",
  modifiedDate: "2026-05-14",
  section: "City Guides"
};

const topics = ["city", "market"];

const faqPageJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Are there any cannabis dispensaries in Waterboro, Maine?", "acceptedAnswer": { "@type": "Answer", "text": "Waterboro has two medical cannabis dispensaries: Joey Nugz (known for 'largest menu of medical marijuana in Maine') and The Garden (MMMP caregiver). Both are medical-only and Waterboro has not opted in to adult-use recreational cannabis." }},
    { "@type": "Question", "name": "Does Waterboro allow recreational cannabis dispensaries?", "acceptedAnswer": { "@type": "Answer", "text": "No. Waterboro has NOT opted in to adult-use cannabis retail. No recreational cannabis stores can operate within Waterboro town limits. Medical cannabis patients with valid MMMP cards are served by Joey Nugz and The Garden." }},
    { "@type": "Question", "name": "What is Joey Nugz known for?", "acceptedAnswer": { "@type": "Answer", "text": "Joey Nugz in Waterboro is known for having the largest menu of medical marijuana in Maine according to their branding. Their motto is 'Come for the weed, stay for the vibe,' indicating a focus on product variety and customer experience." }},
    { "@type": "Question", "name": "What is Waterboro Maine known for?", "acceptedAnswer": { "@type": "Answer", "text": "Waterboro is a York County town of approximately 7,800 residents, one of the largest towns in the region. It has not opted in to recreational cannabis but supports an active medical cannabis community with two dispensary operations." }}
  ]
});
---

<Layout title="Waterboro, ME Dispensary Guide — Medical Cannabis 2026" description="Waterboro, Maine cannabis guide. Joey Nugz (largest medical menu in Maine) and The Garden serve medical patients. No recreational dispensaries — not opted in." heroImage="/images/heroes/naples-dispensary-guide.jpg" article={article} topics={topics} >
<style>
  article { max-width: 720px; margin: 0 auto; }
  .article-header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }
  .subtitle { font-size: 1.125rem; color: var(--color-text-light); }
  section { margin-bottom: 2.5rem; }
  section h2, section h3 { margin-top: 1.5rem; }
  section h2:first-child { margin-top: 0; }
  table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
  th, td { padding: 0.6rem 0.75rem; text-align: left; border-bottom: 1px solid var(--color-border); }
  th { background: var(--color-background); }
  ul, ol { padding-left: 1.5rem; }
  li { margin-bottom: 0.4rem; }
