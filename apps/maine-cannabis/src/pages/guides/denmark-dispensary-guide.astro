---
import Layout from '../../layouts/Layout.astro';
import Faq from '../../components/Faq.astro';

const article = {
  author: "Steve Kelly",
  authorId: "steve-kelly",
  authorTitle: "Founder & Publisher",
  publishDate: "2026-05-14",
  modifiedDate: "2026-05-14",
  section: "City Guides"
};

const topics = ["city", "market"];

const faqPageJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Are there any cannabis dispensaries in Denmark, Maine?", "acceptedAnswer": { "@type": "Answer", "text": "No. Denmark has explicitly prohibited retail marijuana establishments and retail marijuana social clubs through a town ordinance adopted March 28, 2017. One of Maine's earliest opt-out municipalities, there are no cannabis dispensaries of any type operating in Denmark." }},
    { "@type": "Question", "name": "Does Denmark allow cannabis dispensaries?", "acceptedAnswer": { "@type": "Answer", "text": "No. Denmark adopted an ordinance prohibiting retail marijuana establishments and retail marijuana social clubs on March 28, 2017 — very early in Maine's post-legalization timeline. This opt-out was one of the first in the state, reflecting the town's conservative stance on cannabis." }},
    { "@type": "Question", "name": "Where do Denmark residents buy legal cannabis?", "acceptedAnswer": { "@type": "Answer", "text": "Denmark residents must travel to neighboring Fryeburg (~10-15 min) for legal cannabis purchases. White Mountain Craft Cannabis (285 Main St, 207-256-3082) serves recreational customers. Medical patients should use The Glass Cook (295 Bridgton Rd, 207-890-8871) or the other medical dispensaries." }},
    { "@type": "Question", "name": "What is Denmark Maine known for?", "acceptedAnswer": { "@type": "Answer", "text": "Denmark is a small Oxford County town of approximately 1,100 residents in western Maine, close to the New Hampshire border. It is known for its rural character, proximity to outdoor recreation, and its early decision to opt out of cannabis retail — one of the first Maine towns to do so." }}
  ]
});
---

<Layout title="Denmark, ME Dispensary Guide — Opted Out Since 2017 2026" description="Denmark, Maine cannabis guide. Denmark banned cannabis retail in 2017 — earliest opt-outs in Maine. Nearest dispensaries are in Fryeburg (~10-15 min)." heroImage="/images/heroes/naples-dispensary-guide.jpg" article={article} topics={topics} >
<style>
  article { max-width: 720px; margin: 0 auto; }
  .article-header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }
  .subtitle { font-size: 1.125rem; color: var(--color-text-light); }
  section { margin-bottom: 2.5rem; }
  section h2, section h3 { margin-top: 1.5rem; }
  section h2:first-child { margin-top: 0; }
  table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
  th, td { padding: 0.6rem 0.75rem; text-align: left; border-bottom: 1px solid var(--color-border); }
  th { background: var(--color-background); }
  ul, ol { padding-left: 1.5rem; }
  li { margin-bottom: 0.4rem; }
  .disclaimer { background: var(--color-disclaimer-bg); border: 1px solid var(--color-disclaimer-border); padding: 1rem; border-radius: 0.5rem; font-size: 0.875rem; color: var(--color-disclaimer-text); }
  .fact-box { background: rgba(88, 129, 87, 0.1); padding: 1.75rem; border-radius: 1rem; border-left: 4px solid var(--color-primary); }
  .fact-box h2 { margin-top: 0; font-size: 1.25rem; }
  .fact-box table { margin: 0; }
  .opt-out-box { background: rgba(200, 80, 80, 0.06); padding: 1.5rem; border-radius: 1rem; border: 1px solid var(--color-border); margin-top: 1rem; }
  .opt-out-box h3 { margin-top: 0; color: #8b3a3a; }
  .further-reading { background: rgba(88, 129, 87, 0.05); padding: 1.5rem; border-radius: 1rem; margin-top: 3rem; }
  .further-reading h2 { margin-top: 0; font-size: 1.25rem; }
</style>

<article>
  <div class="article-header">
    <h1>Denmark, ME Dispensary Guide</h1>
    <p class="subtitle">Cannabis access for Denmark, Maine residents — Nearest dispensaries in Fryeburg</p>
  </div>

  <section class="fact-box">
    <h2>Denmark at a Glance</h2>
    <table aria-label="Denmark cannabis market overview">
      <thead><tr><th scope="col">Fact</th><th scope="col">Details</th></tr></thead>
      <tbody>
        <tr><td><strong>Dispensaries in Town</strong></td><td>0 — Prohibited by ordinance since 2017</td></tr>
        <tr><td><strong>Opt-In Status</strong></td><td>OPTED OUT — March 28, 2017 (earliest opt-outs in Maine)</td></tr>
        <tr><td><strong>Nearest Dispensaries</strong></td><td>Fryeburg (~10-15 min) — White Mountain Craft Cannabis, The Glass Cook, others</td></tr>
        <tr><td><strong>Population</strong></td><td>~1,100</td></tr>
        <tr><td><strong>County</strong></td><td>Oxford County</td></tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Overview</h2>
    <p>Denmark is a small Oxford County town of approximately 1,100 residents in western Maine, situated near the New Hampshire border. The town is characterized by its rural character, forested landscapes, and proximity to outdoor recreation including hiking, skiing, and lakes access.</p>
    <p>Denmark holds a notable distinction in Maine cannabis history: the town adopted its ordinance prohibiting retail marijuana establishments and retail marijuana social clubs on March 28, 2017 — making it one of the very first municipalities in Maine to formally opt out of cannabis retail after state legalization. This early opt-out signaled a clear conservative stance on cannabis that has not changed in the years since.</p>
  </section>

  <section>
    <div class="opt-out-box">
      <h3>Denmark's Opt-Out History</h3>
      <p>Denmark's March 28, 2017 ordinance was among the earliest municipal opt-outs in Maine. While many towns took months or years to make a decision after Maine's 2016 legalization vote, Denmark acted quickly to prohibit cannabis retail establishments before the regulatory framework was even fully established.</p>
      <p>This early opt-out means that for nearly a decade, Denmark has had no legal cannabis retail of any type — medical or adult-use — within its town limits. Residents seeking legal cannabis must travel to neighboring Fryeburg, which has four active dispensaries.</p>
    </div>
  </section>

  <section>
    <h2>Nearest Dispensaries to Denmark</h2>
    <p>The nearest dispensaries to Denmark are in Fryeburg, approximately 10–15 minutes away:</p>

    <h3>White Mountain Craft Cannabis (Recreational)</h3>
    <p><strong>Address:</strong> 285 Main St Ste 8, Fryeburg, ME 04037</p>
    <p>The first recreational dispensary in western Maine and the primary adult-use option for Denmark residents. Located on Main Street in Fryeburg.</p>

    <h3>The Glass Cook (Medical — MMMP)</h3>
    <p><strong>Address:</strong> 295 Bridgton Rd, Fryeburg, ME 04037</p>
    <p><strong>Phone:</strong> (207) 890-8871</p>
    <p><strong>Hours:</strong> Mon–Sat 11am–7pm, Closed Sunday</p>
    <p>A medical cannabis dispensary with an experiential retail component — combining cannabis with an on-site glassblowing studio. Patients and caregivers appreciate the unique atmosphere.</p>

    <h3>Medical Options in Fryeburg</h3>
    <p>For medical cannabis patients, Above All Greenery North (48 Fair St Unit 4, 207-256-3340) and The Great Atlantic Puffin Company (14 Bridgton Rd, 207-935-5444) serve MMMP cardholders.</p>
  </section>

  <section>
    <h2>Town Status & Opt-In</h2>
    <p>Denmark has <strong>opted out</strong> of cannabis retail. The town's March 28, 2017 ordinance explicitly prohibits both retail marijuana establishments and retail marijuana social clubs. This is one of the earliest opt-outs on record in Maine.</p>
    <p>Changing Denmark's status would require a citizen petition and a town vote to repeal or amend the existing ordinance — a significant political lift in a community that demonstrated early opposition to cannabis retail.</p>
    <p>For current opt-in status and any municipal changes, refer to our <a href="/guides/maine-cannabis-opt-in-tracker">Maine Cannabis Opt-In Tracker</a>.</p>
  </section>

  <section>
    <div class="further-reading">
      <h2>Related Guides</h2>
      <ul>
        <li><a href="/guides/fryeburg-dispensary-guide">Fryeburg Dispensary Guide</a></li>
        <li><a href="/guides/brownfield-dispensary-guide">Brownfield Dispensary Guide</a></li>
        <li><a href="/guides/bridgton-dispensary-guide">Bridgton Dispensary Guide</a></li>
        <li><a href="/guides/maine-cannabis-opt-in-tracker">Maine Cannabis Opt-In Tracker</a></li>
      </ul>
    </div>
  </section>

  <section class="faq-section">
    <h2>Frequently Asked Questions</h2>
    <Faq
      questions={[
        { q: "Are there any cannabis dispensaries in Denmark, Maine?", a: "No. Denmark prohibited cannabis retail via ordinance on March 28, 2017 — one of the earliest opt-outs in Maine. There are no cannabis dispensaries of any type in Denmark." },
        { q: "Does Denmark allow cannabis dispensaries?", a: "No. Denmark adopted an ordinance on March 28, 2017 prohibiting retail marijuana establishments and social clubs, making it one of the first Maine towns to opt out." },
        { q: "Where do Denmark residents buy legal cannabis?", a: "Denmark residents travel approximately 10-15 minutes to Fryeburg, which has recreational: White Mountain Craft Cannabis (285 Main St, 207-256-3082) and medical: The Glass Cook (295 Bridgton Rd, 207-890-8871), Above All Greenery North (48 Fair St, 207-256-3340), Great Atlantic Puffin Company (14 Bridgton Rd, 207-935-5444)." },
        { q: "What is Denmark Maine known for?", a: "Denmark is a small Oxford County town of ~1,100 residents near the NH border. It is known for its early opt-out of cannabis retail (2017), rural character, and proximity to outdoor recreation." }
      ]}
    />
  </section>

  <p class="disclaimer"><strong>Disclaimer:</strong> Information is provided for general reference only. Dispensary status, hours, and product availability can change. Always verify details directly with the dispensary before planning a visit.</p>
</article>
</Layout>
<script type="application/ld+json" set:text={faqPageJsonLd} is:inline></script>
