--- import Layout from '../../layouts/Layout.astro'; import Callout from '../../components/Callout.astro'; const article = { author: "Calvin Waters", authorId: "calvin-waters", authorTitle: "Licensing & Compliance Analyst", publishDate: "2026-01-20", modifiedDate: "2026-04-14", section: "Operations & Technology" }; const topics = ["compliance", "licensing"]; const faqData = { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [ { "@type": "Question", "name": "What are the Maine cultivation license tiers?", "acceptedAnswer": { "@type": "Answer", "text": "Maine has four cultivation tiers: Tier 1 (up to 2,000 sq ft, $500 application fee), Tier 2 (2,001-7,000 sq ft, $1,500 fee), Tier 3 (7,001-20,000 sq ft, $3,000 fee), and Tier 4 (unlimited canopy, $5,000 fee). Each tier has specific annual renewal fees and canopy definitions under 28-B M.R.S. Sections 401-405." } }, { "@type": "Question", "name": "How much does it cost to get a cultivation license in Maine?", "acceptedAnswer": { "@type": "Answer", "text": "Application fees range from $500 for Tier 1 to $5,000 for Tier 4. Annual renewal fees are $1,000 (Tier 1), $2,500 (Tier 2), $5,000 (Tier 3), and $10,000 (Tier 4). Startup costs for a basic compliant facility range from $100K-$200K for Tier 1 up to $2M+ for Tier 4 operations." } }, { "@type": "Question", "name": "What are the canopy limits for Maine cultivation?", "acceptedAnswer": { "@type": "Answer", "text": "Maine defines canopy as actual flowering space, not total facility footprint. Tier 1 allows 2,000 sq ft, Tier 2 permits 2,001-7,000 sq ft, Tier 3 covers 7,001-20,000 sq ft, and Tier 4 has no square footage cap. Storage, vegetative rooms, and office space do not count against tier limits." } }, { "@type": "Question", "name": "How long does it take to get a Maine cultivation license?", "acceptedAnswer": { "@type": "Answer", "text": "The OCP typically reviews complete applications within 60-120 days. Incomplete applications delay processing significantly. You must also obtain municipal approval for your location before applying. Metrc seed-to-sale tracking must be established before licensing." } } ] }; --- <Layout title="Cannabis Cultivation Guide" description="Maine cannabis cultivation guide. Licensing tiers, facility requirements, compliance protocols, and operational best practices for 2026." heroImage="/images/heroes/maine-cannabis-cultivation-guide.jpg" article={article} topics={topics} > <style>
