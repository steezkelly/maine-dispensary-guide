const article = { author: "Eliot Nash", authorId: "eliot-nash", authorTitle: "Market & Real Estate Analyst", publishDate: "2026-05-13", modifiedDate: "2026-05-13", section: "City Guides" };
const topics = ["city", "market"];
const faqPageJsonLd = JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Are there cannabis dispensaries in Gardiner, Maine?","acceptedAnswer":{"@type":"Answer","text":"Yes. Gardiner has at least 5 active dispensaries: The Bud Bar (medical), Gardiner 4Twenty (medical), The Healing Community MEDCo (medical), Wellness Connection of Maine (medical), and Sinsemilla/Rugged Roots Trading Post (recreational). This makes Gardiner one of the most densely served small towns in Maine for cannabis access."}},{"@type":"Question","name":"What is Wellness Connection of Maine in Gardiner?","acceptedAnswer":{"@type":"Answer","text":"Wellness Connection of Maine is a medical cannabis dispensary at 31 Maine Avenue, Gardiner. Established 2011, they operate an in-house indoor garden and CO2 extraction lab. Phone: (207) 588-6055. They operate 2 adult-use and 2 medical stores statewide."}},{"@type":"Question","name":"Where is Sinsemilla in Gardiner?","acceptedAnswer":{"@type":"Answer","text":"Sinsemilla Gardiner (also known as Rugged Roots Trading Post) is a recreational dispensary at 35 Bridge St, Gardiner, ME 04345. Phone: (207) 588-7816. Rating: 4.8/5. They feature MOFGA organic flower from Rugged Roots cultivation."}},{"@type":"Question","name":"Does Gardiner accept out-of-state medical cards?","acceptedAnswer":{"@type":"Answer","text":"Maine allows reciprocity for out-of-state medical cannabis cards. Contact individual dispensaries in Gardiner about their current reciprocity policies."}}]});
---
<Layout title="Gardiner, Maine Dispensary Guide — 5+ Dispensaries on the Kennebec 2026" description="Gardiner, Maine dispensary guide. 5+ dispensaries including The Bud Bar, Gardiner 4Twenty, The Healing Community MEDCo, Wellness Connection, Sinsemilla/Rugged Roots on the Kennebec River for 2026." heroImage="/images/heroes/gardiner-dispensary-guide.jpg" article={article} topics={topics} >
<style>
  article{max-width:720px;margin:0 auto}.article-header{margin-bottom:2.5rem;padding-bottom:1.5rem;border-bottom:1px solid var(--color-border)}.subtitle{font-size:1.125rem;color:var(--color-text-light)}section{margin-bottom:2.5rem}section h2,section h3{margin-top:1.5rem}section h2:first-child{margin-top:0}table{width:100%;border-collapse:collapse;margin:1rem 0}th,td{padding:0.6rem .75rem;text-align:left;border-bottom:1px solid var(--color-border)}th{background:var(--color-background)}ul,ol{padding-left:1.5rem}li{margin-bottom:.4rem}.disclaimer{background:var(--color-disclaimer-bg);border:1px solid var(--color-disclaimer-border);padding:1rem;border-radius:.5rem;font-size:.875rem;color:var(--color-disclaimer-text)}.fact-box{background:rgba(88,129,87,.1);padding:1.75rem;border-radius:1rem;border-left:4px solid var(--color-primary)}.fact-box h2{margin-top:0;font-size:1.25rem}.fact-box table{margin:0}.further-reading{background:rgba(88,129,87,.05);padding:1.5rem;border-radius:1rem;margin-top:3rem}.further-reading h2{margin-top:0;font-size:1.25rem}
