 article { max-width: 720px; margin: 0 auto; }.article-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }.subtitle { font-size: 1.25rem; color: var(--color-text-light); } section { margin-bottom: 2rem; } section h2, section h3 { margin-top: 1.5rem; color: var(--color-primary); font-family: var(--font-serif); } section h2:first-child { margin-top: 0; } table { width: 100%; border-collapse: collapse; margin: 1rem 0; } th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid var(--color-border); } th { background: var(--color-background); } ul { padding-left: 1.5rem; } li { margin-bottom: 0.5rem; }.disclaimer { background: var(--color-disclaimer-bg); border: 1px solid var(--color-disclaimer-border); padding: 1rem; border-radius: 0.5rem; font-size: 0.875rem; margin-top: 2rem; color: var(--color-disclaimer-text); }.further-reading { background: rgba(88, 129, 87, 0.05); padding: 1.5rem; border-radius: 1rem; margin-top: 3rem; }.further-reading h2 { margin-top: 0; font-size: 1.25rem; }.fact-box { background: rgba(88, 129, 87, 0.1); padding: 1.5rem; border-radius: 1rem; border-left: 4px solid var(--color-primary); margin-bottom: 2rem; }.fact-box h2 { margin-top: 0; font-size: 1.25rem; }.fact-box table { margin: 0; width: 100%; border-collapse: collapse; }.fact-box td { padding: 0.5rem; border-bottom: 1px solid rgba(0,0,0,0.05); font-size: 0.95rem; } 
