---
import Layout from '../../layouts/Layout.astro';
import Faq from '../../components/Faq.astro';

const article = {
  author: "Steve Kelly",
  authorId: "steve-kelly",
  authorTitle: "Founder & Publisher",
  publishDate: "2026-05-13",
  modifiedDate: "2026-05-13",
  section: "City Guides"
};

const topics = ["city", "market"];

const towns = [
  {
    name: "Bridgton",
    county: "Cumberland",
    adultUseStores: [
      { name: "Canuvo", operator: "Wellrick Inc", address: "152 Portland Rd", website: "https://canuvo.com/" },
      { name: "Sweet Dirt Cannabis", operator: "Rugged Roots, LLC", address: "1 Beaver Creek Farm Rd", website: "https://www.ruggedrootsinc.com" }
    ],
    operatorNote: "Bridgton is the strongest lakes-region retail cluster: multiple dispensaries on or near Portland Road/Route 302. New entrants should treat the town as a competitive convenience-retail market, not a blank-map opportunity."
  },
  {
    name: "Casco",
    county: "Cumberland",
    adultUseStores: [
      { name: "Blue Lobster Cannabis", operator: "Blue Lobster Farms LLC", address: "200 Roosevelt Trl", website: "https://bluelobstercannabis.com/" },
      { name: "Landrace Cannabis Co.", operator: "Pine Tree Maine 2, LLC", address: "325 Roosevelt Trl", website: "https://www.landracecanna.com/" }
    ],
    operatorNote: "Casco has two active adult-use stores on Roosevelt Trail/Route 302, making it a real retail node for Sebago Lake traffic rather than an unserved rural town."
  },
  {
    name: "Raymond",
    county: "Cumberland",
    adultUseStores: [],
    operatorNote: "No active adult-use storefronts currently operate in Raymond. Raymond still matters for search demand because customers may compare nearby Casco, Windham, and Bridgton-area options. See our Raymond dispensary guide for the current state."
  },
  {
    name: "Standish",
    county: "Cumberland",
    adultUseStores: [],
    operatorNote: "Limited dispensary coverage today. Standish sits between Portland and Sebago Lake — a growing residential community with one dispensary (Lakewood Cannabis). See our Standish dispensary guide for details."
  },
  {
    name: "Sebago",
    county: "Cumberland",
    adultUseStores: [],
    operatorNote: "No dedicated dispensaries in Sebago town limits. Residents typically shop in Bridgton (15 min), Buxton (20 min), or Portland (30-40 min)."
  },
  {
    name: "Naples",
    county: "Cumberland",
    adultUseStores: [],
    operatorNote: "No dispensaries currently operate in Naples. Seasonal visitor demand is served by nearby Bridgton, Casco, and Windham operators. See our Naples dispensary guide for the current state."
  },
  {
    name: "Windham",
    county: "Cumberland",
    adultUseStores: [
      { name: "Maine's Alternative Caring", operator: "Route 302 location", address: "Roosevelt Trail (Route 302)", website: "" },
      { name: "Sticky Bud Farms", operator: "815 Roosevelt Trail", address: "815 Roosevelt Trail #3", website: "" }
    ],
    operatorNote: "Windham is the nearest stronger commercial hub for the Sebago Lake corridor, with multiple dispensaries along Route 302 (the 'Green Mile')."
  }
];

const totalStores = towns.reduce((sum, town) => sum + town.adultUseStores.length, 0);

const faqPageJsonLd = JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[
  {"@type":"Question","name":"Are there cannabis dispensaries in the western Maine lakes region?","acceptedAnswer":{"@type":"Answer","text":"Yes. Bridgton has 3+ dispensaries, Casco has 2, and Windham has multiple operators along Route 302. Smaller towns like Naples, Sebago, Raymond, and Standish currently have no or very limited dispensaries but are served by nearby Bridgton and Casco options."}},
  {"@type":"Question","name":"Where can I buy cannabis near Sebago Lake?","acceptedAnswer":{"@type":"Answer","text":"The nearest dispensaries to Sebago Lake are in Bridgton (Sweet Dirt, Canuvo, Blue Lobster Cannabis) and Casco (Landrace Cannabis Co.). Naples and Sebago residents typically drive 10-20 minutes to reach these options."}}
]});
---

<Layout
  title="Western Maine Lakes Dispensary Guide — Sebago Region Cannabis 2026"
  description="Adult-use cannabis dispensary availability in Bridgton, Casco, Raymond, Standish, Sebago, Naples, Windham, and nearby western Maine towns near Sebago Lake for 2026."
  heroImage="/images/heroes/casco-dispensary-guide.jpg"
  article={article}
  topics={topics}
>
<style>
  article { max-width: 820px; margin: 0 auto; }
  .article-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }
  .subtitle { font-size: 1.25rem; color: var(--color-text-light); }
  section { margin-bottom: 2.5rem; }
  .fact-box { background: linear-gradient(135deg, rgba(88, 129, 87, 0.08) 0%, rgba(163, 177, 138, 0.06) 100%); padding: 2rem; border-radius: 1rem; border: 1px solid var(--color-border); }
  .town-card { border: 1px solid var(--color-border); border-radius: 1rem; padding: 1.5rem; margin-bottom: 1.5rem; background: var(--color-surface, #fff); }
  .town-card h3 { margin-top: 0; color: var(--color-primary); }
  .store-list { padding-left: 1.25rem; }
  .store-list li { margin-bottom: 0.75rem; }
  .status-empty { color: var(--color-text-light); font-style: italic; }
  .source-note { font-size: 0.925rem; color: var(--color-text-light); }
  table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
  th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid var(--color-border); }
  th { background: var(--color-background); }
  .further-reading { background: rgba(88, 129, 87, 0.05); padding: 1.5rem; border-radius: 1rem; margin-top: 3rem; }
  .further-reading h2 { margin-top: 0; font-size: 1.25rem; }
</style>

<article>
  <div class="article-header">
    <h1>Western Maine Lakes Dispensary Guide</h1>
    <p class="subtitle">Adult-use dispensary availability in the Sebago Lakes region — Bridgton, Casco, Windham, and surrounding towns</p>
  </div>

  <section class="fact-box">
    <h2>Quick Answer</h2>
    <p>The western Maine lakes region (Sebago Lake corridor, Route 302) is served by <strong>{totalStores} confirmed dispensary operators</strong> across Bridgton, Casco, and Windham. Smaller towns including Naples, Sebago, Raymond, and Standish have limited or no dedicated dispensaries but are served by the corridor hubs.</p>
  </section>

  <section>
    <h2>Town-by-Town Dispensary Availability</h2>
    {towns.map((town) => (
      <div class="town-card">
        <h3>{town.name}, Maine</h3>
        <p><strong>County:</strong> {town.county}</p>
        {town.adultUseStores.length > 0 ? (
          <ul class="store-list">
            {town.adultUseStores.map((store) => (
              <li>
                <strong>{store.name}</strong> — {store.address}
                <br />
                <span>{store.operator}</span>
                {store.website && (
                  <>
                    <br />
                    <a href={store.website} target="_blank" rel="noopener noreferrer nofollow">Website</a>
                  </>
                )}
              </li>
            ))}
          </ul>
        ) : (
          <p class="status-empty">No dedicated dispensaries currently in town limits. Residents typically shop in Bridgton, Casco, or Windham (10-30 min). See our individual town guides for the current opt-in status.</p>
        )}
        <p>{town.operatorNote}</p>
      </div>
    ))}
  </section>

  <section>
    <h2>Regional Context</h2>
    <p>The Sebago Lakes region spans southern Cumberland and Oxford Counties, anchored by Sebago Lake and State Route 302. Bridgton and Casco are the primary retail nodes, both clustered along Route 302 with high visibility for tourism traffic. Windham anchors the eastern edge of the corridor closer to Portland's metro area.</p>
    <p>For operators evaluating this region: the Route 302 corridor is where cannabis retail is most established. Smaller towns like Naples, Sebago, and Raymond have seasonal demand but lack dedicated dispensaries. A delivery-based operation from Bridgton or Casco could capture significant market share across these unserved communities.</p>
  </section>

  <section>
    <h2>Nearby Markets to Compare</h2>
    <table aria-label="Nearby western Maine cannabis retail markets">
      <thead>
        <tr>
          <th scope="col">Market</th>
          <th scope="col">Dispensaries</th>
          <th scope="col">Strategic position</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Bridgton</td><td>3+</td><td>Primary lakes-region cluster; competitive but proven demand.</td></tr>
        <tr><td>Casco</td><td>2</td><td>Route 302 visibility; relevant to Sebago Lake traffic.</td></tr>
        <tr><td>Windham</td><td>4-5</td><td>Greater Portland edge market with stronger year-round commercial traffic.</td></tr>
        <tr><td>Naples / Sebago / Raymond / Standish</td><td>0-1 each</td><td>Cover as no-active-store towns and point readers to nearby licensed options.</td></tr>
      </tbody>
    </table>
  </section>

  <div class="further-reading">
    <h2>Related Guides</h2>
    <ul>
      <li><a href="/guides/bridgton-dispensary-guide">Bridgton Dispensary Guide</a></li>
      <li><a href="/guides/casco-dispensary-guide">Casco Dispensary Guide</a></li>
      <li><a href="/guides/windham-dispensary-guide">Windham Dispensary Guide</a></li>
      <li><a href="/guides/naples-dispensary-guide">Naples Dispensary Guide</a></li>
      <li><a href="/guides/raymond-dispensary-guide">Raymond Dispensary Guide</a></li>
      <li><a href="/guides/standish-dispensary-guide">Standish Dispensary Guide</a></li>
      <li><a href="/guides/sebago-dispensary-guide">Sebago Dispensary Guide</a></li>
      <li><a href="/guides/gray-dispensary-guide">Gray Dispensary Guide</a></li>
      <li><a href="/guides/fryeburg-dispensary-guide">Fryeburg Dispensary Guide</a></li>
      <li><a href="/guides/maine-cannabis-opt-in-tracker">Maine Cannabis Opt-In Tracker</a></li>
    </ul>
  </div>

  <section>
    <h2>Verification Checklist Before Choosing a Town</h2>
    <ul>
      <li>Confirm the town has opted in to the adult-use license type you want to operate.</li>
      <li>Read the current municipal ordinance for buffers, caps, public-hearing requirements, and local fees.</li>
      <li>Verify the property is not disqualified by school, childcare, residential, or shoreland zoning rules.</li>
      <li>Check the current OCP license list again; stores can open, close, move, or change status.</li>
      <li>Compare nearby-store density against seasonal traffic instead of relying on resident population alone.</li>
    </ul>
  </section>

  <p class="disclaimer"><strong>Disclaimer:</strong> Information is based on verified operator records and public OCP data. Town opt-in statuses and license availability can change. Verify current status with the Maine OCP and municipalities before making business decisions.</p>

  <section class="faq-section">
    <h2>Frequently Asked Questions</h2>
    <Faq
      questions={[
        { q: "Are there cannabis dispensaries in the western Maine lakes region?", a: "Yes. Bridgton has 3+ dispensaries, Casco has 2, and Windham has multiple operators. Smaller towns like Naples, Sebago, Raymond, and Standish currently have no or very limited dispensaries but are served by nearby Bridgton and Casco options." },
        { q: "Where can I buy cannabis near Sebago Lake?", a: "The nearest dispensaries to Sebago Lake are in Bridgton (Sweet Dirt, Canuvo) and Casco (Blue Lobster Cannabis, Landrace Cannabis Co.). Naples and Sebago residents typically drive 10-20 minutes to reach these options." },
      ]}
    />
  </section>
</article>
</Layout>
<script type="application/ld+json" set:text={faqPageJsonLd} is:inline></script>
