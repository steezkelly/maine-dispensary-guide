 article { max-width: 720px; margin: 0 auto; }.article-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }.subtitle { font-size: 1.25rem; color: var(--color-text-light); } section { margin-bottom: 2rem; } section h2 { margin-top: 0; padding-top: 1rem; } section h3 { margin-top: 1.5rem; margin-bottom: 0.75rem; } ul, ol { padding-left: 1.5rem; } li { margin-bottom: 0.5rem; }.disclaimer { background: var(--color-disclaimer-bg); border: 1px solid var(--color-disclaimer-border); padding: 1rem; border-radius: 0.5rem; font-size: 0.875rem; color: var(--color-disclaimer-text); } table { width: 100%; border-collapse: collapse; margin: 1rem 0; } th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid var(--color-border); } th { background: var(--color-background); } section.fact-box { background: linear-gradient(135deg, var(--color-background) 0%, #fff 100%); border-top: 3px solid var(--color-primary); padding: 1.5rem; border-radius: 0.5rem; margin: 1.5rem 0; }.answer-capsule { background: rgba(88, 129, 87, 0.08); border-left: 3px solid var(--color-primary); padding: 1rem 1.25rem; margin: 1rem 0; font-weight: 500; } details { margin-bottom: 0.75rem; padding: 0.5rem; background: rgba(88, 129, 87, 0.05); border-radius: 0.5rem; } summary { cursor: pointer; font-weight: 600; } summary:hover { color: var(--color-primary); } 
