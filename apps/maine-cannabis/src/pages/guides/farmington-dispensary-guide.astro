<article>
  <div class="article-header">
    <h1>Farmington, ME Dispensary Guide</h1>
    <p class="subtitle">Blue Sky Maine's medical and recreational dispensaries — central Maine's vertically integrated cannabis operator</p>
  </div>

  <section class="fact-box">
    <h2>Farmington Cannabis Quick Facts</h2>
    <table aria-label="Farmington cannabis market overview">
      <thead><tr><th scope="col">Fact</th><th scope="col">Details</th></tr></thead>
      <tbody>
        <tr><td><strong>Medical Legal</strong></td><td>Yes</td></tr>
