const faqPageJsonLd = JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Are there cannabis dispensaries in Farmington, Maine?","acceptedAnswer":{"@type":"Answer","text":"Yes. Blue Sky Maine operates both a medical dispensary at 361 Wilton Rd and a recreational dispensary at 104 Fairbanks Rd in Farmington. They are vertically integrated with a C1D1 certified extraction facility and MOFGA-certified organic flower."}},{"@type":"Question","name":"What is Blue Sky Maine in Farmington?","acceptedAnswer":{"@type":"Answer","text":"Blue Sky Maine is a vertically integrated cannabis company with two Farmington locations. The medical store is at 361 Wilton Rd (207-778-0726) and the recreational 21+ store is at 104 Fairbanks Rd (207-578-7328). They operate an extraction lab producing live resin, shatter, batter, diamonds, and more."}},{"@type":"Question","name":"Does Farmington allow recreational cannabis?","acceptedAnswer":{"@type":"Answer","text":"Yes. Farmington permits both medical and recreational cannabis. Blue Sky Maine's recreational storefront at 104 Fairbanks Rd serves the central Maine market with MOFGA-certified organic flower."}},{"@type":"Question","name":"What makes Farmington a unique cannabis market?","acceptedAnswer":{"@type":"Answer","text":"Farmington sits in Franklin County, central to the University of Maine at Farmington and serves the agricultural belt of western Maine. Blue Sky Maine's vertical integration — cultivation, extraction, and retail in one operation — is distinctive for a town of Farmington's size."}},{"@type":"Question","name":"What dispensaries are near Farmington?","acceptedAnswer":{"@type":"Answer","text":"In Farmington: Blue Sky Maine (medical and recreational). Nearby options include Waterville dispensaries (Cannabis Haven, AstroTerf) ~25 mi south, and Lewiston area dispensaries ~35 mi southwest."}}]});
