---
import Layout from '../../layouts/Layout.astro';
import Faq from '../../components/Faq.astro';

const article = { author: "Eliot Nash", authorId: "eliot-nash", authorTitle: "Market & Real Estate Analyst", publishDate: "2026-05-13", modifiedDate: "2026-05-13", section: "City Guides" };
const topics = ["city", "market"];
const faqPageJsonLd = JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Are there any cannabis dispensaries in Limington, Maine?","acceptedAnswer":{"@type":"Answer","text":"No. Limington has no dedicated cannabis dispensaries within town limits. The nearest option is Hidden Greens in Buxton (~10 mi, medical + delivery), and Founding Farmers in Limerick (~6 mi, medical)."}},{"@type":"Question","name":"Is recreational cannabis legal in Limington, Maine?","acceptedAnswer":{"@type":"Answer","text":"Cannabis is legal statewide in Maine for adults 21+. Limington has not opted in to local cannabis retail. Purchase and possession remain legal under state law."}},{"@type":"Question","name":"Where can I buy cannabis near Limington, ME?","acceptedAnswer":{"@type":"Answer","text":"Medical: Founding Farmers in Limerick (~6 mi) or Hidden Greens in Buxton (~10 mi, offers delivery). Recreational: Sweet Dirt/Canuvo in Bridgton (~20 mi)."}}]});
---
<Layout title="Limington, ME Dispensary Guide — Nearest Cannabis Options 2026" description="Limington, Maine cannabis guide. No dispensaries in Limington — nearest are Limerick (6 mi) and Bridgton (20 mi) for 2026." heroImage="/images/heroes/limington-dispensary-guide.jpg" article={article} topics={topics} >
<style>
  article { max-width: 720px; margin: 0 auto; }
  .article-header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }
  .subtitle { font-size: 1.125rem; color: var(--color-text-light); }
  section { margin-bottom: 2.5rem; }
  section h2, section h3 { margin-top: 1.5rem; }
  section h2:first-child { margin-top: 0; }
  table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
  th, td { padding: 0.6rem 0.75rem; text-align: left; border-bottom: 1px solid var(--color-border); }
  th { background: var(--color-background); }
  ul, ol { padding-left: 1.5rem; }
  li { margin-bottom: 0.4rem; }
  .disclaimer { background: var(--color-disclaimer-bg); border: 1px solid var(--color-disclaimer-border); padding: 1rem; border-radius: 0.5rem; font-size: 0.875rem; color: var(--color-disclaimer-text); }
  .fact-box { background: rgba(88, 129, 87, 0.1); padding: 1.75rem; border-radius: 1rem; border-left: 4px solid var(--color-primary); }
  .fact-box h2 { margin-top: 0; font-size: 1.25rem; }
  .fact-box table { margin: 0; }
  .further-reading { background: rgba(88, 129, 87, 0.05); padding: 1.5rem; border-radius: 1rem; margin-top: 3rem; }
  .further-reading h2 { margin-top: 0; font-size: 1.25rem; }
</style>

<article>
  <div class="article-header">
    <h1>Limington, ME Dispensary Guide</h1>
    <p class="subtitle">Cannabis options near Limington in the Saco Lakes region</p>
  </div>

  <section class="fact-box">
    <h2>Limington Cannabis Quick Facts</h2>
    <table aria-label="Limington cannabis market overview">
      <thead><tr><th scope="col">Fact</th><th scope="col">Details</th></tr></thead>
      <tbody>
        <tr><td><strong>Medical Legal</strong></td><td>Yes</td></tr>
        <tr><td><strong>Recreational Legal</strong></td><td>Yes — statewide</td></tr>
        <tr><td><strong>Dispensaries in Town</strong></td><td>0</td></tr>
        <tr><td><strong>Opt-In Status</strong></td><td>NOT opted in</td></tr>
        <tr><td><strong>Nearest Medical</strong></td><td>Founding Farmers, Limerick (~6 mi)</td></tr>
        <tr><td><strong>Nearest Recreational</strong></td><td>Sweet Dirt / Canuvo, Bridgton (~20 mi)</td></tr>
        <tr><td><strong>Delivery Nearby</strong></td><td>Hidden Greens, Buxton (~10 mi, offers delivery)</td></tr>
        <tr><td><strong>Population</strong></td><td>~3,700 (2020 Census)</td></tr>
        <tr><td><strong>County</strong></td><td>York County</td></tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Overview</h2>
    <p>Limington has <strong>no cannabis dispensaries</strong>. With roughly 3,700 residents near Sebago and Little Ossipee lakes, the town's nearest medical option is just 6 miles away in Limerick (Founding Farmers). For recreational purchases, residents typically drive ~20 miles to Bridgton where Sweet Dirt Cannabis and Canuvo operate. Hidden Greens in Buxton (~10 mi) offers delivery service to the area.</p>
  </section>

  <section>
    <h2>Nearest Dispensaries to Limington</h2>

    <h3>Medical Options</h3>
    <ul>
      <li><strong>Founding Farmers</strong> — 16 Main Street, Limerick, ME (~6 mi). Phone: (207) 315-5259. Shortest drive for medical patients.</li>
      <li><strong>Hidden Greens</strong> — 370 Narragansett Trail, Buxton, ME (~10 mi). Medical dispensary with delivery service.</li>
    </ul>

    <h3>Recreational (Adult-Use) Options</h3>
    <ul>
      <li><strong>Sweet Dirt Cannabis</strong> — Bridgton, ME (~20 mi). Adult-use recreational.</li>
      <li><strong>Canuvo</strong> — Bridgton, ME (~20 mi). Curated recreational storefront.</li>
    </ul>
  </section>

  <section>
    <h2>The Delivery Advantage</h2>
    <p>Hidden Greens in Buxton offers delivery, which serves Limington well — medical patients don't need to leave town to get their products. For recreational customers without a medical card, however, a trip to Bridgton is required.</p>
  </section>

  <section>
    <div class="further-reading">
      <h2>Related Guides</h2>
      <ul>
        <li><a href="/guides/limerick-dispensary-guide">Limerick Dispensary Guide</a></li>
        <li><a href="/guides/buxton-dispensary-guide">Buxton Dispensary Guide</a></li>
        <li><a href="/guides/bridgton-dispensary-guide">Bridgton Dispensary Guide</a></li>
        <li><a href="/guides/maine-cannabis-opt-in-tracker">Maine Cannabis Opt-In Tracker</a></li>
      </ul>
    </div>
  </section>

  <section class="faq-section">
    <h2>Frequently Asked Questions</h2>
    <Faq
      questions={[
        { q: "Are there dispensaries in Limington, Maine?", a: "No. Limington has no dispensaries. Founding Farmers in Limerick is the nearest at ~6 mi (medical). Hidden Greens in Buxton (~10 mi) offers delivery." },
        { q: "Is recreational cannabis legal in Limington?", a: "Cannabis is legal statewide for adults 21+. Limington has not opted in to local retail. Purchase and possession remain legal." },
        { q: "Where can I buy recreational cannabis near Limington?", a: "Sweet Dirt and Canuvo in Bridgton (~20 mi) are the nearest adult-use dispensary options." },
        { q: "Does any dispensary deliver to Limington?", a: "Hidden Greens in Buxton (~10 mi) offers delivery services to the surrounding area." },
      ]}
    />
  </section>

  <p class="disclaimer"><strong>Disclaimer:</strong> Information is provided for general reference only. Municipal opt-in statuses can change. Always verify details directly with the town office.</p>
</article>
</Layout>
<script type="application/ld+json" set:text={faqPageJsonLd} is:inline></script>
