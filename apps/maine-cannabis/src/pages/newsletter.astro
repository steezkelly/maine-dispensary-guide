---
import Layout from '../layouts/Layout.astro';
import PineTree from '@network/ui/PineTree';

const article = {
  author: "Steve Kelly",
  authorId: "steve-kelly",
  authorTitle: "Founder & Publisher",
  publishDate: "2026-04-25",
  modifiedDate: "2026-04-25",
  section: "Newsletter"
};

const benefits = [
  {
    icon: "◆",
    title: "Maine Licensing Updates",
    desc: "OCP policy changes, new application windows, and fee adjustments — delivered as they happen, not months later."
  },
  {
    icon: "◆",
    title: "Market Intelligence",
    desc: "Quarterly market snapshots, new dispenser count changes, and emerging opportunity towns before they saturate."
  },
  {
    icon: "◆",
    title: "Operator Interviews",
    desc: "Founders from Portland, Bangor, and rural Maine share what they wish they'd known before they opened."
  },
  {
    icon: "◆",
    title: "New Guide Alerts",
    desc: "When we publish new city guides, technical deep-dives, or updated compliance walkthroughs — you're first to know."
  }
];

const recentIssues = [
  { date: "April 20, 2026", subject: "2026 Tax Changes: What 14% Retail Tax Means for Your Margins", teaser: "The retail cannabis tax jumps from 10% to 14% on Jan 1, 2026. Here's the dollar impact on a $2M revenue shop." },
  { date: "April 14, 2026", subject: "Portland's 12-Dispensary Market: Is It Too Late to Enter?", teaser: "We ran the math on Portland's density vs. Bangor's 4-store opportunity. The numbers are stark." },
  { date: "March 28, 2026", subject: "Delivery License Guide: The Only Statewide Opportunity Left in Maine", teaser: "A Presque Isle courier license + delivery operation could serve 67,000 Aroostook residents with zero competition." }
];
---

<Layout
  title="Maine Cannabis Newsletter — Weekly Operator Intelligence"
  description="The weekly newsletter for Maine cannabis entrepreneurs. Licensing updates, market intelligence, and operator interviews. Free to subscribe."
  heroImage="/images/heroes/newsletter.jpg"
  article={article}
>
  <style>

  .newsletter-page {
    max-width: 850px;
    margin: 0 auto;
  }

  .article-header {
    margin-bottom: 4rem;
    text-align: center;
  }

  .header-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .article-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .subscribe-section {
    margin-bottom: 4rem;
  }

  .subscribe-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    padding: 3rem;
  }

  .subscribe-left h2 {
    font-family: var(--font-serif);
    color: var(--color-primary);
    font-size: 1.375rem;
    margin-bottom: 0.75rem;
  }

  .subscribe-left > p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .subscribe-perks {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .subscribe-perks li {
    font-size: 0.9rem;
    color: var(--color-text-light);
    padding: 0.4rem 0;
    padding-left: 1.25rem;
    position: relative;
  }

  .subscribe-perks li::before {
    content: '◆';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.625rem;
    top: 0.55rem;
  }

  .subscribe-right {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .inline-signup-form {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .form-input {
    width: 100%;
    padding: 1rem 1.25rem;
    border: 2px solid var(--color-border);
    border-radius: 1rem;
    font-size: 1rem;
    font-family: inherit;
    background: var(--color-background);
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .form-select {
    width: 100%;
    padding: 1rem 1.25rem;
    border: 2px solid var(--color-border);
    border-radius: 1rem;
    font-size: 1rem;
    font-family: inherit;
    background: var(--color-background);
    color: var(--color-text);
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .form-select:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .form-btn {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: 1.125rem;
    border-radius: 1rem;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    font-family: inherit;
  }

  .form-btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
  }

  .form-note {
    font-size: 0.8125rem;
    color: var(--color-text-light);
    text-align: center;
    margin-top: 0.75rem;
  }

  .form-note a {
    color: var(--color-accent);
  }

  .what-you-get {
    margin-bottom: 4rem;
  }

  .what-you-get h2 {
    font-family: var(--font-serif);
    color: var(--color-primary);
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .benefit-card {
    display: flex;
    gap: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    padding: 1.75rem;
    transition: border-color 0.2s;
  }

  .benefit-card:hover {
    border-color: var(--color-primary);
  }

  .benefit-icon {
    font-size: 1.25rem;
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .benefit-card h3 {
    font-size: 0.9375rem;
    color: var(--color-primary);
    margin-bottom: 0.4rem;
  }

  .benefit-card p {
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .sample-issues {
    margin-bottom: 4rem;
  }

  .sample-issues h2 {
    font-family: var(--font-serif);
    color: var(--color-primary);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .section-intro {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .issue-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .issue-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    padding: 1.5rem 1.75rem;
    transition: border-color 0.2s;
  }

  .issue-card:hover {
    border-color: var(--color-accent);
  }

  .issue-date {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    display: block;
    margin-bottom: 0.5rem;
  }

  .issue-card h3 {
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .issue-card p {
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .sample-note {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-top: 1.5rem;
  }

  .sample-note a {
    color: var(--color-accent);
    font-weight: 600;
  }

  .why-not-elsewhere {
    margin-bottom: 4rem;
    padding: 2.5rem;
    background: linear-gradient(135deg, rgba(88, 129, 87, 0.04) 0%, rgba(13, 78, 80, 0.04) 100%);
    border-radius: 1.5rem;
    border: 1px solid rgba(88, 129, 87, 0.12);
  }

  .why-not-elsewhere h2 {
    font-family: var(--font-serif);
    color: var(--color-primary);
    font-size: 1.375rem;
    margin-bottom: 1rem;
  }

  .why-not-elsewhere p {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .why-not-elsewhere p:last-child {
    margin-bottom: 0;
  }

  .why-not-elsewhere em {
    color: var(--color-text);
    font-style: normal;
    font-weight: 600;
  }

  .archive-cta {
    text-align: center;
    padding: 2.5rem;
    background: var(--color-surface);
    border-radius: 1.5rem;
    border: 1px dashed var(--color-border);
  }

  .archive-inner h3 {
    font-family: var(--font-serif);
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .archive-inner p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .archive-link {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: var(--color-primary);
    color: white;
    border-radius: 1rem;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }

  .archive-link:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .subscribe-card {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem;
    }

    .subscribe-left {
      text-align: center;
    }

    .subscribe-perks {
      display: inline-block;
      text-align: left;
    }
  }

  @media (max-width: 480px) {
    .article-header h1 { font-size: 1.75rem; }
    .benefits-grid { grid-template-columns: 1fr; }
  }

</style>
<article class="newsletter-page">
    <div class="article-header">
      <div class="header-eyebrow">
        <PineTree size={16} color="var(--color-accent)" />
        <span>Free Weekly Publication</span>
      </div>
      <h1>Maine Cannabis Insider</h1>
      <p class="subtitle">The weekly intelligence brief for Maine cannabis entrepreneurs — licensing updates, market analysis, and operator interviews delivered every Tuesday.</p>
    </div>

    <section class="subscribe-section">
      <div class="subscribe-card">
        <div class="subscribe-left">
          <h2>Join 1,200+ Maine Cannabis Operators</h2>
          <p>Free forever. No spam. Unsubscribe anytime. Published every Tuesday morning.</p>
          <ul class="subscribe-perks">
            <li>◆ Weekly licensing and regulatory updates</li>
            <li>◆ Market intelligence by region and license type</li>
            <li>◆ Founder interviews from Maine operators</li>
            <li>◆ New guide announcements</li>
          </ul>
        </div>
        <div class="subscribe-right">
          <div class="beehiiv-embed" id="beehiiv-embed-form">
            <form
              id="newsletter-signup"
              action="https://formspree.io/f/xvgzlowz"
              method="POST"
              class="inline-signup-form"
            >
              <div class="form-group">
                <label for="sub-email" class="sr-only">Your Email</label>
                <input
                  type="email"
                  id="sub-email"
                  name="email"
                  placeholder="you@yourcompany.com"
                  required
                  autocomplete="email"
                  class="form-input"
                />
              </div>
              <div class="form-group">
                <label for="sub-stage" class="sr-only">Your Stage</label>
                <select id="sub-stage" name="stage" class="form-select">
                  <option value="" disabled selected>Your stage...</option>
                  <option value="startup">Pre-license — researching</option>
                  <option value="applying">Application in progress</option>
                  <option value="operating">Already operating</option>
                  <option value="ancillary">Service provider / investor</option>
                </select>
              </div>
              <button type="submit" class="form-btn">Subscribe Free</button>
              <input type="hidden" name="_subject" value="Newsletter Subscription — Maine Dispensary Guide" />
              <input type="hidden" name="_tags" value="newsletter" />
            </form>
            <p class="form-note">Or <a href="https://app.beehiiv.com/subscribe" target="_blank" rel="noopener noreferrer">subscribe directly on Beehiiv</a> for a better experience.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="what-you-get">
      <h2>What You'll Receive</h2>
      <div class="benefits-grid">
        {benefits.map(b => (
          <div class="benefit-card">
            <span class="benefit-icon">{b.icon}</span>
            <div>
              <h3>{b.title}</h3>
              <p>{b.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="sample-issues">
      <h2>Recent Issues</h2>
      <p class="section-intro">Every issue is written for Maine operators specifically — not national cannabis news, not generic business advice.</p>
      <div class="issue-list">
        {recentIssues.map(issue => (
          <div class="issue-card">
            <span class="issue-date">{issue.date}</span>
            <h3>{issue.subject}</h3>
            <p>{issue.teaser}</p>
          </div>
        ))}
      </div>
      <p class="sample-note">The full archive is available at <a href="https://mainedispensaryguide.com/newsletter" target="_blank" rel="noopener noreferrer">mainedispensaryguide.com/newsletter</a> once you subscribe.</p>
    </section>

    <section class="why-not-elsewhere">
      <h2>Why This Isn't Just Another Newsletter</h2>
      <p>Maine cannabis operators have access to national publications like MJBizDaily and Cannabis Business Times. Those cover the US industry broadly. This newsletter covers <em>Maine specifically</em> — OCP rule changes that only affect Maine operators, town-by-town market analysis you won't find anywhere else, and interviews with operators who opened dispensaries in Lewiston, Bangor, and Waterville.</p>
      <p>If you're building a business in Maine's cannabis market, this newsletter is written for you.</p>
    </section>

    <section class="archive-cta">
      <div class="archive-inner">
        <h3>Missed an Issue?</h3>
        <p>All past issues are archived on Beehiiv. Subscribe above to receive them weekly, or browse the full archive.</p>
        <a href="https://app.beehiiv.com/subscribe" target="_blank" rel="noopener noreferrer" class="archive-link">
          Browse Past Issues →
        </a>
      </div>
    </section>
  </article>
</Layout>

</Layout>
