---
import Layout from '../layouts/Layout.astro';
import PineTree from '../components/PineTree.astro';
import Leaf from '../components/Leaf.astro';

const stats = [
  { label: "Annual Sales", value: "$246M" },
  { label: "Active Stores", value: "179" },
  { label: "Price/Gram", value: "$6.62" }
];

const cityLinks = [
  { name: "Portland", href: "/guides/portland-dispensary-guide/" },
  { name: "Lewiston", href: "/guides/lewiston-dispensary-guide/" },
  { name: "Bangor", href: "/guides/bangor-dispensary-guide/" },
  { name: "Augusta", href: "/guides/augusta-dispensary-guide/" },
  { name: "South Portland", href: "/guides/south-portland-dispensary-guide/" },
  { name: "Biddeford", href: "/guides/biddeford-dispensary-guide/" },
  { name: "Auburn", href: "/guides/auburn-dispensary-guide/" },
];

const recentGuides = [
  { title: "2026 Startup Costs Breakdown", href: "/guides/maine-dispensary-costs/", date: "April 4, 2026", badge: "Updated" },
  { title: "Bangor Market Analysis", href: "/guides/bangor-dispensary-guide/", date: "April 3, 2026", badge: "Updated" },
  { title: "Real Estate & Zoning Guide", href: "/guides/maine-cannabis-real-estate/", date: "April 2, 2026", badge: "Updated" },
  { title: "2026 Launch Checklist", href: "/launch-checklist/", date: "April 1, 2026", badge: "New" },
];

const journeySteps = [
  { num: "01", title: "Get the Launch Checklist", desc: "The complete roadmap from concept to opening day — every step in one place.", href: "/launch-checklist/" },
  { num: "02", title: "Understand Licensing", desc: "OCP Adult-Use Retail License, municipal opt-in requirements, and realistic application timelines.", href: "/guides/maine-dispensary-license/" },
  { num: "03", title: "Run the Numbers", desc: "Model your startup costs against Maine's $246M market and find your break-even point.", href: "/roi-calculator/" },
  { num: "04", title: "Find Your Location", desc: "Zoning rules, school buffer requirements, commercial lease negotiation, and municipal approval.", href: "/guides/maine-cannabis-real-estate/" },
];
---

<Layout 
  title="Maine Cannabis Entrepreneur Resource: 44 Expert Guides (2026)" 
  description="Complete guide to opening a Maine cannabis dispensary. Licensing, compliance, real estate, and 280E taxation explained. Everything you need to open and scale." 
  heroImage="/images/heroes/homepage.jpg"
  article={{ author: "Maine Dispensary Guide Editorial Team", publishDate: "2026-01-01", modifiedDate: "2026-04-18", section: "Home" }}
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO: Heritage Authority — Topographic + Dramatic Typography
  ═══════════════════════════════════════════════════════════════ -->
  <section class="hero-manifesto" aria-labelledby="hero-heading">
    <!-- Topographic background pattern -->
    <div class="topo-bg" aria-hidden="true">
      <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
        <defs>
          <linearGradient id="topoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="var(--color-primary)" stop-opacity="0.08"/>
            <stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0.04"/>
          </linearGradient>
        </defs>
        <!-- Contour lines -->
        <path d="M-50,300 Q150,200 350,350 T750,250" fill="none" stroke="url(#topoGrad)" stroke-width="1.5"/>
        <path d="M-50,350 Q100,250 300,380 T750,300" fill="none" stroke="url(#topoGrad)" stroke-width="1"/>
        <path d="M-50,400 Q80,320 280,420 T750,360" fill="none" stroke="url(#topoGrad)" stroke-width="1.5"/>
        <path d="M-50,450 Q60,380 260,480 T750,420" fill="none" stroke="url(#topoGrad)" stroke-width="1"/>
        <path d="M-50,500 Q40,440 240,540 T750,480" fill="none" stroke="url(#topoGrad)" stroke-width="1"/>
        <path d="M100,50 Q200,150 400,100 T850,150" fill="none" stroke="url(#topoGrad)" stroke-width="0.75"/>
        <path d="M50,100 Q180,180 380,130 T830,180" fill="none" stroke="url(#topoGrad)" stroke-width="0.75"/>
        <!-- Vertical accent lines -->
        <line x1="680" y1="0" x2="680" y2="600" stroke="url(#topoGrad)" stroke-width="0.5" stroke-dasharray="4,8"/>
        <line x1="720" y1="0" x2="720" y2="600" stroke="url(#topoGrad)" stroke-width="0.5" stroke-dasharray="4,8"/>
      </svg>
    </div>

    <div class="hero-inner">
      <!-- Left: Editorial content block -->
      <div class="hero-editorial">
        <div class="edition-mark">
          <span class="edition-year">Est. 2026</span>
          <span class="edition-divider">◆</span>
          <span class="edition-state">Maine, USA</span>
        </div>
        
        <h1 id="hero-heading" class="hero-title">
          The Professional<br/>
          <span class="hero-title-accent">Gateway</span> to<br/>
          Maine Cannabis
        </h1>
        
        <p class="hero-descriptor">
          Expert-vetted guidance for licensing, compliance, and growth in the Pine Tree State. 
          Forty-four guides. One authoritative source.
        </p>
        
        <div class="hero-actions">
          <a href="/guides/maine-dispensary-license/" class="btn-primary">Start Your Application</a>
          <a href="/roi-calculator/" class="btn-ghost">Calculate Your ROI</a>
        </div>
      </div>

      <!-- Right: Visual anchor with botanical -->
      <div class="hero-visual" aria-hidden="true">
        <div class="visual-anchor">
          <div class="anchor-ring ring-1"></div>
          <div class="anchor-ring ring-2"></div>
          <div class="anchor-ring ring-3"></div>
          <div class="botanical-cluster">
            <PineTree size={180} color="var(--color-primary)" class="cluster-pine" />
            <Leaf size={100} color="var(--color-accent)" class="cluster-leaf cluster-leaf-1" />
            <Leaf size={70} color="var(--color-soft-green)" class="cluster-leaf cluster-leaf-2" />
          </div>
          <div class="visual-caption">
            <span class="caption-label">Maine Dispensary Guide</span>
            <span class="caption-ref">Editorial Resource</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom flourish -->
    <div class="hero-flourish" aria-hidden="true">
      <svg viewBox="0 0 1200 40" preserveAspectRatio="none">
        <path d="M0,20 Q300,0 600,20 T1200,20" fill="none" stroke="var(--color-border)" stroke-width="1"/>
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       MARKET BAR: Refined stats strip
  ═══════════════════════════════════════════════════════════════ -->
  <section class="market-intel" aria-label="Maine Market Statistics">
    <div class="intel-inner">
      <div class="intel-stats">
        {stats.map((stat, i) => (
          <>
            <div class="intel-stat">
              <span class="stat-value">{stat.value}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
            {i < stats.length - 1 && <div class="stat-separator" aria-hidden="true">—</div>}
          </>
        ))}
      </div>
      <a href="/market-stats/" class="intel-link">
        Full Market Report
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       MISSION: Editorial typography treatment
  ═══════════════════════════════════════════════════════════════ -->
  <section class="mission-manifesto" aria-labelledby="mission-heading">
    <div class="mission-inner">
      <div class="mission-header">
        <span class="section-eyebrow">Our Purpose</span>
        <h2 id="mission-heading" class="mission-title">Build Your Passion Project</h2>
      </div>
      
      <div class="mission-text">
        <p class="mission-lead">
          Opening a dispensary in Maine is a real business with real regulations. But if you have a vision for what your shop could be — this guide exists to help you get there without getting tripped up on compliance.
        </p>
        
        <div class="mission-body">
          <p>
            We built this resource for entrepreneurs who are serious about doing this correctly: the ones who want to understand the M.R.S. citations, negotiate their own commercial lease, and file their 280E deductions properly rather than relying on luck.
          </p>
          <p>
            Everything here is specific to Maine — the towns that have opted in, the fee structures that OCP publishes, the real estate patterns that only emerge when you know the market. If you are considering Maine cannabis, you need this specificity.
          </p>
        </div>
        
        <a href="/about/" class="read-more">
          Read About Our Methodology
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
    
    <!-- Decorative botanical -->
    <div class="mission-botanical" aria-hidden="true">
      <svg viewBox="0 0 200 400" fill="none">
        <path d="M100,380 C60,320 20,240 40,160 C60,80 100,40 100,40 C100,40 140,80 160,160 C180,240 140,320 100,380" stroke="var(--color-primary)" stroke-width="1" opacity="0.15"/>
        <path d="M100,350 C75,300 50,240 60,180 C70,120 100,100 100,100" stroke="var(--color-accent)" stroke-width="0.75" opacity="0.1"/>
        <path d="M100,350 C125,300 150,240 140,180 C130,120 100,100 100,100" stroke="var(--color-accent)" stroke-width="0.75" opacity="0.1"/>
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       MARKET OVERVIEW: Asymmetric two-column layout
  ═══════════════════════════════════════════════════════════════ -->
  <section class="market-overview" aria-labelledby="overview-heading">
    <div class="overview-inner">
      <div class="overview-header">
        <span class="section-eyebrow">The Opportunity</span>
        <h2 id="overview-heading">Why Maine, Why Now</h2>
      </div>
      
      <div class="overview-grid">
        <div class="overview-main">
          <p>
            Maine has a medical program operating since 1999 and an adult-use market open since 2020. That combination means established patterns, more data, and a clearer picture of what works than newer state markets.
          </p>
          <p>
            The Office of Cannabis Policy (OCP) oversees the industry with regulations mature enough to be predictable — you can read the actual rules, follow the actual processes, and know where the actual pitfalls are.
          </p>
          <p>
            Towns must opt-in before a dispensary can operate within their borders. For entrepreneurs, this means location research is not optional — it is the first and most important strategic decision you will make.
          </p>
        </div>
        
        <div class="overview-aside">
          <div class="aside-card">
            <span class="aside-stat">$246M</span>
            <span class="aside-label">Adult-use sales in 2025</span>
          </div>
          <div class="aside-card">
            <span class="aside-stat">179</span>
            <span class="aside-label">Active stores statewide</span>
          </div>
          <div class="aside-card highlight">
            <span class="aside-stat">41+</span>
            <span class="aside-label">Opt-in municipalities</span>
          </div>
          <p class="aside-note">
            The opportunity is in understanding which towns have been left behind.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       OPERATIONAL EXCELLENCE: Full-width with offset content
  ═══════════════════════════════════════════════════════════════ -->
  <section class="operations-excellence" aria-labelledby="ops-heading">
    <div class="ops-inner">
      <div class="ops-header">
        <span class="section-eyebrow">Day-to-Day Reality</span>
        <h2 id="ops-heading">What It Takes to Run One</h2>
      </div>
      
      <div class="ops-content">
        <p>
          Getting a license is just the start. The actual work of running a dispensary — managing inventory, staying compliant with OCP security rules, training staff who can actually explain the difference between a sativa and an indica — is where most operators discover whether they chose the right business.
        </p>
        <p>
          Maine customers, especially in the Portland metro area and mid-coast college towns, care about craft and transparency. They ask questions about cultivation methods. They read menu listings before they visit. The shops that do the work on staff training — that treat budtenders as product experts rather than cashiers — tend to build real loyalty.
        </p>
        
        <div class="ops-topics">
          <a href="/guides/maine-dispensary-pos/" class="topic-tag">Point-of-Sale Systems</a>
          <a href="/glossary/#metrc" class="topic-tag">Metrc Compliance</a>
          <a href="/guides/maine-cannabis-taxation-280e/" class="topic-tag">280E Tax Strategy</a>
          <a href="/launch-checklist/" class="topic-tag">Launch Checklist</a>
        </div>
        
        <p class="ops-closing">
          The operators who survive past year two tend to share certain habits: meticulous record-keeping, proactive communication with OCP, and a genuine interest in what their customers want. The ones who do not make it tend to have ignored one or more of those three.
        </p>
      </div>
    </div>
    
    <!-- Decorative element -->
    <div class="ops-decoration" aria-hidden="true">
      <svg viewBox="0 0 100 100" fill="none">
        <circle cx="50" cy="50" r="48" stroke="var(--color-primary)" stroke-width="0.5" opacity="0.1"/>
        <circle cx="50" cy="50" r="35" stroke="var(--color-primary)" stroke-width="0.5" opacity="0.15"/>
        <circle cx="50" cy="50" r="20" stroke="var(--color-primary)" stroke-width="0.5" opacity="0.2"/>
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       CORE HUBS: Editorial card grid with hover personality
  ═══════════════════════════════════════════════════════════════ -->
  <section class="core-hubs" aria-labelledby="hubs-heading">
    <div class="hubs-inner">
      <div class="hubs-header">
        <span class="section-eyebrow">Explore</span>
        <h2 id="hubs-heading">Core Topics</h2>
        <p class="hubs-subtitle">Pick a category to dig into.</p>
      </div>
      
      <div class="hubs-grid">
        <a href="/guides/maine-dispensary-license/" class="hub-card">
          <div class="hub-card-inner">
            <div class="hub-icon">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 8h14l10 10v22a4 4 0 01-4 4H14a4 4 0 01-4-4V12a4 4 0 014-4z"/>
                <path d="M28 8v10h10"/>
                <path d="M18 26h12M18 34h8"/>
              </svg>
            </div>
            <h3>Licensing</h3>
            <p>Step-by-step state and local approval maps.</p>
            <span class="hub-cta">Explore <span aria-hidden="true">→</span></span>
          </div>
          <div class="hub-bg" aria-hidden="true"></div>
        </a>
        
        <a href="/guides/maine-cannabis-taxation-280e/" class="hub-card">
          <div class="hub-card-inner">
            <div class="hub-icon">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="24" cy="24" r="18"/>
                <path d="M24 12v24M12 24h24"/>
                <path d="M17 20l5 5 9-9" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Compliance</h3>
            <p>Mastering 280E and OCP tracking rules.</p>
            <span class="hub-cta">Explore <span aria-hidden="true">→</span></span>
          </div>
          <div class="hub-bg" aria-hidden="true"></div>
        </a>
        
        <a href="/guides/maine-cannabis-real-estate/" class="hub-card">
          <div class="hub-card-inner">
            <div class="hub-icon">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M24 6C14.6 6 7 13.6 7 23c0 12 17 21 17 21s17-9 17-21c0-9.4-7.6-17-17-17z"/>
                <circle cx="24" cy="23" r="6"/>
              </svg>
            </div>
            <h3>Real Estate</h3>
            <p>Finding compliant zones in every town.</p>
            <span class="hub-cta">Explore <span aria-hidden="true">→</span></span>
          </div>
          <div class="hub-bg" aria-hidden="true"></div>
        </a>
        
        <a href="/roi-calculator/" class="hub-card">
          <div class="hub-card-inner">
            <div class="hub-icon">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M8 34l12-16 8 8 12-16"/>
                <circle cx="16" cy="22" r="3" fill="currentColor"/>
                <circle cx="28" cy="26" r="3" fill="currentColor"/>
                <circle cx="40" cy="10" r="3" fill="currentColor"/>
              </svg>
            </div>
            <h3>ROI Calculator</h3>
            <p>Estimate startup costs and break-even timelines.</p>
            <span class="hub-cta">Calculate <span aria-hidden="true">→</span></span>
          </div>
          <div class="hub-bg" aria-hidden="true"></div>
        </a>
        
        <a href="/resources/" class="hub-card">
          <div class="hub-card-inner">
            <div class="hub-icon">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="20" cy="18" r="6"/>
                <circle cx="32" cy="32" r="6"/>
                <path d="M32 16v6M32 32l6 6"/>
              </svg>
            </div>
            <h3>Vendor Directory</h3>
            <p>Connect with expert lawyers and CPAs.</p>
            <span class="hub-cta">Browse <span aria-hidden="true">→</span></span>
          </div>
          <div class="hub-bg" aria-hidden="true"></div>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       GEO EXPLORER: Map-based visual with city pins
  ═══════════════════════════════════════════════════════════════ -->
  <section class="geo-explorer" aria-labelledby="geo-heading">
    <div class="geo-inner">
      <div class="geo-header">
        <span class="section-eyebrow">Municipal Guides</span>
        <h2 id="geo-heading">Explore by Location</h2>
        <p class="geo-subtitle">
          Maine has 41+ cities and towns that have opted in to allow cannabis retail. 
          Each has its own zoning rules, local fees, and competitive landscape.
        </p>
      </div>
      
      <div class="geo-content">
        <!-- Stylized map representation -->
        <div class="geo-map" aria-hidden="true">
          <svg viewBox="0 0 400 300" fill="none">
            <!-- Simplified Maine outline suggestion -->
            <path d="M50,250 L80,200 L120,180 L150,190 L180,160 L220,150 L260,140 L300,120 L340,80 L350,60 L340,40 L300,50 L260,70 L220,90 L180,100 L140,120 L100,150 L60,200 Z" 
                  stroke="var(--color-primary)" stroke-width="1" opacity="0.2" fill="var(--color-primary)" fill-opacity="0.03"/>
            <!-- City markers -->
            <circle cx="320" cy="55" r="6" fill="var(--color-accent)"/>
            <circle cx="280" cy="90" r="4" fill="var(--color-accent)" opacity="0.7"/>
            <circle cx="240" cy="120" r="5" fill="var(--color-accent)"/>
            <circle cx="200" cy="140" r="4" fill="var(--color-accent)" opacity="0.7"/>
            <circle cx="160" cy="170" r="5" fill="var(--color-accent)"/>
            <circle cx="120" cy="200" r="4" fill="var(--color-accent)" opacity="0.5"/>
          </svg>
        </div>
        
        <!-- City links as styled chips -->
        <div class="geo-cities">
          {cityLinks.map(city => (
            <a href={city.href} class="city-chip">{city.name}</a>
          ))}
        </div>
      </div>
      
      <a href="/guides/" class="btn-outline">View All 41 Municipal Guides</a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       WHAT'S NEW: Editorial freshness section
  ═══════════════════════════════════════════════════════════════ -->
  <section class="whats-new" aria-labelledby="new-heading">
    <div class="new-inner">
      <div class="new-header">
        <div class="freshness-badge">
          <span class="pulse-dot"></span>
          <span class="freshness-label">Updated April 2026</span>
        </div>
        <h2 id="new-heading">What's New</h2>
        <p class="new-subtitle">Recent updates and additions to the guide library.</p>
      </div>
      
      <div class="new-grid">
        {recentGuides.map(guide => (
          <a href={guide.href} class="new-card">
            <span class={`new-badge ${guide.badge === 'New' ? 'badge-new' : ''}`}>{guide.badge}</span>
            <span class="new-title">{guide.title}</span>
            <span class="new-date">{guide.date}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       SOCIAL PROOF: Authority stats
  ═══════════════════════════════════════════════════════════════ -->
  <section class="authority-stats" aria-label="Site Statistics">
    <div class="stats-inner">
      <p class="stats-intro">
        This resource has been built for Maine cannabis entrepreneurs who want the real information — not the marketing version.
      </p>
      
      <div class="stats-grid">
        <div class="stat-block">
          <span class="stat-number">2,847</span>
          <span class="stat-text">Entrepreneurs Served</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-block">
          <span class="stat-number">44</span>
          <span class="stat-text">Expert Guides</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-block">
          <span class="stat-number">15</span>
          <span class="stat-text">City Guides</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-block">
          <span class="stat-number">98%</span>
          <span class="stat-text">Update Accuracy</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       START HERE: Journey path with personality
  ═══════════════════════════════════════════════════════════════ -->
  <section class="journey-path" aria-labelledby="journey-heading">
    <div class="journey-inner">
      <div class="journey-header">
        <span class="section-eyebrow">For Newcomers</span>
        <h2 id="journey-heading">Start Your Journey</h2>
        <p class="journey-subtitle">
          This curated path walks you through the essentials — from understanding Maine's regulatory framework to signing your commercial lease.
        </p>
      </div>
      
      <div class="journey-steps">
        {journeySteps.map(step => (
          <a href={step.href} class="journey-step">
            <span class="step-num">{step.num}</span>
            <div class="step-content">
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </div>
            <span class="step-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       NEWSLETTER: Refined inline signup
  ═══════════════════════════════════════════════════════════════ -->
  <section class="newsletter-section" aria-labelledby="newsletter-heading">
    <div class="newsletter-inner">
      <div class="newsletter-content">
        <h2 id="newsletter-heading">Stay Current with Maine Cannabis</h2>
        <p>Get notified when we update guides or add new resources. No spam, just signal.</p>
      </div>
      <form class="newsletter-form" action="https://formspree.io/f/xvgzlowz" method="POST">
        <div class="form-row">
          <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" class="form-input"/>
          <select name="stage" aria-label="Your stage" class="form-select">
            <option value="" disabled selected>Your stage</option>
            <option value="startup">Starting a dispensary</option>
            <option value="operating">Already operating</option>
            <option value="researching">Just researching</option>
          </select>
          <button type="submit" class="form-btn">Subscribe</button>
        </div>
