---
import Layout from '../layouts/Layout.astro';
import PineTree from '@network/ui/PineTree';
import Leaf from '@network/ui/Leaf';
import Faq from '../components/Faq.astro';
import siteConfig from '../data/site-config.json';

const homepageFaqs = [
  { question: "How long does it take to get a Maine cannabis dispensary license?", answer: "Plan for 5-7 months under normal processing conditions. Municipal endorsement alone takes 6-12 weeks. OCP requests for additional information can add another 4-8 weeks. See the full licensing guide: /guides/maine-dispensary-license/" },
  { question: "How much does it cost to open a Maine dispensary?", answer: "Most Maine dispensaries need $360K-$1M to open. This includes licensing fees ($3,000-$10,000), buildout ($150K-$500K), initial inventory ($50K-$100K), and working capital ($50K-$100K). See detailed breakdown: /guides/maine-dispensary-costs/" },
  { question: "Which Maine towns allow cannabis dispensaries?", answer: "15 towns have opted in to adult-use retail as of 2026. Key markets include Portland, Lewiston, Bangor, Augusta, Biddeford, and Brunswick. Check the full opt-in list: /guides/maine-cannabis-opt-in-tracker/" },
  { question: "What are the school buffer requirements for Maine dispensaries?", answer: "The state default is 1,000 feet, measured property line to property line. However, municipalities may reduce this to 500 feet through local ordinance. Portland and Bangor have adopted the 500 ft buffer. Check your specific municipality: /guides/maine-cannabis-school-buffer/" }
];
const websiteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteConfig.siteName,
  "url": siteConfig.siteUrl,
  "description": "Your complete guide to opening and operating a cannabis dispensary in Maine.",
  "publisher": {
    "@type": "Organization",
    "name": siteConfig.siteName,
    "url": siteConfig.siteUrl,
    "sameAs": siteConfig.socialLinks
  }
});
const faqPageJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": homepageFaqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
});

const stats = [
  { label: "Annual Sales", value: "$246M" },
  { label: "Active Stores", value: "169" },
  { label: "Price/Gram", value: "$6.62" }
];

const cityLinks = [
  { name: "Portland", href: "/guides/portland-dispensary-guide" },
  { name: "Lewiston", href: "/guides/lewiston-dispensary-guide" },
  { name: "Bangor", href: "/guides/bangor-dispensary-guide" },
  { name: "Augusta", href: "/guides/augusta-dispensary-guide" },
  { name: "South Portland", href: "/guides/south-portland-dispensary-guide" },
  { name: "Biddeford", href: "/guides/biddeford-dispensary-guide" },
  { name: "Auburn", href: "/guides/auburn-dispensary-guide" },
];

const recentGuides = [
  { title: "2026 Startup Costs Breakdown", href: "/guides/maine-dispensary-costs", date: "April 4, 2026", badge: "Updated" },
  { title: "Bangor Market Analysis", href: "/guides/bangor-dispensary-guide", date: "April 3, 2026", badge: "Updated" },
  { title: "Real Estate & Zoning Guide", href: "/guides/maine-cannabis-real-estate", date: "April 2, 2026", badge: "Updated" },
  { title: "2026 Launch Checklist", href: "/launch-checklist", date: "April 1, 2026", badge: "New" },
  { title: "How to Open a Dispensary in Maine", href: "/blog/maine-dispensary-how-to-open", date: "March 28, 2026", badge: "Guide" },
];

const journeySteps = [
  { num: "01", title: "Get the Launch Checklist", desc: "Download the step-by-step checklist used by Portland and Bangor applicants — covers OCP forms, municipal filings, and lease contingencies.", href: "/launch-checklist/" },
  { num: "02", title: "Understand Licensing", desc: "Maine requires OCP Adult-Use Retail License + town opt-in. Lewiston, Augusta, and 39 other towns have different timelines — know yours.", href: "/guides/maine-dispensary-license/" },
  { num: "03", title: "Run the Numbers", desc: "Most Maine dispensaries need $360K–$1M to open. Model your startup costs against the state's $246M adult-use market.", href: "/roi-calculator/" },
  { num: "04", title: "Find Your Location", desc: "Zoning rules, 500-ft school buffers, commercial lease negotiation in Portland, Bangor, or a smaller opt-in town like Waterville.", href: "/guides/maine-cannabis-real-estate/" },
];
---

<Layout
  title="How to Open a Maine Dispensary in 2026 — Step-by-Step Guide"
  description="Everything you need to open a Maine cannabis dispensary: licensing timeline, startup costs ($360K–$1M), location zoning, and OCP application steps. Start here."
  heroImage="/images/heroes/homepage.jpg"
  article={{ author: "Steve Kelly", authorTitle: "Founder & Publisher", authorId: "steve-kelly", publishDate: "2026-01-01", modifiedDate: "2026-04-21", section: "Home" }}
>

  <style>

  /* ─────────────────────────────────────────────────────────────────
     HERITAGE AUTHORITY — CSS Custom Properties
  ───────────────────────────────────────────────────────────────── */
  :root {
    --space-xs: 0.5rem;
    --space-sm: 1rem;
    --space-md: 2rem;
    --space-lg: 4rem;
    --space-xl: 6rem;
    --space-2xl: 8rem;

    --text-xs: 0.75rem;
    --text-sm: 0.875rem;
    --text-base: 1rem;
    --text-lg: 1.125rem;
    --text-xl: 1.25rem;
    --text-2xl: 1.5rem;
    --text-3xl: 2rem;
    --text-4xl: 2.75rem;
    --text-5xl: 3.5rem;

    --ease-out: cubic-bezier(0.2, 1, 0.2, 1);
    --ease-spring: cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  /* ─────────────────────────────────────────────────────────────────
     SECTION EYEBROW — Shared label style
  ───────────────────────────────────────────────────────────────── */
  .section-eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  /* ─────────────────────────────────────────────────────────────────
     HERO SECTION — Manifesto Style
  ───────────────────────────────────────────────────────────────── */
  .hero-manifesto {
    position: relative;
    background:
      radial-gradient(
        ellipse 80% 50% at 20% 80%,
        rgba(88, 129, 87, 0.18) 0%,
        transparent 50%
      ),
      radial-gradient(
        ellipse 60% 40% at 80% 20%,
        rgba(13, 78, 80, 0.25) 0%,
        transparent 50%
      ),
      linear-gradient(
        180deg,
        var(--color-primary) 0%,
        #0A3D3F 100%
      );
    color: var(--color-background);
    padding: var(--space-xl) 0 var(--space-lg);
    margin-bottom: var(--space-lg);
    overflow: hidden;
    min-height: 85vh;
    display: flex;
    flex-direction: column;
  }

  .topo-bg {
    position: absolute;
    inset: 0;
    opacity: 0.6;
    pointer-events: none;
  }

  .topo-bg svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--space-lg);
    align-items: center;
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .edition-mark {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: var(--space-md);
  }

  .edition-divider {
    font-size: 0.4rem;
    color: var(--color-accent);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(var(--text-4xl), 6vw, var(--text-5xl));
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-background);
    margin-bottom: var(--space-md);
  }

  .hero-title-accent {
    font-style: italic;
    color: var(--color-soft-green);
  }

  .hero-descriptor {
    font-size: var(--text-lg);
    line-height: 1.7;
    opacity: 0.9;
    max-width: 520px;
    margin-bottom: var(--space-lg);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    background: var(--color-background);
    color: var(--color-primary);
    padding: 1rem 1.75rem;
    border-radius: 0.5rem;
    font-weight: 700;
    font-size: var(--text-sm);
    text-decoration: none;
    transition: transform 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-background);
    padding: 1rem 1.75rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    border: 1px solid rgba(242,242,226,0.3);
    transition: background 0.2s, border-color 0.2s;
  }

  .btn-ghost:hover {
    background: rgba(242,242,226,0.1);
    border-color: rgba(242,242,226,0.5);
  }

  .hero-secondary-cta {
    display: inline-block;
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 600;
    color: rgba(242,242,226,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero-secondary-cta:hover {
    color: rgba(242,242,226,0.95);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .visual-anchor {
    position: relative;
    width: 320px;
    height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .anchor-ring {
    position: absolute;
    border: 1px solid var(--color-background);
    border-radius: 50%;
    opacity: 0.1;
  }

  .ring-1 { width: 100%; height: 100%; }
  .ring-2 { width: 75%; height: 75%; animation: rotate 20s linear infinite; }
  .ring-3 { width: 50%; height: 50%; animation: rotate 15s linear infinite reverse; }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ring-2, .ring-3 { animation: none; }
  }

  .botanical-cluster {
    position: relative;
    z-index: 1;
  }

  .cluster-pine {
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.1));
  }

  .cluster-leaf {
    position: absolute;
  }

  .cluster-leaf-1 {
    top: -20px;
    right: -40px;
    transform: rotate(25deg);
  }

  .cluster-leaf-2 {
    bottom: 20px;
    left: -50px;
    transform: rotate(-35deg);
  }

  .visual-caption {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    font-size: var(--text-xs);
    opacity: 0.5;
  }

  .caption-label {
    display: block;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .caption-ref {
    font-size: 0.65rem;
  }

  .hero-flourish {
    position: relative;
    z-index: 1;
    margin-top: auto;
    padding-top: var(--space-md);
  }

  .hero-flourish svg {
    width: 100%;
    height: 40px;
  }

  /* ─────────────────────────────────────────────────────────────────
     MARKET INTEL — Stats Strip
  ───────────────────────────────────────────────────────────────── */
  .market-intel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-xl);
    overflow: hidden;
  }

  .intel-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
  }

  .intel-stats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-lg);
  }

  .intel-stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .intel-stat .stat-value {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }

  .intel-stat .stat-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
  }

  .stat-separator {
    color: var(--color-border);
    font-size: var(--text-lg);
  }

  .intel-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap 0.2s var(--ease-out);
  }

  .intel-link:hover {
    gap: var(--space-sm);
  }

  /* ─────────────────────────────────────────────────────────────────
     MISSION MANIFESTO — Editorial Layout
  ───────────────────────────────────────────────────────────────── */
  .mission-manifesto {
    position: relative;
    padding: var(--space-2xl) 0;
    margin-bottom: var(--space-2xl);
    overflow: hidden;
  }

  .mission-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 var(--space-md);
    position: relative;
    z-index: 1;
  }

  .mission-header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .mission-title {
    font-family: var(--font-serif);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    color: var(--color-primary);
    margin: 0;
  }

  .mission-title::before {
    display: none;
  }

  .mission-text {
    max-width: 700px;
    margin: 0 auto;
  }

  .mission-lead {
    font-size: var(--text-xl);
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .mission-body {
    display: grid;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .mission-body p {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap 0.2s var(--ease-out);
  }

  .read-more:hover {
    gap: var(--space-sm);
  }

  .mission-botanical {
    position: absolute;
    right: -50px;
    top: 50%;
    transform: translateY(-50%);
    width: 200px;
    height: 400px;
    pointer-events: none;
    opacity: 0.5;
  }

  /* ─────────────────────────────────────────────────────────────────
     MARKET OVERVIEW — Asymmetric Grid
  ───────────────────────────────────────────────────────────────── */
  .market-overview {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: var(--space-xl) var(--space-lg);
    margin-bottom: var(--space-2xl);
    position: relative;
    overflow: hidden;
  }

  .market-overview::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  }

  .overview-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .overview-header {
    margin-bottom: var(--space-lg);
  }

  .overview-header h2 {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    margin: 0;
  }

  .overview-header h2::before {
    display: none;
  }

  .overview-grid {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .overview-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .overview-main p {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .overview-aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .aside-card {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .aside-card.highlight {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-background);
  }

  .aside-stat {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: 1;
  }

  .aside-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
  }

  .aside-card.highlight .aside-label {
    color: rgba(242,242,226,0.8);
  }

  .aside-note {
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-light);
    padding-top: var(--space-xs);
    border-top: 1px solid var(--color-border);
  }

  /* ─────────────────────────────────────────────────────────────────
     OPERATIONS EXCELLENCE — Full Width Text
  ───────────────────────────────────────────────────────────────── */
  .operations-excellence {
    padding: var(--space-2xl) 0;
    margin-bottom: var(--space-2xl);
    position: relative;
  }

  .ops-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .ops-header {
    margin-bottom: var(--space-lg);
  }

  .ops-header h2 {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    margin: 0;
  }

  .ops-header h2::before {
    display: none;
  }

  .ops-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .ops-content p {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .ops-topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    padding: var(--space-md) 0;
  }

  .topic-tag {
    display: inline-block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-primary);
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s var(--ease-out);
  }

  .topic-tag:hover {
    background: var(--color-primary);
    color: var(--color-background);
    border-color: var(--color-primary);
  }

  .ops-closing {
    font-weight: 500;
    color: var(--color-text) !important;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .ops-decoration {
    position: absolute;
    right: 5%;
    top: 50%;
    transform: translateY(-50%);
    width: 200px;
    height: 200px;
    opacity: 0.4;
    pointer-events: none;
  }

  /* ─────────────────────────────────────────────────────────────────
     CORE HUBS — Editorial Card Grid
  ───────────────────────────────────────────────────────────────── */
  .core-hubs {
    padding: var(--space-2xl) 0;
    margin-bottom: var(--space-2xl);
    background: var(--color-background);
  }

  .hubs-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .hubs-header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .hubs-header h2 {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    margin: 0;
  }

  .hubs-header h2::before {
    display: none;
  }

  .hubs-subtitle {
    font-size: var(--text-base);
    color: var(--color-text-light);
    margin-top: var(--space-xs);
  }

  .hubs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-md);
  }

  .hub-card {
    position: relative;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(209, 209, 193, 0.5);
    border-radius: 1rem;
    padding: var(--space-lg) var(--space-md);
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.2, 1, 0.2, 1);
    overflow: hidden;
  }

  .hub-card:hover {
    transform: translateY(-6px);
    border-color: rgba(13, 78, 80, 0.3);
    box-shadow:
      0 4px 16px rgba(13, 78, 80, 0.08),
      0 16px 48px rgba(13, 78, 80, 0.12);
    background: rgba(255, 255, 255, 0.8);
  }

  .hub-card-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .hub-icon {
    margin-bottom: var(--space-sm);
    transition: transform 0.3s var(--ease-spring);
  }

  .hub-icon svg {
    width: 48px;
    height: 48px;
    color: var(--color-accent);
    transition: color 0.2s;
  }

  .hub-card:hover .hub-icon {
    transform: scale(1.05);
  }

  .hub-card:hover .hub-icon svg {
    color: var(--color-primary);
  }

  .hub-card h3 {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-primary);
    margin: 0 0 var(--space-xs);
  }

  .hub-card p {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  .hub-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: var(--space-sm);
    transition: gap 0.2s var(--ease-out);
  }

