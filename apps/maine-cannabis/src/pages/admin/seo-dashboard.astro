---
import Layout from '../../layouts/Layout.astro';

// This is a private page for the founder to track SEO/GEO milestones.
const targetPrompts = [
  "How to open a dispensary in Maine 2026",
  "Maine cannabis license cost",
  "Portland Maine dispensary zoning rules",
  "Dispensary ROI calculator Maine",
  "Maine cannabis excise tax 2026"
];
---

<Layout title="SEO Intelligence Dashboard" description="Internal dashboard for tracking GEO citations, AI search performance, and weekly prompt audits for Maine cannabis content." heroImage="https://images.unsplash.com/photo-1511497584788-876760111969?auto=format&fit=crop&q=80&w=1200&h=400" noindex>
  <style>

  .admin-header { margin-bottom: 4rem; border-bottom: 2px solid var(--color-primary); padding-bottom: 2rem; }
  .dashboard-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 4rem; }
  .stat-card { background: var(--color-surface); padding: 2.5rem; border-radius: 2rem; border: 1px solid var(--color-border); text-align: center; }
  .stat-card .value { font-size: 3rem; font-weight: 800; color: var(--color-primary); margin: 1rem 0; }
  
  .source-list { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 1.5rem; }
  .source-list span { background: var(--color-background); padding: 0.5rem 1rem; border-radius: 1rem; font-weight: 700; font-size: 0.8rem; }

  .audit-section { background: var(--color-surface); padding: 4rem; border-radius: 3rem; margin-bottom: 4rem; }
  .prompt-list { margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem; }
  .prompt-item { background: var(--color-surface); padding: 1.5rem; border-radius: 1.5rem; display: flex; justify-content: space-between; align-items: center; border: 1px solid var(--color-border); }
  .prompt-item code { color: var(--color-primary); font-weight: 700; }
  
  .audit-actions { display: flex; gap: 0.5rem; }
  .btn-check, .btn-miss { padding: 0.5rem 1rem; border-radius: 0.75rem; border: 1px solid var(--color-border); cursor: pointer; font-weight: 700; font-size: 0.8rem; }
  .btn-check:hover { background: #dcfce7; border-color: #22c55e; }
  .btn-miss:hover { background: #fee2e2; border-color: #ef4444; }

  .checklist { list-style: none; padding: 0; margin-top: 2rem; }
  .checklist li { padding: 1rem; border-radius: 1rem; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 1rem; font-weight: 600; }
  .checklist li.done { background: #dcfce7; color: #166534; }
  .checklist li.done::before { content: '✓'; }
  .checklist li.pending { background: #fef9c3; color: #854d0e; }
  .checklist li.pending::before { content: '○'; }

  .geo-benchmarking { background: var(--color-surface); padding: 3rem; border-radius: 2rem; margin-bottom: 4rem; border: 1px solid var(--color-border); }
  .benchmark-intro { font-size: 1.05rem; line-height: 1.7; margin-bottom: 2rem; color: var(--color-text-light); }
  .competitor-table { overflow-x: auto; margin-bottom: 1.5rem; }
  .competitor-table table { width: 100%; border-collapse: collapse; min-width: 600px; }
  .competitor-table th { background: var(--color-primary); color: var(--color-background); padding: 1rem; text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .competitor-table td { padding: 1rem; border-bottom: 1px solid var(--color-border); font-size: 0.95rem; }
  .competitor-table tr:last-child td { border-bottom: none; }
  .competitor-table tr:hover td { background: rgba(88, 129, 87, 0.04); }
  .benchmark-note { font-size: 0.8rem; color: var(--color-text-light); margin-top: 1rem; }

  .weekly-metrics { background: var(--color-surface); padding: 3rem; border-radius: 2rem; margin-bottom: 4rem; }
  .metric-list { list-style: none; padding: 0; margin-top: 1.5rem; }
  .metric-list li { padding: 1rem 0; border-bottom: 1px solid var(--color-border); font-size: 1rem; }
  .metric-list li:last-child { border-bottom: none; }

  /* GEO Citation Tracker */
  .geo-citation-tracker { background: var(--color-surface); padding: 3rem; border-radius: 2rem; margin-bottom: 4rem; border: 1px solid var(--color-border); }
  .section-intro { font-size: 1.05rem; line-height: 1.7; margin-bottom: 2rem; color: var(--color-text-light); }

  .citation-table-wrapper { overflow-x: auto; }
  .citation-table { width: 100%; border-collapse: collapse; min-width: 800px; }
  .citation-table th { background: var(--color-primary); color: var(--color-background); padding: 1rem; text-align: left; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .citation-table td { padding: 1rem; border-bottom: 1px solid var(--color-border); font-size: 0.9rem; vertical-align: top; }
  .citation-table tr:last-child td { border-bottom: none; }
  .citation-table tr:hover td { background: rgba(88, 129, 87, 0.04); }

  .category-row td { background: rgba(88, 129, 87, 0.08); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-primary); padding: 0.75rem 1rem; }

  .citation-link { color: var(--color-primary); font-weight: 600; text-decoration: none; }
  .citation-link:hover { text-decoration: underline; }

  .status-badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 1rem; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
  .status-claimed { background: #dcfce7; color: #166534; }
  .status-pending { background: #fef9c3; color: #854d0e; }
  .status-na { background: var(--color-border); color: var(--color-text-light); }

  /* Our Citations Section */
  .our-citations { background: var(--color-surface); padding: 3rem; border-radius: 2rem; margin-bottom: 4rem; border: 1px solid var(--color-border); }
  .citation-list { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .citation-list-item { display: grid; grid-template-columns: 1fr auto auto; gap: 1.5rem; align-items: center; padding: 1rem; background: var(--color-background); border-radius: 1rem; font-size: 0.9rem; }
  .citation-list-item span { color: var(--color-text-light); font-size: 0.85rem; }
  .citation-list-item .status-claimed { font-size: 0.7rem; }

</style>
<section class="admin-header">
    <h1>Empire Intelligence Dashboard</h1>
    <p class="lead">Tracking our path to becoming the #1 cited authority in Maine cannabis.</p>
  </section>

  <div class="dashboard-grid">
    <div class="stat-card">
      <h2>GEO Citation Rate</h2>
      <div class="value">Pending Audit</div>
      <p>Goal: 40%+ citation in AI Search</p>
    </div>
    <div class="stat-card">
      <h2>AI Traffic Sources</h2>
      <div class="source-list">
        <span>ChatGPT</span>
        <span>Perplexity</span>
        <span>Gemini</span>
        <span>Claude</span>
      </div>
    </div>
  </div>

  <section class="audit-section">
    <h2>Weekly Prompt Audit</h2>
    <p>Run these prompts in ChatGPT/Perplexity and check if <strong>mainedispensaryguide.com</strong> is cited.</p>
    <div class="prompt-list">
      {targetPrompts.map(prompt => (
        <div class="prompt-item">
          <code>"{prompt}"</code>
          <div class="audit-actions">
            <button class="btn-check">Cited ✅</button>
            <button class="btn-miss">Missed ❌</button>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="technical-seo-status">
    <h2>Technical SEO Checklist</h2>
    <ul class="checklist">
      <li class="done">Google Search Console Verified</li>
      <li class="pending">Bing Webmaster Tools Pending</li>
      <li class="done">Sitemap.xml Auto-Generated</li>
      <li class="done">JSON-LD Structured Data (Article/WebSite)</li>
      <li class="done">Robots.txt Optimized</li>
      <li><a href="/site-health/">Site Health Dashboard →</a></li>
    </ul>
  </section>

  <section class="geo-benchmarking">
    <h2>GEO Competitive Analysis</h2>
    <p class="benchmark-intro">Our primary GEO competitors for Maine cannabis queries include Maine Can Save, Online辛court's state guides, and regional chambers of commerce content. We track citation rates across Perplexity, ChatGPT, and Gemini monthly to measure share-of-voice.</p>
    <div class="competitor-table">
      <table>
        <thead>
          <tr>
            <th scope="col">Competitor</th>
            <th scope="col">Strength</th>
            <th scope="col">Citation Frequency</th>
            <th scope="col">Our Advantage</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Maine Can Save</td>
            <td>Discount pricing content</td>
            <td>High for retail queries</td>
            <td>Compliance depth, municipal zoning</td>
          </tr>
          <tr>
            <td>Leafly / Weedmaps</td>
            <td>Brand listings, strain data</td>
            <td>High for discovery</td>
            <td>B2B focus, business formation guides</td>
          </tr>
          <tr>
            <td>MCA (Maine Cannabis Assoc.)</td>
            <td>Industry advocacy voice</td>
            <td>Medium for policy queries</td>
            <td>Actionable 280E and licensing guides</td>
          </tr>
          <tr>
            <td>Municipal Government Sites</td>
            <td>Zoning authority, permits</td>
            <td>High for regulatory queries</td>
            <td>Plain-language interpretation, checklists</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="benchmark-note">Last updated: April 4, 2026. Citation audits run every Monday via Perplexity Pro and ChatGPT-4o.</p>
  </section>

  <section class="geo-citation-tracker">
    <h2>GEO Citation Tracker</h2>
    <p class="section-intro">Monitor our presence across directory listings and track where mainedispensaryguide.com is cited across the web.</p>

    <!-- Citation Sources Table -->
    <div class="citation-table-wrapper">
      <table class="citation-table">
        <thead>
          <tr>
            <th scope="col">Source</th>
            <th scope="col">Listing URL</th>
            <th scope="col">Status</th>
            <th scope="col">Notes</th>
            <th scope="col">Last Verified</th>
          </tr>
        </thead>
        <tbody>
          <!-- Free Directories -->
          <tr class="category-row">
            <td colspan="5"><strong>Free Listings</strong></td>
          </tr>
          <tr>
            <td>Google Business Profile</td>
            <td><a href="#" class="citation-link">Claim Listing</a></td>
            <td><span class="status-badge status-pending">Pending</span></td>
            <td>Primary GEO signal. Must claim first.</td>
            <td>—</td>
          </tr>
          <tr>
            <td>Bing Places</td>
            <td><a href="#" class="citation-link">Claim Listing</a></td>
            <td><span class="status-badge status-pending">Pending</span></td>
            <td>Secondary search presence.</td>
            <td>—</td>
          </tr>
          <tr>
            <td>Apple Maps</td>
            <td><a href="#" class="citation-link">Claim Listing</a></td>
            <td><span class="status-badge status-pending">Pending</span></td>
            <td>iOS users "near me" queries.</td>
            <td>—</td>
          </tr>
          <tr>
            <td>Yelp Business</td>
            <td><a href="#" class="citation-link">Manage Listing</a></td>
            <td><span class="status-badge status-claimed">Claimed</span></td>
            <td>High authority for local SEO.</td>
            <td>Apr 2026</td>
          </tr>
          <!-- Cannabis Directories -->
          <tr class="category-row">
            <td colspan="5"><strong>Cannabis Industry Directories</strong></td>
          </tr>
          <tr>
            <td>Leafly</td>
            <td><a href="#" class="citation-link">Claim Listing</a></td>
            <td><span class="status-badge status-pending">Claim</span></td>
            <td>Consumer discovery platform. High traffic.</td>
            <td>—</td>
          </tr>
          <tr>
            <td>Weedmaps</td>
            <td><a href="#" class="citation-link">Claim Listing</a></td>
            <td><span class="status-badge status-pending">Claim</span></td>
            <td>Patient/user discovery. Priority.</td>
            <td>—</td>
          </tr>
          <tr>
            <td>Ganjapreneur</td>
            <td><a href="#" class="citation-link">Submit Listing</a></td>
            <td><span class="status-badge status-pending">Submit</span></td>
            <td>Industry trade publication.</td>
            <td>—</td>
          </tr>
          <tr>
            <td>Marijuana Business Daily</td>
            <td><a href="#" class="citation-link">Submit Listing</a></td>
            <td><span class="status-badge status-pending">Submit</span></td>
            <td>B2B focus. National circulation.</td>
            <td>—</td>
          </tr>
          <!-- Media & Editorial -->
          <tr class="category-row">
            <td colspan="5"><strong>Media & Editorial Contacts</strong></td>
          </tr>
          <tr>
            <td>Mainebiz</td>
            <td><a href="https://mainebiz.biz" class="citation-link" target="_blank" rel="noopener">mainebiz.biz</a></td>
            <td><span class="status-badge status-pending">Contact</span></td>
            <td>Business news. Editorial contact approach.</td>
            <td>—</td>
          </tr>
          <tr>
            <td>Maine Public</td>
            <td><a href="https://mainepublic.org" class="citation-link" target="_blank" rel="noopener">mainepublic.org</a></td>
            <td><span class="status-badge status-pending">Contact</span></td>
            <td>NPR affiliate. Feature/story opportunity.</td>
            <td>—</td>
          </tr>
          <!-- Municipal -->
          <tr class="category-row">
            <td colspan="5"><strong>Municipal Government Sites</strong></td>
          </tr>
          <tr>
            <td>City of Portland</td>
            <td><a href="#" class="citation-link">Add to Directory</a></td>
            <td><span class="status-badge status-pending">Pending</span></td>
            <td>Portland cultivator/retailer listings.</td>
            <td>—</td>
          </tr>
          <tr>
            <td>City of Bangor</td>
            <td><a href="#" class="citation-link">Add to Directory</a></td>
            <td><span class="status-badge status-pending">Pending</span></td>
            <td>Economic development business directory.</td>
            <td>—</td>
          </tr>
          <tr>
            <td>City of Lewiston</td>
            <td><a href="#" class="citation-link">Add to Directory</a></td>
            <td><span class="status-badge status-pending">Pending</span></td>
            <td>Second largest city. Local biz hub.</td>
            <td>—</td>
          </tr>
          <tr>
            <td>City of Auburn</td>
            <td><a href="#" class="citation-link">Add to Directory</a></td>
            <td><span class="status-badge status-pending">Pending</span></td>
            <td>Neighboring Lewiston. Combined reach.</td>
            <td>—</td>
          </tr>
          <tr>
            <td>Androscoggin Valley Chamber</td>
            <td><a href="#" class="citation-link">Member Directory</a></td>
            <td><span class="status-badge status-pending">Pending</span></td>
            <td>Regional business network.</td>
            <td>—</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Maine Dispensary Guide Citations -->
  <section class="our-citations">
    <h2>Our Citations</h2>
    <p class="section-intro">Track external sources that mention or cite mainedispensaryguide.com. These build our E-E-A-T signals and referral traffic.</p>
    <div class="citation-list">
      <div class="citation-list-item">
        <strong>Search for: "Maine dispensary guide" on Google</strong>
        <span>Check monthly</span>
        <span class="status-badge status-pending">Audit</span>
      </div>
      <div class="citation-list-item">
        <strong>Bing Places / Apple Maps mentions</strong>
        <span>Cross-reference</span>
        <span class="status-badge status-pending">Audit</span>
      </div>
      <div class="citation-list-item">
        <strong>Industry blog citations</strong>
        <span>Quarterly</span>
        <span class="status-badge status-pending">Track</span>
      </div>
      <div class="citation-list-item">
        <strong>Maine municipal planning documents</strong>
        <span>When cited</span>
        <span class="status-badge status-pending">Monitor</span>
      </div>
    </div>
    <p class="benchmark-note">Use the Brave Search script (<code>node scripts/brave-search.cjs</code>) to audit citation mentions quarterly.</p>
  </section>

  <section class="weekly-metrics">
    <h2>Weekly Metrics to Track</h2>
    <ul class="metric-list">
      <li><strong>Citation Rate:</strong> % of 50 target prompts where Maine Dispensary Guide is cited</li>
      <li><strong>Position Zero Appearances:</strong> Does any Maine Dispensary Guide content appear as an AI summary source?</li>
      <li><strong>Organic Traffic:</strong> Sessions from Google/Bing, filtered by Maine cannabis keywords</li>
      <li><strong>Guide Engagement:</strong> Avg. time on page for technical guides (target: 3+ min)</li>
      <li><strong>City Guide Depth:</strong> Are 15-municipality guides capturing "near me" queries?</li>
    </ul>
  </section>
</Layout>
