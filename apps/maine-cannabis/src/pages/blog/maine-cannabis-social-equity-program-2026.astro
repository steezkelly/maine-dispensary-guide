---
import Layout from '../../layouts/Layout.astro';
import Callout from '../../components/Callout.astro';
import Faq from '../../components/Faq.astro';
import authors from '../../data/authors.json';

const steveKelly = authors.find(a => a.id === 'steve-kelly');

const article = {
  author: "Steve Kelly",
  authorId: "steve-kelly",
  authorTitle: "Founder & Publisher",
  publishDate: "2026-05-13",
  modifiedDate: "2026-05-13",
  section: "Policy & Legislation"
};
const topics = ["social-equity", "licensing", "policy", "start-here"];

const faqItems = [
  { question: "Who qualifies as a social equity applicant in Maine?", answer: "Maine recognizes social equity applicants as individuals who have lived in a disproportionately impacted area for at least 5 of the past 10 years, have a prior cannabis-related conviction (excluding distribution to minors), or are a member of a household with income below 200% of the federal poverty level. Maine residents who are Black, Indigenous, or people of color (BIPOC) and have been historically disadvantaged by cannabis prohibition also qualify." },
  { question: "What benefits does Maine's Social Equity Program provide?", answer: "Approved social equity applicants receive a 50% reduction on OCP license application fees, a 50% reduction on annual license renewal fees, priority processing for license applications, access to a state-funded technical assistance program, and eligibility for grants from the Maine Cannabis Equity Fund. The fund is capitalized by 5% of state cannabis tax revenue and supports business development, legal assistance, and workforce training." },
  { question: "How do I apply for social equity status with OCP?", answer: "Social equity status is verified through a supplemental application submitted with your standard OCP license application. You must provide documentation proving residency in a disproportionately impacted area (utility bills, lease agreements, or tax records), income verification if applicable (tax returns or W-2s), or conviction records if applicable. OCP reviews social equity applications within 30 days and issues a determination letter that remains valid for 2 years." },
  { question: "Can social equity applicants get priority for limited municipal licenses?", answer: "Yes. Maine law requires municipalities that cap the number of cannabis licenses to reserve at least 20% of available licenses for social equity applicants. If a municipality has no cap, social equity applicants still receive expedited municipal review — typically 30 days instead of the standard 60–90 day window. Some municipalities, including Portland and Lewiston, have gone further by creating dedicated social equity license categories with reduced municipal fees." },
  { question: "What is the Maine Cannabis Equity Fund?", answer: "The Maine Cannabis Equity Fund is a state-managed grant program funded by 5% of adult-use cannabis tax revenue. It provides direct grants to social equity licensees for facility build-out, security systems, compliance consulting, and employee training. In 2025, the fund distributed $1.2 million to 34 social equity businesses, with average grants of $35,000. Applications open quarterly and are reviewed by an independent equity advisory board." },
  { question: "Does social equity status transfer if I sell my business?", answer: "No. Social equity status is tied to the individual applicant, not the business entity. If a social equity licensee sells their business or transfers majority ownership to a non-equity individual, the new owner must independently qualify for social equity status to maintain fee reductions and grant eligibility. The license itself remains valid, but the equity-specific benefits do not transfer." }
];

const faqPageJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
});
---

