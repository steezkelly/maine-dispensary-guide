---
import Layout from '../../layouts/Layout.astro';
import Callout from '../../components/Callout.astro';
import Faq from '../../components/Faq.astro';
import authors from '../../data/authors.json';

const calvinWaters = authors.find(a => a.id === 'calvin-waters');

const article = {
  author: "Calvin Waters",
  authorId: "calvin-waters",
  authorTitle: "Licensing & Compliance Analyst",
  publishDate: "2026-05-13",
  modifiedDate: "2026-05-13",
  section: "Medical Cannabis"
};
const topics = ["medical", "operations", "compliance"];

const faqItems = [
  {
    question: "Can Maine medical marijuana patients receive home delivery?",
    answer: "Yes. Maine's medical cannabis program allows registered caregivers and licensed dispensaries to deliver products directly to qualifying patients. Delivery must comply with OCP rules for medical cannabis transport, including product packaging requirements, patient ID verification at delivery, and transport logs. Patients or their caregivers cannot accept delivery from an unlicensed source."
  },
  {
    question: "What is the difference between a caregiver delivery and a dispensary delivery?",
    answer: "A registered caregiver delivers cannabis they have cultivated themselves to their own registered qualifying patients. A dispensary delivery is made by an OCP-licensed dispensary or couriers operating under a dispensary's courier license, delivering products the dispensary has procured or manufactured. Both are legal delivery mechanisms for medical patients, but they operate under different regulatory frameworks and licensing requirements."
  },
  {
    question: "Are there geographic restrictions on medical cannabis delivery in Maine?",
    answer: "Caregiver deliveries are limited to the caregiver's registered patients only — there is no statewide delivery radius for caregivers. OCP-licensed dispensary delivery operates within the dispensary's authorized service area, which is defined by municipal approvals and OCP license conditions. Some municipalities restrict delivery operations as part of their local cannabis ordinances. Patients in opt-out municipalities may have limited access to licensed delivery."
  },
  {
    question: "What documentation must accompany a medical cannabis delivery?",
    answer: "Every medical cannabis delivery must include a transport manifest listing the products, quantities, patient registry ID, and delivery address. The driver must carry their OCP-issued employee badge or caregiver registration. Patient ID must be verified at the delivery address before handing over products. All deliveries must be logged in METRC for adult-use products or the relevant tracking system for medical products."
  },
  {
    question: "Can caregivers charge a delivery fee to their patients?",
    answer: "Caregivers may charge patients for the cost of cannabis products and reasonable delivery fees associated with transporting those products. However, delivery fees cannot be structured in a way that constitutes profit on transport services separate from the product sale. Caregivers should document delivery fees as cost-recovery rather than standalone service charges. OCP guidance on caregiver economics confirms this distinction."
  },
  {
    question: "How do patients in rural Maine access medical cannabis delivery?",
    answer: "Rural access is one of the most significant gaps in Maine's medical cannabis program. Many rural municipalities have opted out of allowing dispensaries, leaving patients dependent on caregivers who may be located far away. Patients in these areas should contact the Maine OCP's patient navigator office, which maintains a list of caregivers and dispensaries willing to serve underserved regions. Telehealth certification paired with caregiver networks is increasingly being used to bridge rural access gaps."
  }
];

const faqPageJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
});
