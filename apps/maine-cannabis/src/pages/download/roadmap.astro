    border-radius: 2rem;
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(6, 26, 27, 0.25);
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .print-btn:hover {
    transform: translateY(-2px);
