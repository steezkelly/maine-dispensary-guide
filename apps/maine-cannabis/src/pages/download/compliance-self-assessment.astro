---
import Layout from '../../layouts/Layout.astro';
import PineTree from '@network/ui/PineTree';

const faqPageJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is included in the Maine Dispensary Compliance Self-Assessment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The self-assessment covers 8 compliance domains required by Maine OCP: facility security, inventory tracking (METRC), licensing documentation, employee records, financial reporting, product testing protocols, marketing compliance, and municipal authorization maintenance. Each domain includes a checklist of specific items OCP inspectors verify during announced and unannounced audits."
      }
    },
    {
      "@type": "Question",
      "name": "How often should Maine dispensaries conduct compliance self-audits?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "OCP recommends monthly internal self-assessments and quarterly comprehensive compliance audits. Dispensaries that self-audit monthly catch compliance gaps before they become enforcement issues. The operators with the cleanest OCP inspection records typically run internal audits every 30 days."
      }
    },
    {
      "@type": "Question",
      "name": "Can this self-assessment replace a professional compliance audit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. This self-assessment is a preparatory tool designed to help operators identify gaps before hiring a professional compliance consultant. It covers the same categories OCP inspectors examine, but a professional audit provides legal documentation, remediation plans, and expert interpretation of regulatory gray areas. Use this self-assessment for monthly internal reviews and engage a professional for annual comprehensive audits or when preparing for OCP inspection."
      }
    }
  ]
});
---

<Layout
  title="Free Maine Dispensary Compliance Self-Assessment"
  description="Download the free 8-domain compliance self-assessment checklist used by Maine cannabis dispensaries to prepare for OCP inspections. Security, METRC, licensing, and more."
  noindex={true}
>
  <style>
    .download-page {
      max-width: 800px;
      margin: 0 auto;
      padding: 3rem 2rem 6rem;
    }

    .doc-header {
      text-align: center;
      padding: 3rem 2rem;
      background: var(--color-surface);
      border-radius: 2rem;
      border: 1px solid var(--color-border);
      margin-bottom: 3rem;
    }

    .doc-logo { margin-bottom: 1rem; }

    .doc-brand {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--color-soft-green);
      margin-bottom: 1rem;
    }

    .doc-title {
      font-family: var(--font-serif);
      font-size: 2.25rem;
      line-height: 1.2;
      color: var(--color-primary);
      margin: 0.5rem 0;
    }

    .doc-subtitle {
      font-size: 1.125rem;
      color: var(--color-text-light);
      margin: 0.75rem 0 1.5rem;
    }

    .doc-meta {
      font-size: 0.8125rem;
      color: var(--color-text-light);
    }

    .download-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--color-primary);
      color: white;
      border: none;
      padding: 1rem 2.5rem;
      border-radius: 2rem;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      margin-top: 1.5rem;
      transition: transform 0.15s, box-shadow 0.15s;
    }

    .download-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(6, 26, 27, 0.3);
      text-decoration: none;
      color: white;
    }

    .domain-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin: 2rem 0;
    }

    .domain-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 1rem;
      padding: 1.5rem;
    }

    .domain-card h3 {
      font-family: var(--font-serif);
      font-size: 1.125rem;
      color: var(--color-primary);
      margin: 0 0 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .domain-card p {
      font-size: 0.9375rem;
      color: var(--color-text-light);
      margin: 0;
      line-height: 1.6;
    }

    .check-count {
      display: inline-block;
      background: var(--color-accent);
      color: white;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.15rem 0.5rem;
      border-radius: 0.75rem;
      margin-left: auto;
    }

    .sop-preview {
      background: rgba(88, 129, 87, 0.04);
      border: 1px solid var(--color-border);
      border-radius: 1rem;
      padding: 2rem;
      margin: 2rem 0;
    }

    .sop-preview h2 {
      font-family: var(--font-serif);
      font-size: 1.5rem;
      color: var(--color-primary);
      margin: 0 0 1rem;
    }

    .sop-preview pre {
      background: #1a1a2e;
      color: #e0e0e0;
      padding: 1.5rem;
      border-radius: 0.75rem;
      font-size: 0.8125rem;
      line-height: 1.7;
      overflow-x: auto;
      white-space: pre-wrap;
      word-wrap: break-word;
    }

    .related-guides {
      background-color: rgba(13, 78, 80, 0.03);
      border-radius: 0.5rem;
      padding: 1.5rem 2rem;
      margin-top: 3rem;
    }

    .related-guides h2 {
      font-size: 1.25rem;
      margin-top: 0;
      padding-bottom: 0;
      border-bottom: none;
    }

    .related-guides ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .related-guides li {
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(88, 129, 87, 0.15);
    }

    .related-guides a {
      color: var(--color-primary);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    @media (max-width: 768px) {
      .doc-title { font-size: 1.75rem; }
      .domain-grid { grid-template-columns: 1fr; }
    }
  </style>

  <article class="download-page">
    <div class="doc-header">
      <div class="doc-logo">
        <PineTree size={48} color="var(--color-primary)" />
      </div>
      <div class="doc-brand">Maine Dispensary Guide</div>
      <h1 class="doc-title">Maine Dispensary<br/>Compliance Self-Assessment</h1>
      <p class="doc-subtitle">The 8-domain checklist Maine operators use to prepare for OCP inspections</p>
      <div class="doc-meta">Version 2026.1 &bull; Updated May 2026 &bull; 12 pages &bull; Free Download</div>
      <a href="/downloads/maine-dispensary-compliance-self-assessment.pdf" class="download-btn" download>
        <span>&#8595;</span> Download PDF Checklist
      </a>
    </div>

    <section>
      <h2>What This Self-Assessment Covers</h2>
      <p>OCP inspectors evaluate dispensaries across 8 core compliance domains. This self-assessment breaks each domain into specific, verifiable checklist items you can review internally before an inspection arrives.</p>

      <div class="domain-grid">
        <div class="domain-card">
          <h3>1. Facility Security <span class="check-count">14 checks</span></h3>
          <p>Camera coverage, 30-day retention, intrusion detection, vault specifications, access control systems, and alarm response protocols.</p>
        </div>
        <div class="domain-card">
          <h3>2. METRC Inventory <span class="check-count">18 checks</span></h3>
          <p>Tagging accuracy, reconciliation frequency, waste logging, transfer manifests, manifest reconciliation, and variance thresholds.</p>
        </div>
        <div class="domain-card">
          <h3>3. Licensing <span class="check-count">10 checks</span></h3>
          <p>License display, renewal status, ownership disclosure accuracy, principal changes reporting, and municipal authorization validity.</p>
        </div>
        <div class="domain-card">
          <h3>4. Employee Records <span class="check-count">12 checks</span></h3>
          <p>IIC/AIC status for all employees, training documentation, background check records, and authorized access area assignments.</p>
        </div>
        <div class="domain-card">
          <h3>5. Financial Reporting <span class="check-count">11 checks</span></h3>
          <p>280E compliance documentation, banking records, source of funds verification, and transaction log accuracy.</p>
        </div>
        <div class="domain-card">
          <h3>6. Product Testing <span class="check-count">9 checks</span></h3>
          <p>Batch testing records, lab results retention, failed batch handling, recall procedures, and coa accessibility.</p>
        </div>
        <div class="domain-card">
          <h3>7. Marketing <span class="check-count">8 checks</span></h3>
          <p>Advertising content review, proximity to schools, online age verification, promotional material approvals, and social media compliance.</p>
        </div>
        <div class="domain-card">
          <h3>8. Municipal Auth <span class="check-count">6 checks</span></h3>
          <p>Local license validity, zoning compliance, buffer distance maintenance, and local tax remittance status.</p>
        </div>
      </div>
    </section>

    <section class="sop-preview">
      <h2>Sample: METRC Daily Reconciliation SOP</h2>
      <p>Every download includes 3 ready-to-customize SOP templates. Here's what a cannabis SOP looks like:</p>
      <pre>
STANDARD OPERATING PROCEDURE
METRC Daily Inventory Reconciliation

PURPOSE:
Ensure physical inventory matches METRC records within 
acceptable variance thresholds.

FREQUENCY: Daily, end of business day
RESPONSIBLE: Inventory Manager + Shift Supervisor

PROCEDURE:
1. Export METRC Active Inventory report for current date
2. Print Physical Inventory worksheet
3. Count all on-hand product by category (flower, 
   concentrates, edibles, topicals)
4. Record actual counts on Physical Inventory worksheet
5. Compare METRC report to physical counts
6. Document variances &gt; 1% on Variance Log (Form INV-01)
7. If variance &gt; 5%, escalate to Compliance Officer
   and pause sales until resolved
8. File completed worksheets in compliance binder
   (Section 6.2, dated order)

ACCEPTABLE VARIANCE THRESHOLDS:
- Flower: +/- 1.0% by weight
- Concentrates: +/- 0.5% by weight
- Edibles: +/- 2.0% by unit count
- Topicals: +/- 1.5% by unit count

DOCUMENT RETENTION: 5 years minimum
REVIEW DATE: Quarterly (next review: July 2026)
      </pre>
    </section>

    <section>
      <h2>How Operators Use This Assessment</h2>
      <p><strong>Monthly Self-Audit:</strong> Set a recurring calendar block. Walk through all 88 checklist items in 90 minutes. Score each item green (pass), yellow (needs attention), or red (non-compliant). Address all reds within 7 days.</p>
      <p><strong>Pre-Inspection Prep:</strong> OCP typically provides 48 hours notice of routine audits. Use this assessment as your final walkthrough checklist. Operators who run the full assessment before inspection report significantly lower deficiency rates.</p>
      <p><strong>Staff Training:</strong> Assign domain sections to relevant team members. The inventory manager owns Domain 2 (METRC). The compliance officer owns Domains 1, 3, 4, and 7. The GM owns Domains 5 and 8.</p>
    </section>

    <div class="doc-header" style="margin-top: 3rem;">
      <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">Download the Full Assessment</h2>
      <p class="doc-subtitle">12 pages &bull; 88 checklist items &bull; 3 SOP templates &bull; Print-ready PDF</p>
      <a href="/downloads/maine-dispensary-compliance-self-assessment.pdf" class="download-btn" download>
        <span>&#8595;</span> Download Free PDF
      </a>
    </div>

    <section class="related-guides">
      <h2>Related Compliance Resources</h2>
      <ul>
        <li><a href="/guides/maine-metrc-compliance-guide">Maine METRC Compliance Guide</a> — Complete seed-to-sale tracking requirements</li>
        <li><a href="/guides/maine-dispensary-security">Maine Dispensary Security Requirements</a> — OCP facility security specifications</li>
        <li><a href="/guides/maine-cannabis-marketing-compliance">Maine Cannabis Marketing Compliance</a> — Advertising rules and prohibited practices</li>
        <li><a href="/blog/maine-dispensary-how-to-open">How to Open a Maine Dispensary</a> — Full licensing walkthrough</li>
      </ul>
    </section>
  </article>
</Layout>

<script type="application/ld+json" set:text={faqPageJsonLd}></script>
