---
/**
 * Layout.astro — Maine Dispensary Guide
 *
 * This is the main Layout for the Maine cannabis vertical.
 * It reads configuration from src/data/site-config.json
 *
 * For the content network architecture:
 * - packages/layouts/Layout.astro is the SHARED base layout (template)
 * - Each app's src/layouts/Layout.astro is the CUSTOMIZED version
 *
 * This file contains the actual implementation with Maine-specific config.
 * The shared package provides the component architecture and design system.
 */

import Breadcrumbs from '@network/ui/Breadcrumbs';
import PineTree from '@network/ui/PineTree';
import Leaf from '@network/ui/Leaf';
import GuideSidebar from '@network/ui/GuideSidebar';
import Search from '@network/ui/Search';
import RelatedArticles from '@network/ui/RelatedArticles';
import siteConfig from '../data/site-config.json';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface ArticleData {
  author?: string;
  authorTitle?: string;
  authorId?: string;
  publishDate?: string;
  modifiedDate?: string;
  section?: string;
}

interface Breadcrumb {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  stateName?: string;
  isHub?: boolean;
  heroImage?: string;
  article?: ArticleData;
  breadcrumbs?: Breadcrumb[];
  noindex?: boolean;
  topics?: string[];
  tags?: string[];
}

const {
  title,
  description = "Your complete guide to opening and operating a cannabis dispensary.",
  stateName = siteConfig.stateName,
  isHub = false,
  heroImage,
  article,
  breadcrumbs = [],
  noindex = false,
  topics = [],
  tags = []
} = Astro.props;

// Site Metadata & State
const siteName = isHub ? "Dispensary Guide" : siteConfig.siteName;
const siteUrl = siteConfig.siteUrl;
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const isGuide = Astro.url.pathname.startsWith('/guides/') && Astro.url.pathname !== '/guides';
const isContent = isGuide || Astro.url.pathname.startsWith('/founders/');

// Breadcrumbs
const breadcrumbLabels: Record<string, string> = {
  'guides': 'Guides',
  'about': 'About',
  'blog': 'Blog',
  'resources': 'Resources',
  'founders': 'Founders',
  'download': 'Downloads',
  'contact': 'Contact',
  'start-here': 'Start Here',
  'roi-calculator': 'ROI Calculator',
  'glossary': 'Glossary',
  'market-stats': 'Market Stats',
};

function buildCrumbs(path: string, explicitCrumbs: Breadcrumb[]): Breadcrumb[] {
  if (explicitCrumbs.length > 0) return explicitCrumbs;
  const parts = path.split('/').filter(Boolean);
  if (parts.length === 0) return [];
  const crumbs: Breadcrumb[] = [];
  let running = '';
  for (const part of parts) {
    running = running + '/' + part;
    crumbs.push({ label: breadcrumbLabels[part] || part.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()), href: running });
  }
  return crumbs;
}

const allBreadcrumbs = buildCrumbs(Astro.url.pathname.replace(/\/$/, ''), breadcrumbs);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
