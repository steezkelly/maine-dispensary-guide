              <div class="article-meta">
                <span class="article-byline">By {article.author || siteConfig.siteName + " Editorial Team"}</span>
                {article.publishDate && (
                  <span class="article-date">Published {new Date(article.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                )}
