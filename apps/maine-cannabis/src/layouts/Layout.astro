    </header>

    <main id="main-content" role="main" tabindex="-1">
      <Breadcrumbs />
      {isGuide ? (
        <div class="guide-layout">
          <div class="guide-content">
            {heroImage && <div class="guide-hero"><img src={heroImage} alt={`${stateName} cannabis ${article?.section?.toLowerCase() || 'guide'}: ${title}`} width={1200} height={400} loading="eager" /></div>}
            <slot />
