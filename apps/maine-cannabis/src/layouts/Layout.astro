        <p class="disclaimer">Informational purposes only. Consult with professionals.</p>
      </div>
    </footer>

    <script is:inline>
      // Scroll handler for header effects, progress bar, and back-to-top
      (function() {
        const header = document.getElementById('site-header');
        if (!header) return;

        const handleScroll = () => {
          const scrolled = window.scrollY > 50;
          header.classList.toggle('scrolled', scrolled);

          const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
          const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          const progress = (winScroll / height) * 100;
          const pb = document.getElementById("progress-bar");
          if (pb) pb.style.width = progress + "%";

          const btt = document.getElementById('back-to-top');
          if (btt) btt.style.display = winScroll > 500 ? "block" : "none";
        };

        // Check for reduced motion preference
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (!prefersReducedMotion) {
          window.addEventListener('scroll', handleScroll, { passive: true });
          handleScroll(); // Initial check
        }

        const bttBtn = document.getElementById('back-to-top');
        if (bttBtn) bttBtn.onclick = () => window.scrollTo({top: 0, behavior: 'smooth'});

        // Scroll-triggered reveal animation
        const observerOptions = {
          root: null,
          rootMargin: '0px 0px -80px 0px',
          threshold: 0.1
        };

        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              const delay = entry.target.style.animationDelay || '0s';
              entry.target.style.transitionDelay = delay;
              entry.target.classList.add('visible');
              revealObserver.unobserve(entry.target);
            }
          });
        }, observerOptions);

        document.querySelectorAll('.reveal').forEach(el => {
          revealObserver.observe(el);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  /**
   * Layout.astro
   * The structural "DNA" of the Maine Dispensary Guide.
   */
  :root {
    --color-primary: #0D4E50;
    --color-primary-dark: #083638;
    --color-secondary: #101820; /* Deepest Navy/Charcoal */
    --color-accent: #588157;    /* Leaf Green */
    --color-soft-green: #7A9A6A; /* Sage - darkened to 4.5:1 on white */
    --color-background: #F2F2E2; /* Warm Bone */
    --color-surface: #ffffff;
    --color-text: #101820;      /* Maximum Contrast Text */
    --color-text-light: #4A5568;
    --color-border: #D1D1C1;
    --font-family: 'Plus Jakarta Sans', sans-serif;
    --font-serif: 'Fraunces', serif;
    --max-width: 1200px;
    --radius: 1.5rem;

    /* Disclaimer / Alert Box */
    --color-disclaimer-bg: #fff3cd;
    --color-disclaimer-border: #ffc107;
    --color-disclaimer-text: #1a1a1a;
  }

  [data-theme="dark"] {
    --color-primary: #C4D4B6;
    --color-primary-dark: #F2F2E2;
    --color-background: #061A1B;
    --color-surface: #0A2829;
    --color-text: #F2F2E2;
    --color-text-light: #B8C9B0;
    --color-border: #1D3D3D;

    /* Disclaimer / Alert Box */
