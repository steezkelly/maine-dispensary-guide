# Maine Dispensary Guide — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Brave Search API (primary web search)
# Get key at: https://brave.com/search/api/
# Free tier: 1000 req/month
BRAVE_SEARCH_API_KEY=your-brave-api-key-here

# NOTE: Site config (GA4, Formspree, verification tokens) lives in
# apps/maine-cannabis/src/data/site-config.json — not env vars.
# This site is single-environment (production only), so config is committed.
