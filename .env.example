# Maine Dispensary Guide — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Brave Search API (primary web search)
# Get key at: https://brave.com/search/api/
# Free tier: 1000 req/month
BRAVE_SEARCH_API_KEY=your-brave-api-key-here

# Google Analytics GA4 (optional — already hardcoded in Layout.astro)
# GA_MEASUREMENT_ID=G-614GHG67ZQ

# Formspree (lead capture — already hardcoded in forms)
# FORMSPREE_ENDPOINT=https://formspree.io/f/xvgzlowz
