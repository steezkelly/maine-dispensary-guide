---
const { url } = Astro;
const pathSegments = url.pathname.split('/').filter(segment => segment !== '');

const breadcrumbs = pathSegments.map((segment, index) => {
  if (segment === 'admin') return null;
  const isDownloadParent = segment === 'download' && index === 0 && pathSegments.length > 1;
  const href = isDownloadParent
    ? '/resources'
    : '/' + pathSegments.slice(0, index + 1).join('/');
  const label = isDownloadParent
    ? 'Resources'
    : segment
      .replace(/-/g, ' ')
      .replace(/\b\w/g, char => char.toUpperCase());
  return { href, label };
}).filter((crumb): crumb is { href: string; label: string } => crumb !== null);

const isHome = url.pathname === '/';

// Use the same trailing-slash-free URL as the site's trailingSlash: 'never' config
// so schema URLs match canonical/page URLs exactly
const siteUrl = "https://mainedispensaryguide.com";

const breadcrumbListSchema = !isHome ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    ...breadcrumbs.map((crumb, index) => ({
      "@type": "ListItem",
      "position": index + 2,
      "name": crumb.label,
      // href always has trailing slash from the map() above; strip it to match trailingSlash: 'never'
      "item": siteUrl + crumb.href.replace(/\/$/, '')
    }))
  ]
} : null;
---

{!isHome && breadcrumbListSchema && (
  <script type="application/ld+json" set:text={JSON.stringify(breadcrumbListSchema)} />
)}

{!isHome && (
  <nav aria-label="Breadcrumb" class="breadcrumbs">
    <ol>
      <li>
        <a href="/">Home</a>
      </li>
      {breadcrumbs.map((crumb, index) => (
        <li>
          <span class="separator">/</span>
          {index === breadcrumbs.length - 1 ? (
            <span class="current" aria-current="page">{crumb?.label}</span>
          ) : (
            <a href={crumb?.href}>{crumb?.label}</a>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .breadcrumbs {
    max-width: var(--max-width);
    margin: 0 auto 1.5rem;
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  .breadcrumbs ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }

  .breadcrumbs li {
    display: flex;
    align-items: center;
  }

  .breadcrumbs a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumbs a:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
  }

  .separator {
    margin: 0 0.5rem;
    color: #ccc;
    user-select: none;
  }

  .current {
    font-weight: 500;
    color: var(--color-text);
  }
</style>
