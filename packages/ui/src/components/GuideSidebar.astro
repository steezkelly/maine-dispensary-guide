const businessGuides = [
  { title: "License Requirements", href: "/guides/maine-dispensary-license" },
  { title: "Business Plan", href: "/guides/maine-dispensary-business-plan" },
  { title: "Startup Costs", href: "/guides/maine-dispensary-costs" },
  { title: "Market Analysis", href: "/guides/maine-cannabis-market" }
];

const cityGuides = [
  { title: "Portland Guide", href: "/guides/portland-dispensary-guide" },
  { title: "Augusta Guide", href: "/guides/augusta-dispensary-guide" },
  { title: "South Portland", href: "/guides/south-portland-dispensary-guide" },
  { title: "Bangor Guide", href: "/guides/bangor-dispensary-guide" }
];

const complianceGuides = [
  { title: "280E Tax Guide", href: "/guides/maine-cannabis-taxation-280e" },
  { title: "Security Rules", href: "/guides/maine-dispensary-security" },
  { title: "POS Systems", href: "/guides/maine-dispensary-pos" }
];

// Use trailing-slash-free paths to match trailingSlash: 'never' config
const isActive = (href: string) => currentPath === href || currentPath.startsWith(href) || currentPath.startsWith(href + '/');

function calculateScore(guideTopics: string[], topics: string[]): number {
  let score = 0;
  for (const topic of guideTopics) {
    if (topics.includes(topic)) score += 2;
  }
  return score;
}

// Score each guide by topic match
const scoredGuides = allGuides.map(g => ({ ...g, score: calculateScore(g.topics, currentTopics) }));

// City guides (score > 0 means at least one topic matches)
const relatedCityGuides = scoredGuides
  .filter(g => g.topics.includes('city') && g.score > 0)
  .sort((a, b) => b.score - a.score || a.title.localeCompare(b.title))
  .slice(0, 4);

// Business guides (score > 0)
const relatedBusinessGuides = scoredGuides
  .filter(g => (g.topics.includes('business') || g.topics.includes('finance') || g.topics.includes('licensing')) && g.score > 0)
  .sort((a, b) => b.score - a.score || a.title.localeCompare(b.title))
  .slice(0, 4);

// Compliance guides (score > 0)
const relatedComplianceGuides = scoredGuides
  .filter(g => g.topics.includes('compliance') && g.score > 0)
  .sort((a, b) => b.score - a.score || a.title.localeCompare(b.title))
  .slice(0, 4);

// Fallback to static arrays when no topic matches
const hasRelatedContent = relatedCityGuides.length > 0 || relatedBusinessGuides.length > 0 || relatedComplianceGuides.length > 0;
