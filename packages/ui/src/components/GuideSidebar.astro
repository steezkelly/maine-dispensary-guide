---
const { category = "Business Essentials" } = Astro.props;
const currentPath = Astro.url.pathname;

const businessGuides = [
  { title: "License Requirements", href: "/guides/maine-dispensary-license" },
  { title: "Business Plan", href: "/guides/maine-dispensary-business-plan" },
  { title: "Startup Costs", href: "/guides/maine-dispensary-costs" },
  { title: "Market Analysis", href: "/guides/maine-cannabis-market" }
];

const cityGuides = [
  { title: "Portland Guide", href: "/guides/portland-dispensary-guide" },
  { title: "Augusta Guide", href: "/guides/augusta-dispensary-guide" },
  { title: "South Portland", href: "/guides/south-portland-dispensary-guide" },
  { title: "Bangor Guide", href: "/guides/bangor-dispensary-guide" }
];

const complianceGuides = [
  { title: "280E Tax Guide", href: "/guides/maine-cannabis-taxation-280e" },
  { title: "Security Rules", href: "/guides/maine-dispensary-security" },
  { title: "POS Systems", href: "/guides/maine-dispensary-pos" }
];

const isActive = (href: string) => currentPath === href || currentPath.startsWith(href + '/');
---

<aside class="guide-sidebar">
  <div class="author-badge">
    <div class="author-icon">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>
    <div class="author-content">
      <span class="author-title">Expert Verified Guide</span>
      <span class="author-date">Updated: March 2026</span>
    </div>
  </div>

  <nav class="sidebar-nav" aria-label="Guide navigation">
    <div class="sidebar-section">
      <h3 class="section-header">
        <span class="section-icon">◆</span>
        Business Essentials
      </h3>
      <ul class="section-list">
        {businessGuides.map(guide => (
          <li>
            <a 
              href={guide.href} 
              class:list={["nav-link", { active: isActive(guide.href) }]}
              aria-current={isActive(guide.href) ? "page" : undefined}
            >
              <span class="link-indicator"></span>
              <span class="link-text">{guide.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="sidebar-section">
      <h3 class="section-header">
        <span class="section-icon">▲</span>
        City Guides
      </h3>
      <ul class="section-list">
        {cityGuides.map(guide => (
          <li>
            <a 
              href={guide.href} 
              class:list={["nav-link", { active: isActive(guide.href) }]}
              aria-current={isActive(guide.href) ? "page" : undefined}
            >
              <span class="link-indicator"></span>
              <span class="link-text">{guide.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="sidebar-section">
      <h3 class="section-header">
        <span class="section-icon">✦</span>
        Compliance
      </h3>
      <ul class="section-list">
        {complianceGuides.map(guide => (
          <li>
            <a 
              href={guide.href} 
              class:list={["nav-link", { active: isActive(guide.href) }]}
              aria-current={isActive(guide.href) ? "page" : undefined}
            >
              <span class="link-indicator"></span>
              <span class="link-text">{guide.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <div class="sidebar-cta">
    <div class="cta-decoration"></div>
    <p class="cta-question">Need professional help?</p>
    <p class="cta-subtitle">Connect with verified vendors</p>
    <a href="/resources" class="btn-cta">
      <span>View Vendor Directory</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>
</aside>

<style>
  .guide-sidebar {
    width: 100%;
    padding: 1.75rem;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 0.875rem;
    position: sticky;
    top: 120px;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  /* Author Badge */
  .author-badge {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 1.125rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, color-mix(in srgb, var(--color-primary) 85%, black) 100%);
    border-radius: 0.5rem;
    margin-bottom: 1.75rem;
    position: relative;
    overflow: hidden;
  }

  .author-badge::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 60px;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1));
    pointer-events: none;
  }

  .author-icon {
    width: 32px;
    height: 32px;
    background: rgba(255, 255, 255, 0.2);
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    flex-shrink: 0;
    backdrop-filter: blur(4px);
  }

  .author-content {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .author-title {
    font-family: 'Fraunces', serif;
    font-weight: 700;
    font-size: 0.9375rem;
    color: white;
    letter-spacing: -0.01em;
  }

  .author-date {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 500;
  }

  /* Navigation */
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 1.75rem;
  }

  .sidebar-section {
    position: relative;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Fraunces', serif;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-border);
    position: relative;
  }

  .section-header::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 40px;
    height: 2px;
    background: var(--color-accent);
  }

  .section-icon {
    font-size: 0.625rem;
    color: var(--color-accent);
    display: inline-block;
  }

  .section-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* Nav Links */
  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    color: var(--color-text);
    text-decoration: none;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    background: transparent;
  }

  .link-indicator {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-border);
    flex-shrink: 0;
    transition: all 0.25s ease;
  }

  .link-text {
    position: relative;
  }

  .link-text::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--color-primary);
    transition: width 0.25s ease;
  }

  /* Hover State */
  .nav-link:hover {
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 6%, transparent);
  }

  .nav-link:hover .link-indicator {
    background: var(--color-accent);
    transform: scale(1.2);
  }

  .nav-link:hover .link-text::after {
    width: 100%;
  }

  /* Active State */
  .nav-link.active {
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    font-weight: 600;
  }

  .nav-link.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 60%;
    background: var(--color-accent);
    border-radius: 0 2px 2px 0;
  }

  .nav-link.active .link-indicator {
    background: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 25%, transparent);
  }

  .nav-link.active .link-text::after {
    width: 100%;
  }

  /* Focus State */
  .nav-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* CTA Section */
  .sidebar-cta {
    background: linear-gradient(145deg, var(--color-primary) 0%, color-mix(in srgb, var(--color-primary) 85%, black) 100%);
    border-radius: 0.625rem;
    padding: 1.375rem 1.25rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-decoration {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 80px;
    height: 80px;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-question {
    font-family: 'Fraunces', serif;
    font-size: 1rem;
    font-weight: 700;
    color: white;
    margin: 0 0 0.25rem 0;
    letter-spacing: -0.01em;
  }

  .cta-subtitle {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 1rem 0;
    font-weight: 500;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: white;
    color: var(--color-primary);
    padding: 0.75rem 1.25rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .btn-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    background: var(--color-accent);
    color: white;
  }

  .btn-cta:active {
    transform: translateY(0);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
  }

  .btn-cta svg {
    transition: transform 0.2s ease;
  }

  .btn-cta:hover svg {
    transform: translateX(3px);
  }

  /* Dark Mode */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) {
      --color-background: #0D1F20;
      --color-text: #E8E4D9;
      --color-text-light: #9CA3AF;
    }
  }

  [data-theme="dark"] .guide-sidebar {
    background: #0D1F20;
    border-color: #1E3A3D;
  }

  [data-theme="dark"] .author-badge {
    background: linear-gradient(135deg, #1A5F5A 0%, #134545 100%);
  }

  [data-theme="dark"] .section-header {
    color: #E8E4D9;
    border-color: #1E3A3D;
  }

  [data-theme="dark"] .section-header::after {
    background: #3D9F97;
  }

  [data-theme="dark"] .nav-link {
    color: #C4BBA8;
  }

  [data-theme="dark"] .nav-link:hover {
    color: #3D9F97;
    background: rgba(61, 159, 151, 0.08);
  }

  [data-theme="dark"] .nav-link.active {
    color: #3D9F97;
    background: rgba(61, 159, 151, 0.12);
  }

  [data-theme="dark"] .sidebar-cta {
    background: linear-gradient(145deg, #1A5F5A 0%, #134545 100%);
  }

  [data-theme="dark"] .btn-cta:hover {
    background: #3D9F97;
  }

  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .guide-sidebar,
    .nav-link,
    .link-indicator,
    .link-text::after,
    .btn-cta,
    .author-badge::before {
      transition: none;
    }

    .nav-link:hover,
    .btn-cta:hover {
      transform: none;
    }
  }
</style>