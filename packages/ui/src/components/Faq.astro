---
interface FAQItem {
  question: string;
  answer: string;
}

interface ShortFAQItem {
  q: string;
  a: string;
}

interface Props {
  faqs?: FAQItem[];
  items?: FAQItem[];
  questions?: ShortFAQItem[];
}

const { faqs, items, questions } = Astro.props;
const normalizedFaqs = faqs ?? items ?? questions?.map(({ q, a }) => ({ question: q, answer: a })) ?? [];

const siteUrl = "https://mainedispensaryguide.com";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": normalizedFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<script type="application/ld+json" set:text={JSON.stringify(faqSchema)} />

<div class="faq-schema-wrapper">
  <slot />
</div>

<style>
  .faq-schema-wrapper {
    display: contents;
  }
</style>
