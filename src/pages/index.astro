---
import Layout from '../layouts/Layout.astro';
import PineTree from '../components/PineTree.astro';
import Leaf from '../components/Leaf.astro';

const stats = [
  { label: "Annual Sales", value: "$246M" },
  { label: "Active Stores", value: "179" },
  { label: "Price/Gram", value: "$6.62" }
];
---

<Layout title="Maine Dispensary Guide | High-Authority Cannabis Business Resource">
  <section class="premium-hero">
    <div class="hero-container">
      <div class="hero-content reveal" style="animation-delay: 0.1s;">
        <div class="hero-badge">Updated for 2026</div>
        <h1>The Professional Gateway to Maine's Cannabis Market</h1>
        <p>Expert-vetted guides for navigating licensing, compliance, and growth in the Pine Tree State.</p>
        <div class="hero-btns">
          <a href="/guides/maine-dispensary-license/" class="btn-main">Start Your Application</a>
          <a href="/roi-calculator/" class="btn-secondary">Calculate Your ROI</a>
        </div>
      </div>
      <div class="hero-visual reveal" style="animation-delay: 0.3s;">
        <div class="visual-card">
          <PineTree size={120} color="rgba(255,255,255,0.2)" />
          <Leaf size={80} color="rgba(255,255,255,0.1)" />
        </div>
      </div>
    </div>

  </section>

  <section class="market-bar">
    <div class="bar-container">
      {stats.map(stat => (
        <div class="bar-item">
          <span class="bar-label">{stat.label}:</span>
          <span class="bar-value">{stat.value}</span>
        </div>
      ))}
      <a href="/market-stats/" class="bar-link">Full Report &rarr;</a>
    </div>
  </section>
  
  <section class="mission-statement">
    <div class="mission-content">
      <h2>Build Your Passion Project</h2>
      <p>Opening a dispensary in Maine is more than just a business—it's about community, craft, and following a vision. We believe that with the right guidance, the complexity of compliance shouldn't stand in the way of your passion.</p>
    </div>
  </section>

  <section class="core-hubs reveal" style="animation-delay: 0.2s;">
    <div class="section-header">
      <h2>Authority Knowledge Hubs</h2>
      <p>Select a category to begin your deep-dive.</p>
    </div>
    <div class="hub-grid">
      <a href="/guides/maine-dispensary-license/" class="hub-card">
        <div class="hub-icon">📜</div>
        <h3>Licensing</h3>
        <p>Step-by-step state and local approval maps.</p>
      </a>
      <a href="/guides/maine-cannabis-taxation-280e/" class="hub-card">
        <div class="hub-icon">⚖️</div>
        <h3>Compliance</h3>
        <p>Mastering 280E and OCP tracking rules.</p>
      </a>
      <a href="/guides/maine-cannabis-real-estate/" class="hub-card">
        <div class="hub-icon">📍</div>
        <h3>Real Estate</h3>
        <p>Finding compliant zones in every town.</p>
      </a>
      <a href="/roi-calculator/" class="hub-card">
        <div class="hub-icon">📊</div>
        <h3>ROI Calculator</h3>
        <p>Estimate startup costs and break-even timelines.</p>
      </a>
      <a href="/resources/" class="hub-card">
        <div class="hub-icon">🤝</div>
        <h3>Vendors</h3>
        <p>Connect with expert lawyers and CPAs.</p>
      </a>
    </div>
  </section>

  <section class="geo-explorer reveal" style="animation-delay: 0.4s;">
    <div class="explorer-content">
      <h2>Explore Municipal Guides</h2>
      <p>Local zoning and competitive analysis for Maine's "Opt-In" communities.</p>
      <div class="city-chips">
        <a href="/guides/portland-dispensary-guide/">Portland</a>
        <a href="/guides/augusta-dispensary-guide/">Augusta</a>
        <a href="/guides/bangor-dispensary-guide/">Bangor</a>
        <a href="/guides/lewiston-dispensary-guide/">Lewiston</a>
        <a href="/guides/south-portland-dispensary-guide/">South Portland</a>
        <a href="/guides/biddeford-dispensary-guide/">Biddeford</a>
        <a href="/guides/auburn-dispensary-guide/">Auburn</a>
      </div>
      <a href="/guides/" class="btn-secondary">View All 41 Guides &rarr;</a>
    </div>
  </section>
</Layout>

<style>
  <body class="bg-maine">
    <!-- BOTANICAL BACKGROUND ORNAMENTS -->
    <div class="bg-ornament top-right"><PineTree size={400} color="rgba(13, 78, 80, 0.03)" /></div>
    <div class="bg-ornament bottom-left"><Leaf size={300} color="rgba(88, 129, 87, 0.03)" /></div>

    <section class="premium-hero">
...
  .premium-hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: white;
    padding: 4rem 0;
    border-radius: 2rem;
    margin-bottom: 0;
    overflow: hidden;
    position: relative;
    max-width: 100%;
    z-index: 10;
  }

  /* Botanical Ornaments */
  .bg-ornament {
    position: absolute;
    pointer-events: none;
    z-index: -1;
    overflow: hidden;
  }

  .top-right { top: -100px; right: -100px; transform: rotate(15deg); }
  .bottom-left { bottom: 10%; left: -50px; transform: rotate(-10deg); }

  [data-theme="dark"] .bg-ornament { opacity: 0.5; }

  [data-theme="dark"] .premium-hero {
    background: linear-gradient(135deg, #051A1B 0%, #0D2628 100%);
    border: 1px solid var(--color-border);
  }

  [data-theme="dark"] .btn-main {
    background: var(--color-primary);
    color: var(--color-background);
  }

  .hero-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .hero-content h1 {
    color: white;
    font-size: 2.75rem;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  @media (max-width: 600px) {
    .hero-content h1 { font-size: 2.25rem; }
    .premium-hero { padding: 4rem 0; }
    .core-hubs { margin-bottom: 4rem; }
    .hub-grid { gap: 1rem; }
    .hub-card { padding: 1.5rem; }
  }

  .hero-content p {
    font-size: 1.25rem;
    opacity: 0.9;
    margin-bottom: 2.5rem;
  }

  .hero-btns {
    display: flex;
    gap: 1rem;
  }

  .btn-main {
    background: white;
    color: var(--color-primary);
    padding: 1rem 2rem;
    border-radius: 1rem;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .btn-outline {
    border: 1px solid rgba(255,255,255,0.3);
    color: white;
    padding: 1rem 2rem;
    border-radius: 1rem;
    font-weight: 700;
    text-decoration: none;
  }

  .hero-visual {
    position: relative;
    height: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @keyframes float {
    0% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(2deg); }
    100% { transform: translateY(0px) rotate(0deg); }
  }

  .logo-pine {
    animation: float 6s ease-in-out infinite;
  }

  .logo-leaf {
    animation: float 8s ease-in-out infinite reverse;
    margin-left: -30px;
    margin-top: 50px;
  }

  .hero-leaf {
    position: absolute;
    bottom: 20%;
    right: 20%;
  }

  .market-bar {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 1.5rem 0;
    margin-bottom: 5rem;
  }

  .bar-container {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: 3rem;
    align-items: center;
  }

  .bar-item {
    font-size: 0.9375rem;
  }

  .bar-label {
    color: var(--color-text-light);
    font-weight: 600;
    margin-right: 0.5rem;
  }

  .bar-value {
    color: var(--color-primary);
    font-weight: 700;
  }

  .bar-link {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-accent);
    text-decoration: none;
  }

  .mission-statement {
    text-align: center;
    margin-bottom: 6rem;
  }

  .mission-content h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .mission-content p {
    font-size: 1.25rem;
    color: var(--color-text-light);
    max-width: 700px;
    margin: 0 auto;
  }

  .core-hubs {
    margin-bottom: 8rem;
  }
.hub-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 2rem;
  margin-top: 3rem;
}

.hub-card {
  background: white;
  padding: 3rem 2rem;
  border-radius: 2.5rem;
  border: 1px solid var(--color-border);
  text-decoration: none;
  transition: all 0.5s cubic-bezier(0.2, 1, 0.2, 1);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hub-card:hover {
  transform: translateY(-12px);
  box-shadow: 0 30px 60px rgba(13, 78, 80, 0.1);
  border-color: var(--color-primary);
}

.hub-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.6),
    transparent
  );
  transition: 0.6s;
}

.hub-card:hover::after {
  left: 100%;
}

.hub-icon {
  font-size: 3.5rem;
  margin-bottom: 1.5rem;
  display: block;
  transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.hub-card:hover .hub-icon {
  transform: scale(1.2) rotate(8deg);
}

.hub-card h3 {
  margin: 0 0 0.75rem;
  color: var(--color-primary);
  font-family: var(--font-serif);
  font-size: 1.5rem;
}

.hub-card p {
  margin: 0;
  font-size: 0.95rem;
  color: var(--color-text-light);
  line-height: 1.6;
}

.visual-card {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  padding: 4rem;
  border-radius: 3.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 40px 80px rgba(0,0,0,0.15);
}


  .city-chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin: 2.5rem 0 3.5rem;
  }

  .city-chips a {
    background: var(--color-background);
    color: var(--color-primary);
    padding: 0.75rem 1.5rem;
    border-radius: 2rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .city-chips a:hover {
    background: var(--color-primary);
    color: white;
  }

  @media (max-width: 850px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-btns {
      justify-content: center;
    }
    .hero-visual {
      display: none;
    }
    .bar-container {
      flex-wrap: wrap;
      gap: 1rem;
    }
  }
</style>
