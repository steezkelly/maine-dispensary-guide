---
import Layout from '../layouts/Layout.astro';
import PineTree from '../components/PineTree.astro';
import Leaf from '../components/Leaf.astro';

const stats = [
  { label: "Annual Sales", value: "$246M" },
  { label: "Active Stores", value: "179" },
  { label: "Price/Gram", value: "$6.62" }
];
---

<Layout title="Maine Dispensary Guide | High-Authority Cannabis Business Resource">
  <section class="premium-hero">
    <div class="hero-container">
      <div class="hero-content">
        <div class="hero-badge">Updated for 2026</div>
        <h1>The Professional Gateway to Maine's Cannabis Market</h1>
        <p>Expert-vetted guides for navigating licensing, compliance, and growth in the Pine Tree State.</p>
        <div class="hero-btns">
          <a href="/guides/maine-dispensary-license/" class="btn-main">Start Your Application</a>
          <a href="/roi-calculator/" class="btn-outline">Calculate Your ROI</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="abstract-shape">
          <PineTree size={120} color="white" className="hero-pine" />
          <Leaf size={80} color="rgba(255,255,255,0.4)" className="hero-leaf" />
        </div>
      </div>
    </div>
  </section>

  <section class="market-bar">
    <div class="bar-container">
      {stats.map(stat => (
        <div class="bar-item">
          <span class="bar-label">{stat.label}:</span>
          <span class="bar-value">{stat.value}</span>
        </div>
      ))}
      <a href="/market-stats/" class="bar-link">Full Report &rarr;</a>
    </div>
  </section>
  
  <section class="mission-statement">
    <div class="mission-content">
      <h2>Build Your Passion Project</h2>
      <p>Opening a dispensary in Maine is more than just a business—it's about community, craft, and following a vision. We believe that with the right guidance, the complexity of compliance shouldn't stand in the way of your passion.</p>
    </div>
  </section>

  <section class="core-hubs">
    <div class="section-header">
      <h2>Authority Knowledge Hubs</h2>
      <p>Select a category to begin your deep-dive.</p>
    </div>
    <div class="hub-grid">
      <a href="/guides/maine-dispensary-license/" class="hub-card">
        <div class="hub-icon">📜</div>
        <h3>Licensing</h3>
        <p>Step-by-step state and local approval maps.</p>
      </a>
      <a href="/guides/maine-cannabis-taxation-280e/" class="hub-card">
        <div class="hub-icon">⚖️</div>
        <h3>Compliance</h3>
        <p>Mastering 280E and OCP tracking rules.</p>
      </a>
      <a href="/guides/maine-cannabis-real-estate/" class="hub-card">
        <div class="hub-icon">📍</div>
        <h3>Real Estate</h3>
        <p>Finding compliant zones in every town.</p>
      </a>
      <a href="/roi-calculator/" class="hub-card">
        <div class="hub-icon">📊</div>
        <h3>ROI Calculator</h3>
        <p>Estimate startup costs and break-even timelines.</p>
      </a>
      <a href="/resources/" class="hub-card">
        <div class="hub-icon">🤝</div>
        <h3>Vendors</h3>
        <p>Connect with expert lawyers and CPAs.</p>
      </a>
    </div>
  </section>

  <section class="geo-explorer">
    <div class="explorer-content">
      <h2>Explore Municipal Guides</h2>
      <p>Local zoning and competitive analysis for Maine's "Opt-In" communities.</p>
      <div class="city-chips">
        <a href="/guides/portland-dispensary-guide/">Portland</a>
        <a href="/guides/augusta-dispensary-guide/">Augusta</a>
        <a href="/guides/bangor-dispensary-guide/">Bangor</a>
        <a href="/guides/lewiston-dispensary-guide/">Lewiston</a>
        <a href="/guides/south-portland-dispensary-guide/">South Portland</a>
        <a href="/guides/biddeford-dispensary-guide/">Biddeford</a>
        <a href="/guides/auburn-dispensary-guide/">Auburn</a>
      </div>
      <a href="/guides/" class="btn-secondary">View All 41 Guides &rarr;</a>
    </div>
  </section>
</Layout>

<style>
  .premium-hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: white;
    padding: 6rem 0;
    border-radius: 2rem;
    margin-bottom: 0;
    overflow: hidden;
    position: relative;
  }

  .hero-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .hero-content h1 {
    color: white;
    font-size: 3.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  @media (max-width: 600px) {
    .hero-content h1 { font-size: 2.25rem; }
    .premium-hero { padding: 4rem 0; }
    .core-hubs { margin-bottom: 4rem; }
    .hub-grid { gap: 1rem; }
    .hub-card { padding: 1.5rem; }
  }

  .hero-content p {
    font-size: 1.25rem;
    opacity: 0.9;
    margin-bottom: 2.5rem;
  }

  .hero-btns {
    display: flex;
    gap: 1rem;
  }

  .btn-main {
    background: white;
    color: var(--color-primary);
    padding: 1rem 2rem;
    border-radius: 1rem;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .btn-outline {
    border: 1px solid rgba(255,255,255,0.3);
    color: white;
    padding: 1rem 2rem;
    border-radius: 1rem;
    font-weight: 700;
    text-decoration: none;
  }

  .hero-visual {
    position: relative;
    height: 300px;
    background: rgba(255,255,255,0.05);
    border-radius: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-leaf {
    position: absolute;
    bottom: 20%;
    right: 20%;
  }

  .market-bar {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 1.5rem 0;
    margin-bottom: 5rem;
  }

  .bar-container {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: 3rem;
    align-items: center;
  }

  .bar-item {
    font-size: 0.9375rem;
  }

  .bar-label {
    color: var(--color-text-light);
    font-weight: 600;
    margin-right: 0.5rem;
  }

  .bar-value {
    color: var(--color-primary);
    font-weight: 700;
  }

  .bar-link {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-accent);
    text-decoration: none;
  }

  .mission-statement {
    text-align: center;
    margin-bottom: 6rem;
  }

  .mission-content h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .mission-content p {
    font-size: 1.25rem;
    color: var(--color-text-light);
    max-width: 700px;
    margin: 0 auto;
  }

  .core-hubs {
    margin-bottom: 8rem;
  }

  .hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .hub-card {
    background: white;
    padding: 2.5rem 2rem;
    border-radius: 2rem;
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: all 0.3s;
    text-align: center;
  }

  .hub-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    border-color: var(--color-primary);
  }

  .hub-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .hub-card h3 {
    margin: 0 0 0.75rem;
    color: var(--color-primary);
  }

  .hub-card p {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-text-light);
  }

  .geo-explorer {
    background: var(--color-surface);
    padding: 6rem 2rem;
    border-radius: 3rem;
    text-align: center;
    border: 1px solid var(--color-border);
  }

  .city-chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin: 2.5rem 0 3.5rem;
  }

  .city-chips a {
    background: var(--color-background);
    color: var(--color-primary);
    padding: 0.75rem 1.5rem;
    border-radius: 2rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .city-chips a:hover {
    background: var(--color-primary);
    color: white;
  }

  @media (max-width: 850px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-btns {
      justify-content: center;
    }
    .hero-visual {
      display: none;
    }
    .bar-container {
      flex-wrap: wrap;
      gap: 1rem;
    }
  }
</style>
