---
import Layout from '../layouts/Layout.astro';
import Callout from '../components/Callout.astro';
---

<Layout title="Maine Dispensary ROI Calculator | Financial Planning Tool" description="Estimate your startup costs, revenue, and time to profitability for a Maine cannabis dispensary based on your starting capital.">
  <section class="calculator-header">
    <h1>Dispensary Profitability Calculator</h1>
    <p class="lead">A data-driven "Reality Check" for Maine cannabis entrepreneurs.</p>
  </section>

  <div class="calc-container">
    <div class="calc-inputs">
      <div class="input-section">
        <h2>1. Initial Investment</h2>
        <div class="input-group">
          <label for="capital">Total Startup Capital:</label>
          <div class="currency-input">
            <span>$</span>
            <input type="number" id="capital" value="300000" step="5000" />
          </div>
          <p class="input-hint">License, build-out, and initial inventory.</p>
        </div>
      </div>

      <div class="input-section">
        <h2>2. Monthly Revenue</h2>
        <div class="input-group">
          <label for="customers">Monthly Customers:</label>
          <input type="range" id="customers" min="100" max="5000" value="1000" class="slider" />
          <div class="slider-value"><span id="customer-count">1000</span> customers</div>
        </div>
        <div class="input-group">
          <label for="avg-sale">Average Sale ($):</label>
          <div class="currency-input small">
            <span>$</span>
            <input type="number" id="avg-sale" value="85" step="5" />
          </div>
        </div>
      </div>

      <div class="input-section">
        <h2>3. Monthly Overhead</h2>
        <div class="input-group">
          <label for="expenses">Operating Expenses (OPEX):</label>
          <div class="currency-input small">
            <span>$</span>
            <input type="number" id="expenses" value="25000" step="1000" />
          </div>
          <p class="input-hint">Rent, Payroll, & Utilities.</p>
        </div>
      </div>
    </div>

    <div class="calc-results">
      <div class="result-card primary">
        <span class="result-label">Net Monthly Profit</span>
        <span class="result-value" id="monthly-profit">Calculating...</span>
        <p id="profit-note">Net income after COGS, 280E, and OPEX.</p>
      </div>

      <div class="result-grid">
        <div class="result-card">
          <span class="result-label">Annual Revenue</span>
          <span class="result-value small" id="annual-revenue">...</span>
        </div>
        <div class="result-card">
          <span class="result-label">Break-Even (Months)</span>
          <span class="result-value small" id="breakeven">...</span>
        </div>
      </div>

      <div class="result-footer">
        <div class="mini-stat">
          <span>COGS:</span>
          <strong>65%</strong>
        </div>
        <div class="mini-stat">
          <span>280E Tax Est:</span>
          <strong>21%</strong>
        </div>
      </div>
    </div>
  </div>

  <Callout title="Understanding the Math" type="success">
    This model uses Maine market averages: 65% for Cost of Goods Sold (COGS) and a 21% effective federal tax rate on Gross Profit (280E). Net profit is what remains after paying your staff, rent, and the IRS.
  </Callout>

  <script>
    function calculate() {
      const capital = parseFloat(document.getElementById('capital').value) || 0;
      const customers = parseInt(document.getElementById('customers').value);
      const avgSale = parseFloat(document.getElementById('avg-sale').value) || 0;
      const opex = parseFloat(document.getElementById('expenses').value) || 0;
      
      document.getElementById('customer-count').innerText = customers;

      // 1. Gross Revenue
      const monthlyGrossRev = customers * avgSale;
      const annualRev = monthlyGrossRev * 12;

      // 2. Gross Profit (After 65% COGS)
      const cogs = monthlyGrossRev * 0.65;
      const grossProfit = monthlyGrossRev - cogs;

      // 3. 280E Federal Tax (21% of Gross Profit - conservative estimate)
      const tax280e = grossProfit * 0.21;

      // 4. Net Monthly Profit
      const netMonthlyProfit = grossProfit - tax280e - opex;

      // 5. Break Even
      const monthsToBreakeven = netMonthlyProfit > 0 ? Math.ceil(capital / netMonthlyProfit) : -1;

      // UI Update
      const formatter = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
      
      document.getElementById('monthly-profit').innerText = formatter.format(netMonthlyProfit);
      document.getElementById('annual-revenue').innerText = formatter.format(annualRev);
      
      const breakevenEl = document.getElementById('breakeven');
      if (netMonthlyProfit <= 0) {
        breakevenEl.innerText = "N/A";
        document.getElementById('monthly-profit').style.color = "#ff6b6b";
      } else {
        document.getElementById('monthly-profit').style.color = "white";
        breakevenEl.innerText = monthsToBreakeven > 60 ? "5+ Years" : monthsToBreakeven;
      }
    }

    // Attach listeners and initial call
    document.addEventListener('DOMContentLoaded', () => {
      const inputs = ['capital', 'customers', 'avg-sale', 'expenses'];
      inputs.forEach(id => document.getElementById(id).addEventListener('input', calculate));
      calculate();
    });
    
    // Backup call for Astro hydration
    calculate();
  </script>
</Layout>

<style>
  .calculator-header { text-align: center; margin-bottom: 4rem; }
  .lead { font-size: 1.25rem; color: var(--color-text-light); max-width: 700px; margin: 0 auto; }

  .calc-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-bottom: 6rem;
    background: white;
    padding: 4rem;
    border-radius: 2rem;
    border: 1px solid var(--color-border);
    box-shadow: 0 20px 50px rgba(0,0,0,0.03);
  }

  .input-section {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-background);
  }

  .input-group label { display: block; font-weight: 700; margin-bottom: 0.75rem; font-size: 0.95rem; }

  .currency-input {
    display: flex;
    align-items: center;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    border-bottom: 2px solid var(--color-primary);
  }

  .currency-input.small { font-size: 1.5rem; }

  .currency-input input {
    border: none;
    padding: 0.5rem;
    width: 100%;
    font-weight: 700;
    color: var(--color-primary);
    background: transparent;
  }

  .currency-input input:focus { outline: none; }

  .input-hint { font-size: 0.75rem; color: var(--color-text-light); margin-top: 0.5rem; }

  .slider { width: 100%; height: 6px; background: var(--color-background); border-radius: 3px; appearance: none; outline: none; }
  .slider::-webkit-slider-thumb { appearance: none; width: 20px; height: 20px; background: var(--color-primary); border-radius: 50%; cursor: pointer; }

  .slider-value { margin-top: 0.75rem; font-weight: 700; color: var(--color-primary); font-size: 0.9rem; }

  .calc-results { display: flex; flex-direction: column; gap: 1.5rem; }

  .result-card { background: var(--color-background); padding: 2.5rem; border-radius: 1.5rem; text-align: center; }
  .result-card.primary { background: var(--color-primary); color: white; }

  .result-label { display: block; font-size: 0.75rem; text-transform: uppercase; font-weight: 700; letter-spacing: 0.1em; margin-bottom: 0.75rem; opacity: 0.8; }
  .result-value { display: block; font-family: var(--font-serif); font-size: 3.5rem; font-weight: 700; line-height: 1; }
  .result-value.small { font-size: 2.25rem; }

  .result-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }

  .result-footer {
    display: flex;
    justify-content: space-between;
    padding: 1.5rem;
    background: rgba(13, 78, 80, 0.05);
    border-radius: 1rem;
    font-size: 0.8rem;
  }

  .mini-stat span { color: var(--color-text-light); margin-right: 0.5rem; }

  @media (max-width: 1000px) {
    .calc-container { grid-template-columns: 1fr; padding: 2rem; }
  }
</style>
