---
import Layout from '../layouts/Layout.astro';
import Callout from '../components/Callout.astro';

// Preset data for calculations
const licensingFee = 3000;
const avgTransaction = 85;
const margin = 0.35; // 35% net after COGS and 280E estimates
---

<Layout title="Maine Dispensary ROI Calculator | Financial Planning Tool" description="Estimate your startup costs, revenue, and time to profitability for a Maine cannabis dispensary based on your starting capital.">
  <section class="calculator-header">
    <h1>Dispensary Profitability Calculator</h1>
    <p class="lead">Plan your financial journey based on your available capital and growth goals.</p>
  </section>

  <div class="calc-container">
    <div class="calc-inputs">
      <h2>1. Your Starting Capital</h2>
      <div class="input-group">
        <label for="capital">How much money are you starting with?</label>
        <div class="currency-input">
          <span>$</span>
          <input type="number" id="capital" value="50000" step="1000" />
        </div>
        <p class="input-hint">Try $5,000 for "Lean Bootstrap" or $300,000 for "Full Retail."</p>
      </div>

      <h2>2. Estimated Monthly Customers</h2>
      <div class="input-group">
        <label for="customers">Projected unique customers per month:</label>
        <input type="range" id="customers" min="50" max="2000" value="300" class="slider" />
        <div class="slider-value"><span id="customer-count">300</span> customers</div>
      </div>
    </div>

    <div class="calc-results">
      <div class="result-card primary">
        <span class="result-label">Estimated Monthly Profit</span>
        <span class="result-value" id="monthly-profit">$0</span>
        <p id="profit-note">Based on 35% net margin after 280E.</p>
      </div>

      <div class="result-grid">
        <div class="result-card">
          <span class="result-label">Annual Revenue</span>
          <span class="result-value small" id="annual-revenue">$0</span>
        </div>
        <div class="result-card">
          <span class="result-label">Break-Even Timeline</span>
          <span class="result-value small" id="breakeven">Calculated...</span>
        </div>
      </div>
    </div>
  </div>

  <section class="founder-scenarios">
    <div class="scenario-grid">
      <div class="scenario-box">
        <h3>"I have $5,000 to start..."</h3>
        <p>Starting with $5,000 is a "Lean Bootstrap" strategy. In Maine, this is ideal for a <strong>Registered Caregiver</strong> start. A full Adult-Use storefront requires significantly more for local fees and security, but starting small allows you to build a brand and customer base first.</p>
        <a href="/guides/maine-dispensary-costs/" class="text-link">See full cost breakdown &rarr;</a>
      </div>
      
      <div class="scenario-box highlight">
        <h3>"How do I use a Line of Credit?"</h3>
        <p>To protect yourself personally, you should establish a <strong>Business Line of Credit</strong> under an LLC or Corporation. This separates your personal assets from the business. Because cannabis is federally illegal, you'll need to work with Maine-specific cannabis-friendly credit unions.</p>
        <a href="/guides/maine-cannabis-banking-solutions/" class="text-link">View Banking Partners &rarr;</a>
      </div>
    </div>
  </section>

  <Callout title="A Note on 280E" type="tip">
    Remember that cannabis businesses cannot deduct standard operating expenses from their federal taxes. Our calculator assumes a "Safe" net margin of 35% to account for this high tax burden. Always consult with a Maine cannabis CPA.
  </Callout>

  <script>
    const capitalInput = document.getElementById('capital');
    const customerSlider = document.getElementById('customers');
    const customerDisplay = document.getElementById('customer-count');
    
    const profitDisplay = document.getElementById('monthly-profit');
    const revenueDisplay = document.getElementById('annual-revenue');
    const breakevenDisplay = document.getElementById('breakeven');

    function calculate() {
      const capital = parseFloat(capitalInput.value) || 0;
      const customers = parseInt(customerSlider.value);
      customerDisplay.innerText = customers;

      const avgTicket = 85;
      const margin = 0.35; // 35% after COGS and 280E

      const monthlyRev = customers * avgTicket;
      const monthlyProfit = monthlyRev * margin;
      const annualRev = monthlyRev * 12;
      
      const monthsToBreakeven = monthlyProfit > 0 ? Math.ceil(capital / monthlyProfit) : "N/A";

      profitDisplay.innerText = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(monthlyProfit);
      revenueDisplay.innerText = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(annualRev);
      
      if (typeof monthsToBreakeven === 'number') {
        breakevenDisplay.innerText = monthsToBreakeven > 48 ? "3+ Years" : monthsToBreakeven + " Months";
      } else {
        breakevenDisplay.innerText = "N/A";
      }
    }

    capitalInput.addEventListener('input', calculate);
    customerSlider.addEventListener('input', calculate);
    
    // Initial calc
    calculate();
  </script>
</Layout>

<style>
  .calculator-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .lead {
    font-size: 1.25rem;
    color: var(--color-text-light);
    max-width: 700px;
    margin: 0 auto;
  }

  .calc-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-bottom: 6rem;
    background: white;
    padding: 4rem;
    border-radius: 2rem;
    border: 1px solid var(--color-border);
    box-shadow: 0 20px 50px rgba(0,0,0,0.03);
  }

  .calc-inputs h2 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }

  .input-group {
    margin-bottom: 3rem;
  }

  .input-group label {
    display: block;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .currency-input {
    display: flex;
    align-items: center;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    border-bottom: 2px solid var(--color-border);
  }

  .currency-input input {
    border: none;
    padding: 0.5rem;
    width: 100%;
    font-weight: 700;
    color: var(--color-primary);
    background: transparent;
  }

  .currency-input input:focus { outline: none; }

  .input-hint {
    font-size: 0.8125rem;
    color: var(--color-text-light);
    margin-top: 0.75rem;
  }

  .slider {
    width: 100%;
    height: 8px;
    background: var(--color-background);
    border-radius: 4px;
    appearance: none;
    outline: none;
  }

  .slider::-webkit-slider-thumb {
    appearance: none;
    width: 24px;
    height: 24px;
    background: var(--color-primary);
    border-radius: 50%;
    cursor: pointer;
  }

  .slider-value {
    margin-top: 1rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .calc-results {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .result-card {
    background: var(--color-background);
    padding: 2rem;
    border-radius: 1.5rem;
    text-align: center;
  }

  .result-card.primary {
    background: var(--color-primary);
    color: white;
  }

  .result-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }

  .result-value {
    display: block;
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 700;
  }

  .result-value.small {
    font-size: 2rem;
  }

  .result-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .founder-scenarios {
    margin-bottom: 6rem;
  }

  .scenario-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .scenario-box {
    padding: 3rem;
    background: white;
    border-radius: 2rem;
    border: 1px solid var(--color-border);
  }

  .scenario-box.highlight {
    background: rgba(13, 78, 80, 0.03);
    border-color: var(--color-primary);
  }

  .scenario-box h3 {
    margin-top: 0;
    color: var(--color-primary);
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .text-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .calc-container { grid-template-columns: 1fr; padding: 2rem; }
    .scenario-grid { grid-template-columns: 1fr; }
    .result-value { font-size: 2.5rem; }
  }
</style>
