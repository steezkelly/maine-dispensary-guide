  section { margin-bottom: 2rem; }
  section h2 { margin-top: 0; color: var(--color-primary); font-family: var(--font-serif); }
  section h3 { margin-top: 1.5rem; color: var(--color-primary); font-family: var(--font-serif); }
  table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
