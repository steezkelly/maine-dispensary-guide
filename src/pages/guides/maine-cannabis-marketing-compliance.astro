<Layout 
  title="Maine Cannabis Marketing Compliance | Maine Dispensary Guide" 
  description="Expert guide to cannabis marketing compliance for dispensary entrepreneurs in Maine."
  heroImage="https://images.unsplash.com/photo-1533491414534-19253f53874c?q=80&w=2070&auto=format&fit=crop"
>
  <article>
    <div class="article-header">
      <h1>Maine Cannabis Marketing Compliance</h1>
      <p class="subtitle">Navigating advertising and marketing regulations in Maine</p>
    </div>

