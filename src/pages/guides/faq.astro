---
import Layout from '../../layouts/Layout.astro';
import FaqSchema from '../../components/Faq.astro';

const article = {
  author: "Maine Dispensary Guide Editorial Team",
  publishDate: "2026-04-20",
  modifiedDate: "2026-04-20",
  section: "Resources"
};

const licensingFaqs = [
  {
    question: "How do I get a cannabis dispensary license in Maine?",
    answer: "Apply through the Maine Office of Cannabis Policy (OCP). You need a Conditional License first (30-60 days), then Local Authorization from your town, then Active Licensure after final inspection. Full process: /guides/maine-dispensary-license/"
  },
  {
    question: "How much does a Maine cannabis license cost?",
    answer: "Application fees range from $500 (Tier 1 cultivation) to $5,000 (Tier 4). Annual renewal fees are $1,000-$10,000 depending on tier. See full fee schedule: /guides/maine-dispensary-costs/"
  },
  {
    question: "How long does the Maine licensing process take?",
    answer: "Typically 6-12 months from application to opening. Conditional licensure takes 30-60 days, local authorization 1-3 months, and buildout/inspection 2-4 months."
  },
  {
    question: "What is the IIC/AIC requirement in Maine?",
    answer: "Every officer needs an Authorized Individual Card (AIC). Every employee needs an Individual Identification Card (IIC). Both require background checks through the OCP."
  },
  {
    question: "Can I operate a cannabis business alone in Maine?",
    answer: "Technically yes, but it's not recommended. The OCP and 280E tax rules make solo operation extremely difficult. Most successful operators have a team covering operations, compliance, and business development."
  }
];

const zoningFaqs = [
  {
    question: "Which Maine towns allow cannabis dispensaries?",
    answer: "15 towns have opted in to adult-use retail. Check the complete list: /guides/maine-cannabis-opt-in-tracker/"
  },
  {
    question: "How far from schools can a dispensary be located?",
    answer: "Maine requires a 1,000ft buffer (or town-reduced 300ft) from schools. The OCP measures from your primary entrance to the school's primary entrance — not property line to property line."
  },
  {
    question: "Does medical marijuana authorization mean adult-use is allowed?",
    answer: "No. Many towns allow medical but not adult-use retail. Always check the specific land-use ordinance for 'Retail Storefront' authorization."
  },
  {
    question: "What zoning requirements apply to Maine dispensaries?",
    answer: "Requirements vary by municipality. Common requirements include: distance from schools/churches, parking minimums, signage restrictions, and operating hour limits. See: /guides/maine-cannabis-real-estate/"
  }
];

const taxFaqs = [
  {
    question: "What is IRS 280E and how does it affect Maine dispensaries?",
    answer: "IRS Code 280E prohibits deducting ordinary business expenses (rent, payroll, marketing). You're taxed on Gross Profit, not Net. Strategy: maximize Cost of Goods Sold (COGS) deductions. Full guide: /guides/maine-cannabis-taxation-280e/"
  },
  {
    question: "What taxes do Maine cannabis businesses pay?",
    answer: "Maine has a 10% adult-use cannabis excise tax plus standard state and federal taxes. The 280E federal tax code is the biggest burden. See: /guides/maine-cannabis-taxes-2026/"
  },
  {
    question: "Can Maine cannabis businesses use traditional banks?",
    answer: "Some Maine banks and credit unions serve cannabis operators, but options are limited. Most operators work with specialized cannabis-friendly financial institutions. See: /guides/maine-cannabis-banking-solutions/"
  },
  {
    question: "How much does it cost to open a dispensary in Maine?",
    answer: "Startup costs range from $300K-$500K for a basic retail operation. Cultivation facilities cost $100K-$2M+ depending on tier. Full breakdown: /guides/maine-dispensary-costs/"
  }
];

const operationsFaqs = [
  {
    question: "What POS system should a Maine dispensary use?",
    answer: "Your POS must sync with Metrc in real-time. Popular options include Dutchie, Flowhub, and Blaze. Discrepancies over 1% between physical and digital inventory risk fines. See: /guides/maine-dispensary-pos/"
  },
  {
    question: "What are Maine's cannabis delivery rules?",
    answer: "Maine allows licensed dispensaries to deliver with a separate courier license from the OCP. Drivers need OCP-issued badges, vehicles need GPS tracking. See: /guides/maine-cannabis-delivery-rules/"
  },
  {
    question: "What security requirements apply to Maine dispensaries?",
    answer: "Requirements include: cameras at all entry/exit points, POS areas, vault, and storage. 90-day footage retention. Limited Access Area signage. Vault integrity. See: /guides/maine-dispensary-security/"
  },
  {
    question: "How do I track inventory in a Maine dispensary?",
    answer: "All cannabis products must be tracked through Metrc seed-to-sale system. Weekly physical-to-digital inventory counts are essential for compliance. See: /guides/maine-cannabis-inventory-management/"
  },
  {
    question: "What are Maine's cannabis marketing restrictions?",
    answer: "Maine restricts marketing that targets minors, makes health claims, or uses cartoon characters. All advertising must include age-gating. See: /guides/maine-cannabis-marketing-compliance/"
  }
];

const cityFaqs = [
  {
    question: "Where can I open a dispensary in Portland, Maine?",
    answer: "Portland is Maine's largest cannabis market. Key areas: Congress Street, East Bayside, and the Peninsula. See: /guides/portland-dispensary-guide/"
  },
  {
    question: "Is Bangor a good market for a cannabis dispensary?",
    answer: "Bangor serves eastern Maine with limited competition. Strong medical market transitioning to adult-use. See: /guides/bangor-dispensary-guide/"
  },
  {
    question: "What about Lewiston-Auburn?",
    answer: "L-A is Maine's second-largest metro with growing demand. Franco-American heritage market, lower real estate costs than Portland. See: /guides/lewiston-dispensary-guide/"
  },
  {
    question: "Are there opportunities in smaller Maine towns?",
    answer: "Yes. Brunswick, Biddeford, Sanford, and Scarborough all have opt-in status and underserved markets. See our city guides for details."
  }
];

const allFaqs = [...licensingFaqs, ...zoningFaqs, ...taxFaqs, ...operationsFaqs, ...cityFaqs];
---

<Layout
  title="Maine Cannabis FAQ — Licensing, Zoning, Tax & Operations"
  description="Comprehensive FAQ for Maine cannabis entrepreneurs. Licensing process, 280E tax, zoning rules, security requirements, and city-specific guidance."
  heroImage="/images/heroes/faq.jpg"
  article={article}
>
  <article>
    <div class="article-header">
      <h1>Maine Cannabis FAQ</h1>
      <p class="subtitle">Answers to the most common questions from Maine cannabis entrepreneurs</p>
    </div>

    <section class="faq-intro">
      <p>These answers are drawn from our comprehensive technical guides covering every aspect of opening and operating a cannabis dispensary in Maine. Each answer links to the full guide for deeper detail.</p>
    </section>

    <FaqSchema faqs={allFaqs}>
      <section class="faq-category">
        <h2>Licensing & Application</h2>
        <div class="faq-list">
          {licensingFaqs.map(faq => (
            <details class="faq-item">
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="faq-category">
        <h2>Location & Zoning</h2>
        <div class="faq-list">
          {zoningFaqs.map(faq => (
            <details class="faq-item">
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="faq-category">
        <h2>Tax & Finance</h2>
        <div class="faq-list">
          {taxFaqs.map(faq => (
            <details class="faq-item">
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="faq-category">
        <h2>Operations & Compliance</h2>
        <div class="faq-list">
          {operationsFaqs.map(faq => (
            <details class="faq-item">
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="faq-category">
        <h2>City-Specific Questions</h2>
        <div class="faq-list">
          {cityFaqs.map(faq => (
            <details class="faq-item">
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>
    </FaqSchema>

    <section class="faq-cta">
      <h2>Need More Detail?</h2>
      <p>Each answer above links to a comprehensive guide. Browse our full library of 51+ technical guides covering every aspect of Maine cannabis business.</p>
      <a href="/guides/" class="cta-link">Browse All Guides →</a>
    </section>
  </article>
</Layout>

<style>
  .faq-intro {
    max-width: 700px;
    margin: 0 0 3rem;
    font-size: 1.125rem;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  .faq-category {
    margin-bottom: 3rem;
  }

  .faq-category h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary);
    display: inline-block;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item:hover {
    border-color: var(--color-primary);
  }

  .faq-item summary {
    padding: 1.25rem 1.5rem;
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: background 0.2s;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::before {
    content: "◆";
    color: var(--color-primary);
    font-size: 0.75rem;
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .faq-item[open] summary::before {
    content: "▼";
  }

  .faq-item summary:hover {
    background: rgba(122, 154, 106, 0.05);
  }

  .faq-item p {
    padding: 0 1.5rem 1.25rem 2.5rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin: 0;
  }

  .faq-item p a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .faq-item p a:hover {
    color: var(--color-accent);
  }

  .faq-cta {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-surface);
    border-radius: 2rem;
    border: 1px solid var(--color-border);
    margin-top: 3rem;
  }

  .faq-cta h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .faq-cta p {
    color: var(--color-text-light);
    max-width: 500px;
    margin: 0 auto 1.5rem;
    font-size: 1rem;
  }

  .cta-link {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    padding: 0.875rem 1.75rem;
    border-radius: 2rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .cta-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(6, 26, 27, 0.2);
  }

  [data-theme="dark"] .faq-item {
    background: var(--color-surface);
  }

  [data-theme="dark"] .faq-item summary:hover {
    background: rgba(122, 154, 106, 0.1);
  }

  @media (max-width: 768px) {
    .faq-category h2 {
      font-size: 1.25rem;
    }

    .faq-item summary {
      padding: 1rem 1.25rem;
      font-size: 0.9375rem;
    }

    .faq-item p {
      padding: 0 1.25rem 1rem 2rem;
      font-size: 0.9375rem;
    }
  }
</style>
