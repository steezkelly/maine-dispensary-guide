<Layout 
  title="Maine Dispensary Business Plan" 
  description="Maine cannabis dispensary business plan guide. Investor-ready pitch decks, financial projections, and operational strategy for 2026."
  heroImage="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&q=80&w=1200&h=400"
