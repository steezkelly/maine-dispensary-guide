  <article>
    <div class="article-header">
      <h1>Biddeford Dispensary Guide</h1>
      <p class="subtitle">How to open a cannabis dispensary in Biddeford, Maine</p>
    </div>

    <section class="fact-box">
      <h2>Biddeford at a Glance</h2>
      <table aria-label="Biddeford dispensary requirements and market data">
        <caption>Key requirements and market data for opening a dispensary in Biddeford</caption>
        <thead><tr><th scope="col">Requirement</th><th scope="col">Details</th></tr></thead>
