---
import Layout from '../../layouts/Layout.astro';
import Callout from '../../components/Callout.astro';

const article = { author: "Maine Dispensary Guide Editorial Team", publishDate: "2026-01-15", modifiedDate: "2026-03-28", section: "City Guides" };
export const title = "Sanford Dispensary Guide";
---

<Layout 
  title="Sanford Maine Cannabis Dispensary Guide" 
  description="Complete technical guide to opening a cannabis dispensary in Sanford Dispensary Guide. Includes 2026 market opportunities, strategic locations, local fee structures, and Maine OCP investment requirements."
  heroImage="https://images.unsplash.com/photo-1500916434205-0c77489c6cf7?auto=format&fit=crop&q=80&w=1200&h=400"
  article={article}
>
  <article>
    <div class="article-header">
      <h1>Sanford Dispensary Guide</h1>
      <p class="subtitle">How to open a cannabis dispensary in Sanford, Maine</p>
    </div>

    <section class="fact-box">
      <h2>📋 Sanford at a Glance</h2>
      <table>
        <tbody>
          <tr><td><strong>License Required</strong></td><td>Maine OCP Adult-Use Retail License</td></tr>
          <tr><td><strong>Local Fee</strong></td><td>$2,000-2,500 annually</td></tr>
          <tr><td><strong>School Buffer</strong></td><td>500 ft minimum</td></tr>
          <tr><td><strong>Commercial Rent</strong></td><td>$10-16/sq ft annually</td></tr>
          <tr><td><strong>Current Dispensaries</strong></td><td>2-3 (opportunity)</td></tr>
        </tbody>
      </table>
    </section>

    <section>
      <h2>Why Sanford?</h2>
      <p>Sanford is southern Maine's largest city (21,000 residents) and serves as a regional hub for York County. With lower costs than Portland and minimal competition, Sanford offers genuine first-mover opportunity.</p>
    </section>

    <Callout title="Southern Maine Opportunity" type="passion">
      Sanford is the economic center of York County without the Portland saturation. For entrepreneurs seeking first-mover advantage in southern Maine, Sanford is one of the best remaining opportunities.
    </Callout>

    <section>
      <h2>Market Data</h2>
      <table>
        <thead>
          <tr><th>Factor</th><th>Assessment</th></tr>
        </thead>
        <tbody>
          <tr><td>Population</td><td>21,000+</td></tr>
          <tr><td>York County Access</td><td>200,000+</td></tr>
          <tr><td>Competition</td><td>Low</td></tr>
          <tr><td>Access</td><td>I-95, Route 109</td></tr>
        </tbody>
      </table>
    </section>

    <section>
      <h2>Local X-Factor: York County Hub</h2>
      <p><strong>What sets Sanford apart:</strong> Sanford serves as the retail hub for all of York County (200,000+ residents). Customers from towns without dispensaries travel to Sanford for cannabis.</p>
      <p><strong>Strategic Implication:</strong> First-movers can capture regional customers from Wells, Kennebunk, Acton, and other underserved York County towns.</p>
    </section>

    <section>
      <h2>Best Locations</h2>
      <table>
        <thead>
          <tr><th>Area</th><th>Pros</th><th>Rent/Sq Ft</th></tr>
        </thead>
        <tbody>
          <tr><td><strong>Main Street</strong></td><td>Downtown, regional traffic</td><td>$14-16</td></tr>
          <tr><td><strong>Route 109</strong></td><td>Highway access, new development</td><td>$10-14</td></tr>
          <tr><td><strong>Alfred Road</strong></td><td>Commercial area</td><td>$10-13</td></tr>
        </tbody>
      </table>
    </section>

    <section>
      <h2>Key Takeaways</h2>
      <ul>
        <li><strong>✅ Opportunity:</strong> First-mover in York County hub</li>
        <li><strong>✅ Advantage:</strong> Regional draw from 200K+</li>
        <li><strong>💰 Investment:</strong> $250K-350K (lower costs)</li>
      </ul>
    </section>

    <section class="further-reading">
      <h2>Resources</h2>
      <ul>
        <li><a href="https://www.maine.gov/dafs/ocp/" target="_blank" rel="noopener noreferrer">Maine OCP</a></li>
        <li><a href="/guides/maine-dispensary-license/">License Guide</a></li>
      </ul>
    </section>

    <section class="disclaimer">
      <p><em>Informational only.</em></p>
    </section>
  </article>
</Layout>

<style>
  article { max-width: 720px; margin: 0 auto; }
  .article-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }
  .subtitle { font-size: 1.25rem; color: var(--color-text-light); }
  section { margin-bottom: 2rem; }
  section h2, section h3 { margin-top: 1.5rem; }
  table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
  th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid var(--color-border); }
  th { background: var(--color-background); }
  ul { padding-left: 1.5rem; }
  li { margin-bottom: 0.5rem; }
  .disclaimer { background: #fff3cd; border: 1px solid #ffc107; padding: 1rem; border-radius: 0.5rem; font-size: 0.875rem; }
  .further-reading { background: rgba(88, 129, 87, 0.05); padding: 1.5rem; border-radius: 1rem; margin-top: 3rem; }
  .further-reading h2 { margin-top: 0; }
  .fact-box { background: rgba(88, 129, 87, 0.1); padding: 1.5rem; border-radius: 1rem; border-left: 4px solid var(--color-primary); }
  .fact-box h2 { margin-top: 0; font-size: 1.25rem; }
  .fact-box table { margin: 0; }
</style>