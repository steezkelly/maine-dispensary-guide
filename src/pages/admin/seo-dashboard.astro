---
import Layout from '../../layouts/Layout.astro';

// This is a private page for the founder to track SEO/GEO milestones.
const targetPrompts = [
  "How to open a dispensary in Maine 2026",
  "Maine cannabis license cost",
  "Portland Maine dispensary zoning rules",
  "Dispensary ROI calculator Maine",
  "Maine cannabis excise tax 2026"
];
---

<Layout title="SEO & Intelligence Dashboard | Admin" description="Internal dashboard for tracking GEO citations and search performance.">
  <section class="admin-header">
    <h1>Empire Intelligence Dashboard</h1>
    <p class="lead">Tracking our path to becoming the #1 cited authority in Maine cannabis.</p>
  </section>

  <div class="dashboard-grid">
    <div class="stat-card">
      <h3>GEO Citation Rate</h3>
      <div class="value">Pending Audit</div>
      <p>Goal: 40%+ citation in AI Search</p>
    </div>
    <div class="stat-card">
      <h3>AI Traffic Sources</h3>
      <div class="source-list">
        <span>ChatGPT</span>
        <span>Perplexity</span>
        <span>Gemini</span>
        <span>Claude</span>
      </div>
    </div>
  </div>

  <section class="audit-section">
    <h2>Weekly Prompt Audit</h2>
    <p>Run these prompts in ChatGPT/Perplexity and check if <strong>mainedispensaryguide.com</strong> is cited.</p>
    <div class="prompt-list">
      {targetPrompts.map(prompt => (
        <div class="prompt-item">
          <code>"{prompt}"</code>
          <div class="audit-actions">
            <button class="btn-check">Cited ✅</button>
            <button class="btn-miss">Missed ❌</button>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="technical-seo-status">
    <h2>Technical SEO Checklist</h2>
    <ul class="checklist">
      <li class="done">Google Search Console Verified</li>
      <li class="pending">Bing Webmaster Tools Pending</li>
      <li class="done">Sitemap.xml Auto-Generated</li>
      <li class="done">JSON-LD Structured Data (Article/WebSite)</li>
      <li class="done">Robots.txt Optimized</li>
    </ul>
  </section>
</Layout>

<style>
  .admin-header { margin-bottom: 4rem; border-bottom: 2px solid var(--color-primary); padding-bottom: 2rem; }
  .dashboard-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 4rem; }
  .stat-card { background: white; padding: 2.5rem; border-radius: 2rem; border: 1px solid var(--color-border); text-align: center; }
  .stat-card .value { font-size: 3rem; font-weight: 800; color: var(--color-primary); margin: 1rem 0; }
  
  .source-list { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 1.5rem; }
  .source-list span { background: var(--color-background); padding: 0.5rem 1rem; border-radius: 1rem; font-weight: 700; font-size: 0.8rem; }

  .audit-section { background: var(--color-surface); padding: 4rem; border-radius: 3rem; margin-bottom: 4rem; }
  .prompt-list { margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem; }
  .prompt-item { background: white; padding: 1.5rem; border-radius: 1.5rem; display: flex; justify-content: space-between; align-items: center; border: 1px solid var(--color-border); }
  .prompt-item code { color: var(--color-primary); font-weight: 700; }
  
  .audit-actions { display: flex; gap: 0.5rem; }
  .btn-check, .btn-miss { padding: 0.5rem 1rem; border-radius: 0.75rem; border: 1px solid var(--color-border); cursor: pointer; font-weight: 700; font-size: 0.8rem; }
  .btn-check:hover { background: #dcfce7; border-color: #22c55e; }
  .btn-miss:hover { background: #fee2e2; border-color: #ef4444; }

  .checklist { list-style: none; padding: 0; margin-top: 2rem; }
  .checklist li { padding: 1rem; border-radius: 1rem; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 1rem; font-weight: 600; }
  .checklist li.done { background: #dcfce7; color: #166534; }
  .checklist li.done::before { content: '✓'; }
  .checklist li.pending { background: #fef9c3; color: #854d0e; }
  .checklist li.pending::before { content: '○'; }
</style>
