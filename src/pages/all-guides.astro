---
import Layout from '../layouts/Layout.astro';
import Callout from '../components/Callout.astro';

const categories = [
  {
    name: "Business Essentials",
    icon: "📋",
    guides: [
      { title: "Maine Dispensary License Requirements", href: "/guides/maine-dispensary-license/" },
      { title: "Dispensary Business Plan", href: "/guides/maine-dispensary-business-plan/" },
      { title: "Startup Costs & Investment", href: "/guides/maine-dispensary-costs/" },
      { title: "Maine Cannabis Market Analysis", href: "/guides/maine-cannabis-market/" },
      { title: "Funding & Capital", href: "/guides/maine-cannabis-funding-guide/" },
      { title: "Cannabis Zoning & Real Estate", href: "/guides/maine-cannabis-real-estate/" },
      { title: "Hiring & Staffing", href: "/guides/maine-dispensary-hiring/" }
    ]
  },
  {
    name: "Compliance & Legal",
    icon: "⚖️",
    guides: [
      { title: "Cannabis Regulations in Maine", href: "/guides/maine-cannabis-regulations/" },
      { title: "Cannabis Taxation & 280E", href: "/guides/maine-cannabis-taxation-280e/" },
      { title: "Cannabis Banking Solutions", href: "/guides/maine-cannabis-banking-solutions/" },
      { title: "Employee Licensing (IIC/AIC)", href: "/guides/maine-cannabis-staffing-licensing/" },
      { title: "Marketing Compliance", href: "/guides/maine-cannabis-marketing-compliance/" }
    ]
  },
  {
    name: "Operations & Technology",
    icon: "🔧",
    guides: [
      { title: "Dispensary Security Requirements", href: "/guides/maine-dispensary-security/" },
      { title: "Inventory & Metrc Management", href: "/guides/maine-cannabis-inventory-management/" },
      { title: "POS Systems for Dispensaries", href: "/guides/maine-dispensary-pos/" },
      { title: "Packaging & Labeling", href: "/guides/maine-dispensary-packaging/" },
      { title: "Cannabis Delivery Rules", href: "/guides/maine-cannabis-delivery-rules/" },
      { title: "Cannabis Edibles Compliance", href: "/guides/maine-cannabis-edibles-compliance/" }
    ]
  },
  {
    name: "City & Regional Guides",
    icon: "📍",
    guides: [
      { title: "Portland Dispensary Guide", href: "/guides/portland-dispensary-guide/" },
      { title: "Lewiston Dispensary Guide", href: "/guides/lewiston-dispensary-guide/" },
      { title: "Bangor Dispensary Guide", href: "/guides/bangor-dispensary-guide/" },
      { title: "Augusta Dispensary Guide", href: "/guides/augusta-dispensary-guide/" },
      { title: "South Portland Dispensary Guide", href: "/guides/south-portland-dispensary-guide/" },
      { title: "All City Guides (15 total)", href: "/guides/" }
    ]
  },
  {
    name: "Business Tools",
    icon: "🛠️",
    guides: [
      { title: "ROI Calculator", href: "/roi-calculator/" },
      { title: "Market Statistics", href: "/market-stats/" },
      { title: "Vendor Directory", href: "/resources/" },
      { title: "Technical Glossary", href: "/glossary/" },
      { title: "2026 Launch Checklist", href: "/launch-checklist/" }
    ]
  }
];
---

<Layout 
  title="Maine Cannabis Resource Library" 
  description="Complete index of 44 technical guides for Maine cannabis entrepreneurs. Covering licensing, compliance, operations, real estate, taxation, and municipal zoning."
  heroImage="https://images.unsplash.com/photo-1511497584788-876760111969?auto=format&fit=crop&q=80&w=1200&h=400"
>
  <section class="page-header">
    <div class="hero-badge">44 Expert Guides</div>
    <h1>Maine Cannabis Resource Library</h1>
    <p class="lead">Everything you need to open, operate, and scale a compliant cannabis business in the Pine Tree State.</p>
  </section>

  <section class="library-intro">
    <p>This library covers every phase of the Maine cannabis business lifecycle. From navigating the Maine Office of Cannabis Policy (OCP) application process and securing municipal authorization, to day-to-day operations including Metrc inventory tracking, compliance reporting, and staff management. Each guide is written for Maine-specific conditions — federal 280E tax implications, state licensing tiers, and local opt-in requirements vary town by town.</p>
    <p>City guides provide granular market analysis for 15 Maine municipalities, from Portland's competitive landscape to Bangor's underserved northern opportunity. Technical guides address specific operational challenges including POS system selection, cannabis-specific banking solutions, edibles manufacturing compliance, and delivery logistics.</p>
  </section>

  <div class="category-grid">
    {categories.map(cat => (
      <div class="category-card">
        <div class="cat-header">
          <span class="cat-icon">{cat.icon}</span>
          <h2>{cat.name}</h2>
        </div>
        <ul class="guide-list">
          {cat.guides.map(g => (
            <li><a href={g.href}>{g.title}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <Callout title="Start with the Launch Checklist" type="info">
    New to Maine cannabis? Begin with our <a href="/launch-checklist/">2026 Launch Checklist</a> — a step-by-step roadmap from entity formation to your first day of sales.
  </Callout>
</Layout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 5rem;
    padding-top: 2rem;
  }

  .hero-badge {
    display: inline-block;
    background: var(--color-primary);
    color: var(--color-background);
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .page-header h1 {
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.25rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto;
  }

  .library-intro {
    max-width: 720px;
    margin: 0 auto 4rem;
    padding: 2rem;
    background: rgba(88, 129, 87, 0.05);
    border-radius: 1.5rem;
    border-left: 4px solid var(--color-primary);
  }

  .library-intro p {
    margin-bottom: 1.5rem;
    line-height: 1.7;
    font-size: 1.05rem;
  }

  .library-intro p:last-child {
    margin-bottom: 0;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 5rem;
  }

  .category-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    padding: 2rem;
    transition: all 0.2s;
  }

  .category-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 8px 24px rgba(13, 78, 80, 0.08);
  }

  .cat-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .cat-icon {
    font-size: 1.75rem;
  }

  .cat-header h2 {
    margin: 0;
    font-size: 1.25rem;
    color: var(--color-primary);
  }

  .guide-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .guide-list li {
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }

  .guide-list li:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .guide-list a {
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .guide-list a:hover {
    color: var(--color-accent);
  }
</style>
