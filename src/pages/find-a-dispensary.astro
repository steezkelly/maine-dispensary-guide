---
import Layout from '../layouts/Layout.astro';
import Callout from '../components/Callout.astro';

const cities = [
  {
    name: "Portland",
    stores: [
      { name: "Theory Wellness", address: "10 Gannett Dr", rating: "4.8", highlight: "Premium Craft Selection" },
      { name: "Seaweed Co.", address: "185 Museum Way", rating: "4.7", highlight: "Unique Design & Experience" },
      { name: "Higher Grounds", address: "45 Wharf St", rating: "4.9", highlight: "Coffee & Cannabis Hub" }
    ]
  },
  {
    name: "Augusta",
    stores: [
      { name: "The Healing House", address: "264 Water St", rating: "4.7", highlight: "Capital City Authority" },
      { name: "Canuvo", address: "282 Western Ave", rating: "4.6", highlight: "Patient-Focused Roots" },
      { name: "Sweet Relief", address: "103 Water St", rating: "4.8", highlight: "Friendly Local Service" }
    ]
  },
  {
    name: "Bangor",
    stores: [
      { name: "HighLife Farms", address: "1018 Stillwater Ave", rating: "4.9", highlight: "Quality & Consistency" },
      { name: "The Grass Company", address: "50 Main St", rating: "4.7", highlight: "Community Staple" },
      { name: "Sweet Relief", address: "1476 Hammond St", rating: "4.8", highlight: "Expert Knowledge" }
    ]
  }
];
---

<Layout 
  title="Maine Dispensary Directory" 
  description="Curated directory of the highest-rated adult-use and medical cannabis dispensaries in Maine, sorted by city and verified for quality."
  heroImage="https://images.unsplash.com/photo-1603912627214-9011de557cdd?auto=format&fit=crop&q=80&w=1200&h=400"
>
  <section class="directory-header">
    <div class="hero-badge">Curated by Experts</div>
    <h1>Maine Dispensary Directory</h1>
    <p class="lead">We've audited the local market to find the most professional, high-quality cannabis storefronts in the state. This directory is updated quarterly and verified against Maine OCP public licensee records.</p>
  </section>

  <section class="market-overview">
    <h2>Maine's Dispensary Landscape</h2>
    <p>Maine's adult-use market has matured significantly since retaillaunch in 2020. With 179 active stores as of early 2026, the market generates over $246 million in annual sales. Stores are distributed across the state, with the highest concentration in York and Cumberland counties, but rural operators in Aroostook, Washington, and Piscataquis counties report less competition and strong tourist traffic during peak seasons.</p>
    <p>Our directory highlights stores that maintain professional standards: compliant packaging, knowledgeable staff, clean facility environments, and accurate inventory. We exclude any establishment with active OCP compliance actions on record.</p>
  </section>

  <div class="city-directory">
    {cities.map(city => (
      <div class="city-section">
        <div class="city-title-row">
          <h2>{city.name}</h2>
          <a href={`/guides/${city.name.toLowerCase()}-dispensary-guide/`} class="guide-link">View {city.name} Guide &rarr;</a>
        </div>
        <div class="store-grid">
          {city.stores.map(store => (
            <div class="store-card">
              <div class="store-rating">★ {store.rating}</div>
              <h3>{store.name}</h3>
              <p class="store-highlight">{store.highlight}</p>
              <p class="store-address">{store.address}</p>
              <div class="store-actions">
                <a href="#" class="btn-map">Directions</a>
                <a href="#" class="btn-menu">Menu</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <Callout title="Are you a Store Owner?" type="tip">
    Want your shop to be featured at the top of your city? We offer **Verified Listings** for professional Maine dispensaries. <a href="/about/">Contact our team</a> to learn more about our audit process.
  </Callout>
</Layout>

<style>
  .directory-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .hero-badge {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .lead {
    font-size: 1.25rem;
    color: var(--color-text-light);
    max-width: 700px;
    margin: 0 auto;
  }

  .market-overview {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    padding: 3rem;
    margin-bottom: 6rem;
  }

  .market-overview h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    color: var(--color-primary);
    margin-top: 0;
    margin-bottom: 1.5rem;
  }

  .market-overview p {
    font-size: 1.0rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .market-overview p:last-child { margin-bottom: 0; }

  .city-directory {
    display: flex;
    flex-direction: column;
    gap: 6rem;
    margin-bottom: 8rem;
  }

  .city-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2.5rem;
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 1rem;
  }

  .city-title-row h2 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 2.5rem;
    color: var(--color-primary);
  }

  .guide-link {
    font-weight: 700;
    text-decoration: none;
    color: var(--color-accent);
  }

  .store-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .store-card {
    background: white;
    padding: 2.5rem;
    border-radius: 2rem;
    border: 1px solid var(--color-border);
    box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    position: relative;
    transition: all 0.3s;
  }

  .store-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-primary);
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
  }

  .store-rating {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: rgba(88, 129, 87, 0.1);
    color: var(--color-accent);
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-weight: 800;
    font-size: 0.8rem;
  }

  .store-card h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-family: var(--font-serif);
    color: var(--color-primary);
  }

  .store-highlight {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-accent);
    margin-bottom: 1rem !important;
  }

  .store-address {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 2rem !important;
  }

  .store-actions {
    display: flex;
    gap: 1rem;
  }

  .btn-map, .btn-menu {
    flex: 1;
    text-align: center;
    padding: 0.75rem;
    border-radius: 0.75rem;
    font-weight: 700;
    text-decoration: none;
    font-size: 0.85rem;
  }

  .btn-map {
    background: var(--color-background);
    color: var(--color-primary);
  }

  .btn-menu {
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
  }

  @media (max-width: 600px) {
    .city-title-row { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .store-card { padding: 1.5rem; }
  }
</style>
