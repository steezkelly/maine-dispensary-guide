---
import Layout from '../layouts/Layout.astro';
import Callout from '../components/Callout.astro';
import PineTree from '../components/PineTree.astro';
---

<Layout title="Download: 2026 Maine Dispensary Checklist | Founders Resource">
  <section class="squeeze-hero">
    <div class="hero-container">
      <div class="hero-text">
        <div class="hero-badge">Free Founder Resource</div>
        <h1>Get the Definitive 2026 Maine Dispensary Launch Checklist</h1>
        <p class="lead">Don't miss a single OCP requirement. Download the step-by-step roadmap used by Maine's most successful cannabis entrepreneurs.</p>
        
        <div class="benefit-list">
          <div class="benefit-item">✅ Complete Phase-by-Phase Licensing Map</div>
          <div class="benefit-item">✅ 280E Tax Prep Checklist for Accountants</div>
          <div class="benefit-item">✅ OCP-Compliant Security Vendor List</div>
          <div class="benefit-item">✅ Real Estate Zoning 'Opt-In' Quick Reference</div>
        </div>

        <form class="lead-form">
          <input type="email" placeholder="Enter your business email" required />
          <button type="submit" class="btn-main">Get the PDF Checklist &rarr;</button>
          <p class="form-note">Join 500+ Maine cannabis founders. No spam, just high-value updates.</p>
        </form>
      </div>
      <div class="hero-visual">
        <div class="checklist-preview">
          <div class="doc-header">
            <PineTree size={32} color="var(--color-primary)" />
            <span>2026 ROADMAP</span>
          </div>
          <div class="doc-line"></div>
          <div class="doc-line short"></div>
          <div class="doc-line"></div>
          <div class="doc-check"></div>
          <div class="doc-check"></div>
          <div class="doc-check pending"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="trust-section">
    <p>Trusted by professionals across the state of Maine.</p>
  </section>
</Layout>

<style>
  .squeeze-hero {
    background: white;
    padding: 6rem 0 8rem;
    border-radius: 3rem;
    border: 1px solid var(--color-border);
    margin-top: 2rem;
  }

  .hero-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    background: var(--color-soft-green);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .hero-text h1 {
    font-size: 3rem;
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .benefit-list {
    margin: 2.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .benefit-item {
    font-weight: 600;
    color: var(--color-text);
    font-size: 1.125rem;
  }

  .lead-form {
    background: var(--color-background);
    padding: 2.5rem;
    border-radius: 2rem;
    border: 1px solid var(--color-border);
    margin-top: 3rem;
  }

  .lead-form input {
    width: 100%;
    padding: 1rem 1.5rem;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    font-size: 1rem;
    margin-bottom: 1rem;
  }

  .btn-main {
    width: 100%;
    background: var(--color-primary);
    color: white;
    padding: 1rem;
    border-radius: 1rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    font-size: 1.125rem;
    transition: transform 0.1s;
  }

  .btn-main:active { transform: scale(0.98); }

  .form-note {
    font-size: 0.75rem;
    color: var(--color-text-light);
    margin-top: 1rem;
    text-align: center;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
  }

  .checklist-preview {
    width: 300px;
    height: 400px;
    background: white;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    box-shadow: 0 30px 60px rgba(0,0,0,0.1);
    padding: 2rem;
    transform: rotate(3deg);
  }

  .doc-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    font-weight: 800;
    font-size: 0.75rem;
    color: var(--color-primary);
  }

  .doc-line {
    height: 8px;
    background: #f0f0f0;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .doc-line.short { width: 60%; }

  .doc-check {
    width: 20px;
    height: 20px;
    background: var(--color-soft-green);
    border-radius: 4px;
    margin-top: 1.5rem;
    position: relative;
  }

  .doc-check::after {
    content: 'L';
    color: white;
    font-size: 12px;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(45deg) scaleX(-1);
  }

  .doc-check.pending {
    background: #f0f0f0;
  }

  .doc-check.pending::after { display: none; }

  .trust-section {
    text-align: center;
    margin-top: 4rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 850px) {
    .hero-container { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
  }
</style>
