---
import Layout from '../layouts/Layout.astro';
import Callout from '../components/Callout.astro';
import PineTree from '../components/PineTree.astro';

const roadmapFeatures = [
  { 
    title: "The 4-Phase State Map", 
    desc: "A detailed timeline from entity formation to final OCP inspection.",
    icon: "🗺️"
  },
  { 
    title: "Financial Integrity Prep", 
    desc: "Exactly what Maine banks and credit unions look for in a founder.",
    icon: "💰"
  },
  { 
    title: "Security Master List", 
    desc: "Standard OCP-compliant hardware and surveillance protocols.",
    icon: "🛡️"
  },
  { 
    title: "280E Tax Strategy", 
    desc: "How to maximize COGS deductions and manage high tax burdens.",
    icon: "⚖️"
  }
];
---

<Layout title="Download the 2026 Maine Dispensary Roadmap | Founders Edition">
  <section class="download-hero">
    <div class="hero-container">
      <div class="hero-text">
        <div class="hero-badge">Verified Founder Asset</div>
        <h1>Your Professional Roadmap to the Maine Market</h1>
        <p class="lead">Stop guessing at regulations. Download the definitive, 40-page founder's guide to launching and scaling a Maine cannabis dispensary.</p>
        
        <form class="lead-capture-form" action="https://formspree.io/f/xvgzlowz" method="POST">
          <div class="input-stack">
            <input type="email" placeholder="Business Email Address" required />
            <button type="submit" class="btn-primary">Send Me the Roadmap &rarr;</button>
          </div>
          <p class="form-disclaimer">Join 500+ Maine entrepreneurs. 100% Privacy. Zero Spam.</p>
        </form>
      </div>
      
      <div class="hero-visual">
        <div class="document-preview">
          <div class="preview-badge">PDF</div>
          <div class="preview-content">
            <div class="preview-logo">
              <PineTree size={40} color="var(--color-primary)" />
            </div>
            <div class="preview-title">2026 ROADMAP</div>
            <div class="preview-lines">
              <div class="line"></div>
              <div class="line short"></div>
              <div class="line"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="feature-overview">
    <h2>What's inside the guide?</h2>
    <div class="feature-grid">
      {roadmapFeatures.map(feature => (
        <div class="feature-card">
          <span class="feature-icon">{feature.icon}</span>
          <h3>{feature.title}</h3>
          <p>{feature.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="trust-footer">
    <p>Authored by industry experts. Updated for 2026 Maine OCP Statutes.</p>
  </section>
</Layout>

<style>
  .download-hero {
    background: white;
    padding: 6rem 0;
    border-radius: 3rem;
    border: 1px solid var(--color-border);
    margin-top: 2rem;
    margin-bottom: 6rem;
  }

  .hero-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .hero-text h1 {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }

  .lead {
    font-size: 1.25rem;
    color: var(--color-text-light);
    margin-bottom: 3rem;
  }

  .input-stack {
    display: flex;
    gap: 1rem;
    background: var(--color-background);
    padding: 0.75rem;
    border-radius: 1.5rem;
    border: 1px solid var(--color-border);
  }

  .input-stack input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 0.5rem 1rem;
    font-size: 1rem;
    font-weight: 600;
  }

  .input-stack input:focus { outline: none; }

  .btn-primary {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.1s;
  }

  .btn-primary:active { transform: scale(0.98); }

  .form-disclaimer {
    font-size: 0.75rem;
    color: var(--color-text-light);
    margin-top: 1rem;
    padding-left: 1rem;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
  }

  .document-preview {
    width: 320px;
    height: 440px;
    background: white;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    position: relative;
    box-shadow: 0 40px 80px rgba(0,0,0,0.1);
    padding: 3rem;
    transform: rotate(2deg);
  }

  .preview-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: #ef4444;
    color: white;
    font-size: 0.7rem;
    font-weight: 900;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }

  .preview-logo { margin-bottom: 2rem; }
  .preview-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 2rem;
  }

  .preview-lines .line {
    height: 6px;
    background: #f0f0f0;
    border-radius: 3px;
    margin-bottom: 1rem;
  }
  .preview-lines .line.short { width: 60%; }

  .feature-overview {
    margin-bottom: 8rem;
    text-align: center;
  }

  .feature-overview h2 {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    margin-bottom: 4rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    background: var(--color-surface);
    padding: 3rem 2rem;
    border-radius: 2rem;
    border: 1px solid var(--color-border);
    transition: all 0.3s;
  }

  .feature-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-5px);
  }

  .feature-icon { font-size: 2.5rem; display: block; margin-bottom: 1.5rem; }
  .feature-card h3 { font-size: 1.25rem; margin-bottom: 1rem; color: var(--color-primary); }
  .feature-card p { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.6; }

  .trust-footer {
    text-align: center;
    border-top: 1px solid var(--color-border);
    padding-top: 4rem;
    color: var(--color-text-light);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 900px) {
    .hero-container { grid-template-columns: 1fr; text-align: center; }
    .hero-visual { display: none; }
    .input-stack { flex-direction: column; padding: 1.5rem; gap: 1.5rem; border-radius: 2rem; }
    .input-stack input { text-align: center; }
  }
</style>
