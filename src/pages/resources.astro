---
import Layout from '../layouts/Layout.astro';
import Callout from '../components/Callout.astro';

const vendors = [
  {
    category: "Legal & Compliance",
    providers: [
      { id: "legal-1", name: "Tammie Snow, Esq.", specialty: "Maine Cannabis Law & Licensing", link: "https://mainemarijuanaattorney.com/" },
      { id: "legal-2", name: "Bernstein Shur", specialty: "Regulatory Policy & Business Law", link: "https://www.bernsteinshur.com/service/cannabis/" },
      { id: "legal-3", name: "Caseiro Burke LLC", specialty: "IP & Cannabis IP Protection", link: "https://www.caseiroburke.com/" }
    ]
  },
  {
    category: "Accounting & Tax (280E)",
    providers: [
      { id: "tax-1", name: "BerryDunn", specialty: "Cannabis Industry Consulting & Tax", link: "https://www.berrydunn.com/" },
      { id: "tax-2", name: "Macpage LLC", specialty: "Specialized Cannabis Audit & Assurance", link: "https://www.macpage.com/" }
    ]
  }
];
---

<Layout 
  title="Professional Vendor Directory | Maine Dispensary Guide" 
  description="Connect with verified Maine cannabis lawyers, accountants, and security professionals. Request direct introductions to industry experts."
  heroImage="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&q=80&w=1200&h=400"
>
  <section class="directory-header">
    <div class="hero-badge">Verified Expert Network</div>
    <h1>Professional Vendor Directory</h1>
    <p class="lead">We've curated the leading Maine-based professionals who specialize in the cannabis industry. Use the form below to request a direct introduction.</p>
  </section>

  <div class="vendor-grid">
    {vendors.map(group => (
      <div class="vendor-category">
        <h2>{group.category}</h2>
        <div class="provider-list">
          {group.providers.map(provider => (
            <div class="provider-card">
              <div class="card-body">
                <h3>{provider.name}</h3>
                <p class="specialty">{provider.specialty}</p>
                <div class="card-actions">
                  <a href={provider.link} target="_blank" class="btn-outline-small">View Site</a>
                  <button class="btn-intro" data-vendor={provider.name}>Request Intro</button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <section id="intro-form" class="intro-form-section">
    <div class="form-container">
      <h2>Request a Professional Introduction</h2>
      <p>Tell us which service you need, and we will connect you with our preferred partners.</p>
      
      <form class="lead-form">
        <div class="form-row">
          <input type="text" placeholder="Full Name" required />
          <input type="email" placeholder="Business Email" required />
        </div>
        <select required>
          <option value="">Select Service Needed...</option>
          <option value="legal">Legal & Licensing</option>
          <option value="tax">Tax & 280E Accounting</option>
          <option value="security">Security & Surveillance</option>
          <option value="real-estate">Real Estate / Zoning</option>
        </select>
        <textarea placeholder="Briefly describe your project goals..."></textarea>
        <button type="submit" class="btn-main">Submit Request &rarr;</button>
      </form>
    </div>
  </section>
</Layout>

<style>
  .directory-header { text-align: center; margin-bottom: 4rem; }
  .hero-badge { display: inline-block; background: var(--color-primary); color: white; padding: 0.5rem 1rem; border-radius: 2rem; font-size: 0.75rem; font-weight: 700; margin-bottom: 1.5rem; }
  .lead { font-size: 1.25rem; color: var(--color-text-light); max-width: 800px; margin: 0 auto; }

  .vendor-grid { display: flex; flex-direction: column; gap: 4rem; margin-bottom: 6rem; }
  .vendor-category h2 { border-bottom: 2px solid var(--color-primary); display: inline-block; padding-bottom: 0.5rem; margin-bottom: 2rem; font-family: var(--font-serif); }

  .provider-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
  .provider-card { background: white; border-radius: 1.5rem; border: 1px solid var(--color-border); overflow: hidden; transition: all 0.3s; }
  .provider-card:hover { transform: translateY(-5px); border-color: var(--color-primary); box-shadow: 0 20px 40px rgba(0,0,0,0.05); }
  
  .card-body { padding: 2rem; }
  .provider-card h3 { margin: 0 0 0.5rem; color: var(--color-primary); font-family: var(--font-serif); }
  .specialty { font-size: 0.875rem; color: var(--color-text-light); margin-bottom: 2rem !important; min-height: 3rem; }

  .card-actions { display: flex; gap: 1rem; }
  .btn-outline-small { flex: 1; text-align: center; border: 1px solid var(--color-border); padding: 0.5rem; border-radius: 0.75rem; font-size: 0.8rem; font-weight: 700; text-decoration: none; color: var(--color-text); }
  .btn-intro { flex: 1; background: var(--color-background); border: none; padding: 0.5rem; border-radius: 0.75rem; font-size: 0.8rem; font-weight: 700; color: var(--color-primary); cursor: pointer; }

  .intro-form-section { background: var(--color-primary); color: white; padding: 6rem 2rem; border-radius: 3rem; }
  .form-container { max-width: 700px; margin: 0 auto; text-align: center; }
  .form-container h2 { color: white; margin-top: 0; font-family: var(--font-serif); font-size: 2.5rem; }
  
  .lead-form { margin-top: 3rem; display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  input, select, textarea { padding: 1rem 1.5rem; border-radius: 1rem; border: none; font-size: 1rem; }
  textarea { height: 120px; resize: none; }
  .btn-main { background: white; color: var(--color-primary); padding: 1.25rem; border-radius: 1rem; font-weight: 800; border: none; cursor: pointer; margin-top: 1rem; }

  @media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
</style>
