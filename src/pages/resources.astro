---
import Layout from '../layouts/Layout.astro';
import Callout from '../components/Callout.astro';

const vendorCategories = [
  {
    name: "Legal & Licensing",
    description: "Expert cannabis attorneys to guide your state and local applications.",
    vendors: [
      { name: "Tammie Snow, Esq.", specialty: "Licensing & Regulatory", location: "Portland" },
      { name: "Bernstein Shur", specialty: "Corporate & Zoning", location: "Portland/Augusta" }
    ]
  },
  {
    name: "Accounting & 280E Tax",
    description: "CPAs specializing in IRC 280E compliance and dispensary bookkeeping.",
    vendors: [
      { name: "BerryDunn", specialty: "Tax & Audit", location: "Portland" },
      { name: "Macpage", specialty: "Financial Strategy", location: "South Portland" }
    ]
  }
];
---

<Layout title="Professional Vendor Directory | Maine Dispensary Guide" description="Connect with verified Maine cannabis lawyers, accountants, and consultants. Request a professional introduction to start your project.">
  
  <!-- THEATER OVERLAY (Local to this page for stability) -->
  <div id="local-theater-overlay" class="theater-overlay"></div>

  <section class="resources-header">
    <div class="hero-badge">Verified Expert Network</div>
    <h1>Professional Vendor Directory</h1>
    <p class="lead">Building a dispensary requires an elite team. We've vetted the leading professionals in the Maine market to help you launch with confidence.</p>
  </section>

  <div class="directory-container">
    <div class="vendor-list">
      {vendorCategories.map(category => (
        <div class="category-block">
          <h2>{category.name}</h2>
          <p class="cat-desc">{category.description}</p>
          <div class="vendor-grid">
            {category.vendors.map(vendor => (
              <div class="vendor-card">
                <h3>{vendor.name}</h3>
                <p><strong>Specialty:</strong> {vendor.specialty}</p>
                <p><strong>Location:</strong> {vendor.location}</p>
                <button class="btn-referral" data-vendor={vendor.name}>Request Intro &rarr;</button>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <aside class="referral-sidebar">
      <div id="referral-form-box" class="referral-box">
        <button id="close-theater" class="btn-close-theater" type="button">&times;</button>
        <h3>Need a Referral?</h3>
        <p>Tell us about your project, and we will connect you with the right professional for your specific needs.</p>
        <form class="referral-form" action="https://formspree.io/f/xvgzlowz" method="POST">
          <input type="text" name="name" placeholder="Full Name" required />
          <input type="email" name="email" placeholder="Business Email" required />
          <input type="hidden" id="target-vendor" name="requested_professional" value="General Referral" />
          <select name="service" id="service-select" required>
            <option value="">Select Service Needed...</option>
            <option value="legal">Legal & Licensing</option>
            <option value="accounting">Tax & 280E</option>
            <option value="security">Security & Hardware</option>
            <option value="real-estate">Real Estate / Zoning</option>
          </select>
          <textarea name="message" id="message-box" placeholder="Briefly describe your goals..."></textarea>
          <button type="submit" class="btn-main">Request Introduction</button>
        </form>
        <p class="form-disclaimer">By submitting, you agree to share your info with our vetted partners.</p>
      </div>
    </aside>
  </div>

  <Callout title="Are you a Maine Professional?" type="passion">
    Want to be featured in our directory? We are looking for high-authority lawyers, accountants, and security firms. <a href="mailto:admin@mainedispensaryguide.com">Contact our partnership team</a>.
  </Callout>

  <script is:inline>
    console.log("Theater Mode Logic Initialized");
    const referralButtons = document.querySelectorAll('.btn-referral');
    const closeButton = document.getElementById('close-theater');
    const overlay = document.getElementById('local-theater-overlay');
    const vendorInput = document.getElementById('target-vendor');
    const messageBox = document.getElementById('message-box');

    const openTheater = (vendorName) => {
      if (vendorInput) vendorInput.value = vendorName;
      if (messageBox) messageBox.placeholder = `I would like an introduction to ${vendorName}...`;
      document.body.classList.add('theater-active');
    };

    const closeTheater = () => {
      document.body.classList.remove('theater-active');
    };

    referralButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        openTheater(btn.getAttribute('data-vendor'));
      });
    });

    if (closeButton) closeButton.addEventListener('click', closeTheater);
    if (overlay) overlay.addEventListener('click', closeTheater);
  </script>
</Layout>

<style>
  /* Immersive Theater Overlay */
  .theater-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(5, 26, 27, 0.85);
    backdrop-filter: blur(8px);
    z-index: 1500;
    opacity: 0;
    pointer-events: none;
    transition: all 0.4s ease;
  }

  :global(body.theater-active) .theater-overlay {
    opacity: 1;
    pointer-events: auto;
  }

  /* Referral Box & Interactive States */
  .referral-box {
    background: white;
    padding: 2.5rem;
    border-radius: 2.5rem;
    border: 2px solid var(--color-primary);
    position: sticky;
    top: 120px;
    z-index: 100;
    transition: all 0.5s cubic-bezier(0.2, 1, 0.2, 1);
  }

  :global(body.theater-active) .referral-box {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1.05);
    z-index: 2000;
    width: 90%;
    max-width: 500px;
    box-shadow: 0 40px 100px rgba(0,0,0,0.5);
  }

  .btn-close-theater {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: var(--color-background);
    color: var(--color-primary);
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    font-size: 1.5rem;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 2001;
  }

  :global(body.theater-active) .btn-close-theater { display: flex; }

  /* Standard Page Styles */
  .resources-header { text-align: center; margin-bottom: 4rem; }
  .lead { max-width: 800px; margin: 0 auto; font-size: 1.25rem; color: var(--color-text-light); }

  .directory-container {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 4rem;
    margin-bottom: 6rem;
  }

  .category-block { margin-bottom: 4rem; }
  .category-block h2 { border-bottom: 2px solid var(--color-primary); padding-bottom: 0.5rem; margin-bottom: 1rem; }
  .cat-desc { margin-bottom: 2rem; color: var(--color-text-light); }

  .vendor-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .vendor-card { background: white; padding: 2rem; border-radius: 1.5rem; border: 1px solid var(--color-border); }
  .vendor-card h3 { margin-top: 0; color: var(--color-primary); }
  
  .btn-referral {
    margin-top: 1.5rem;
    background: var(--color-background);
    color: var(--color-primary);
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 1rem;
    font-weight: 700;
    cursor: pointer;
    width: 100%;
    transition: all 0.2s;
  }

  .btn-referral:hover { background: var(--color-primary); color: white; }

  .referral-form { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem; }
  .referral-form input, .referral-form select, .referral-form textarea {
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    font-family: inherit;
  }
  .referral-form textarea { height: 100px; resize: none; }
  .form-disclaimer { font-size: 0.7rem; color: var(--color-text-light); margin-top: 1rem; text-align: center; }

  @media (max-width: 1000px) {
    .directory-container { grid-template-columns: 1fr; }
    .referral-sidebar { order: -1; }
  }
</style>
