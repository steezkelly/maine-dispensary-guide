---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resources | Maine Dispensary Guide" description="Helpful resources, tools, and templates for Maine cannabis dispensary owners.">
  <section class="page-header">
    <h1>Resources</h1>
    <p>Tools, templates, and helpful links for opening and operating your Maine dispensary.</p>
  </section>
  
  <section>
    <h2>Official Resources</h2>
    <ul class="resource-list">
      <li>
        <a href="https://www.maine.gov/dafs/ocp" target="_blank" rel="noopener">Maine Office of Cannabis Policy</a>
        <p>Official state licensing authority for cannabis businesses in Maine.</p>
      </li>
      <li>
        <a href="https://www.maine.gov/dafs/ocp/licenses" target="_blank" rel="noopener">License Applications</a>
        <p>Apply for or renew your Maine cannabis business license.</p>
      </li>
      <li>
        <a href="https://www.maine.gov/dafs/ocp/rules" target="_blank" rel="noopener">Cannabis Rules & Regulations</a>
        <p>Complete rules governing Maine's cannabis industry.</p>
      </li>
    </ul>
  </section>
  
  <section>
    <h2>Business Resources</h2>
    <ul class="resource-list">
      <li>
        <a href="#">Dispensary Business Plan Template</a>
        <p>Comprehensive business plan template designed for Maine dispensaries.</p>
      </li>
      <li>
        <a href="#">Financial Projections Calculator</a>
        <p>Estimate your startup costs and revenue projections.</p>
      </li>
      <li>
        <a href="#">Compliance Checklist</a>
        <p>Pre-opening checklist to ensure regulatory compliance.</p>
      </li>
    </ul>
  </section>
  
  <section>
    <h2>Industry Tools</h2>
    <ul class="resource-list">
      <li>
        <a href="#">POS System Comparisons</a>
        <p>Compare top POS systems designed for cannabis dispensaries.</p>
      </li>
      <li>
        <a href="#">Seed-to-Sale Tracking</a>
        <p>Information on mandatory inventory tracking systems.</p>
      </li>
      <li>
        <a href="#">Security Vendors</a>
        <p>Approved security system providers for Maine dispensaries.</p>
      </li>
    </ul>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: 3rem;
    text-align: center;
  }
  
  .page-header p {
    font-size: 1.125rem;
    color: var(--color-text-light);
  }
  
  section {
    margin-bottom: 3rem;
  }
  
  section h2 {
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  .resource-list {
    list-style: none;
    padding: 0;
  }
  
  .resource-list li {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  
  .resource-list a {
    font-weight: 600;
    font-size: 1.0625rem;
  }
  
  .resource-list p {
    color: var(--color-text-light);
    margin-bottom: 0;
    margin-top: 0.25rem;
  }
</style>
