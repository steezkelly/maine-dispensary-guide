---
import Layout from '../layouts/Layout.astro';
import Callout from '../components/Callout.astro';

const vendorCategories = [
  {
    name: "Legal & Licensing",
    description: "Expert cannabis attorneys to guide your state and local applications.",
    vendors: [
      { name: "Tammie Snow, Esq.", specialty: "Licensing & Regulatory", location: "Portland" },
      { name: "Bernstein Shur", specialty: "Corporate & Zoning", location: "Portland/Augusta" }
    ]
  },
  {
    name: "Accounting & 280E Tax",
    description: "CPAs specializing in IRC 280E compliance and dispensary bookkeeping.",
    vendors: [
      { name: "BerryDunn", specialty: "Tax & Audit", location: "Portland" },
      { name: "Macpage", specialty: "Financial Strategy", location: "South Portland" }
    ]
  }
];
---

<Layout title="Professional Vendor Directory | Maine Dispensary Guide" description="Connect with verified Maine cannabis lawyers, accountants, and consultants. Request a professional introduction to start your project.">
  
  <!-- THEATER OVERLAY -->
  <div id="theater-focus-overlay" class="theater-overlay" onclick="document.body.classList.remove('theater-active')"></div>

  <section class="resources-header">
    <div class="hero-badge">Verified Expert Network</div>
    <h1>Professional Vendor Directory</h1>
    <p class="lead">Building a dispensary requires an elite team. We've vetted the leading professionals in the Maine market.</p>
  </section>

  <div class="directory-container">
    <div class="vendor-list">
      {vendorCategories.map(category => (
        <div class="category-block">
          <h2>{category.name}</h2>
          <p class="cat-desc">{category.description}</p>
          <div class="vendor-grid">
            {category.vendors.map(vendor => (
              <div class="vendor-card">
                <h3>{vendor.name}</h3>
                <p><strong>Specialty:</strong> {vendor.specialty}</p>
                <p><strong>Location:</strong> {vendor.location}</p>
                <button 
                  type="button" 
                  class="btn-referral-trigger" 
                  onclick={`window.openLeadTheater('${vendor.name}')`}
                >
                  Request Intro &rarr;
                </button>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <aside class="referral-sidebar">
      <div id="referral-form-box" class="referral-box">
        <button type="button" class="btn-close-theater" onclick="document.body.classList.remove('theater-active')">&times;</button>
        <h3>Need a Referral?</h3>
        <p>Tell us about your project, and we will connect you with the right professional.</p>
        <form class="referral-form" action="https://formspree.io/f/xvgzlowz" method="POST">
          <input type="text" name="name" placeholder="Full Name" required />
          <input type="email" name="email" placeholder="Business Email" required />
          <input type="hidden" id="target-vendor-input" name="requested_professional" value="General Referral" />
          <select name="service" required>
            <option value="">Select Service Needed...</option>
            <option value="legal">Legal & Licensing</option>
            <option value="accounting">Tax & 280E</option>
            <option value="security">Security & Hardware</option>
            <option value="real-estate">Real Estate / Zoning</option>
          </select>
          <textarea id="message-text-area" name="message" placeholder="Briefly describe your goals..."></textarea>
          <button type="submit" class="btn-main">Request Introduction</button>
        </form>
      </div>
    </aside>
  </div>

  <script is:inline>
    // Global function to ensure it's available before DOM triggers
    window.openLeadTheater = function(vendorName) {
      console.log("Opening Theater for:", vendorName);
      const input = document.getElementById('target-vendor-input');
      const area = document.getElementById('message-text-area');
      if (input) input.value = vendorName;
      if (area) area.placeholder = "I would like an introduction to " + vendorName + "...";
      document.body.classList.add('theater-active');
    };
  </script>

  <style>
    /* FORCE GLOBAL SCOPE FOR BODY CLASS */
    :global(body.theater-active) {
      overflow: hidden;
    }

    .theater-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(10px);
      z-index: 9000;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.4s ease;
    }

    :global(body.theater-active) .theater-overlay {
      opacity: 1;
      pointer-events: auto;
    }

    .referral-box {
      background: white;
      padding: 3rem;
      border-radius: 2rem;
      border: 2px solid var(--color-primary);
      position: sticky;
      top: 120px;
      z-index: 100;
      transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    :global(body.theater-active) .referral-box {
      position: fixed !important;
      top: 50% !important;
      left: 50% !important;
      transform: translate(-50%, -50%) scale(1) !important;
      z-index: 9001 !important;
      width: 90% !important;
      max-width: 500px !important;
      box-shadow: 0 50px 100px rgba(0,0,0,0.5);
    }

    .btn-referral-trigger {
      margin-top: 1.5rem;
      background: var(--color-background);
      color: var(--color-primary);
      border: none;
      padding: 1rem;
      border-radius: 1rem;
      font-weight: 800;
      cursor: pointer;
      width: 100%;
      transition: all 0.2s;
    }

    .btn-referral-trigger:hover { background: var(--color-primary); color: white; }

    .btn-close-theater {
      position: absolute;
      top: 1rem;
      right: 1.5rem;
      background: none;
      border: none;
      font-size: 2.5rem;
      cursor: pointer;
      display: none;
      color: var(--color-text-light);
    }

    :global(body.theater-active) .btn-close-theater { display: block; }

    /* Layout Spacing */
    .directory-container { display: grid; grid-template-columns: 1fr 350px; gap: 4rem; margin-bottom: 6rem; }
    .category-block { margin-bottom: 4rem; }
    .vendor-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
    .vendor-card { background: white; padding: 2rem; border-radius: 1.5rem; border: 1px solid var(--color-border); }
    .referral-form { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem; }
    .referral-form input, .referral-form select, .referral-form textarea { padding: 1rem; border-radius: 1rem; border: 1px solid var(--color-border); font-family: inherit; }
    
    @media (max-width: 1000px) {
      .directory-container { grid-template-columns: 1fr; }
      .referral-sidebar { order: -1; }
    }
  </style>
</Layout>
