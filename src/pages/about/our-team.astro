---
import Layout from '../../layouts/Layout.astro';
import Callout from '../../components/Callout.astro';
import authors from '../../data/authors.json';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Our Team', href: '/about/our-team' }
];

const editorialTeam = authors.find(a => a.id === 'editorial-team');
const complianceReviewer = authors.find(a => a.id === 'compliance-reviewer');
---

<Layout 
  title="Our Team | Maine Dispensary Guide" 
  description="Meet the professionals behind Maine Dispensary Guide. Our content is written by industry experts and reviewed by Maine-licensed cannabis compliance professionals."
  breadcrumbs={breadcrumbs}
>
  <div class="article-header">
    <h1>Our Team</h1>
    <p class="lead">Professional cannabis business guidance, reviewed by licensed Maine compliance experts.</p>
  </div>

  <section class="intro">
    <p>Maine Dispensary Guide provides factual, detailed cannabis business information for Maine entrepreneurs. Our content bridges the gap between regulatory complexity and practical business implementation.</p>
    <p>What sets us apart: <strong>every regulatory claim in our content is reviewed by a Maine-licensed cannabis compliance professional</strong> before publication. This isn't just editorial care — it's a structured review process designed to protect the entrepreneurs who rely on our guidance.</p>
  </section>

  <Callout title="Credential Verification for Outreach" type="success">
    When we reach out to Maine.gov, the Maine Chamber of Commerce, or academic institutions, we're not sending anonymous content. Our bylined, reviewed content demonstrates the professional credibility that earns links from authoritative sources.
  </Callout>

  <section class="team-preview">
    <h2>Content Review Credentials</h2>
    <div class="team-grid">
      <div class="team-card">
        <div class="card-icon">✦</div>
        <h3>Editorial Team</h3>
        <p>Primary research and content drafting from team members with direct Maine cannabis industry experience.</p>
        <ul class="credential-list">
          <li>Industry-reviewed content</li>
          <li>Primary research from OCP sources</li>
          <li>Maine-specific focus</li>
        </ul>
      </div>
      <div class="team-card">
        <div class="card-icon">◆</div>
        <h3>Compliance Review</h3>
        <p>All regulatory content is verified by a Maine-licensed cannabis compliance professional before publication.</p>
        <ul class="credential-list">
          <li>Maine OCP licensee</li>
          <li>Cannabis compliance specialization</li>
          <li>Regulatory content review</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="review-process">
    <h2>How We Ensure Accuracy</h2>
    <p>Maine cannabis regulations are complex and change frequently. Our review process:</p>
    <ol class="process-list">
      <li><strong>Source Verification</strong> — We cite primary sources including Maine OCP, state statutes, and municipal ordinances.</li>
      <li><strong>Expert Review</strong> — Regulatory content is reviewed by someone with Maine cannabis licensing experience.</li>
      <li><strong>Regular Updates</strong> — When regulations change, we update our content promptly.</li>
    </ol>
  </section>

  <section class="meet-authors">
    <h2>Meet Our Authors</h2>
    <p>Learn more about the professionals behind our content:</p>
    <div class="author-links">
      {authors.map((author) => (
        <a href="/about/authors" class="author-link-card">
          <div class="author-link-photo">
            {author.photo ? (
              <img src={author.photo} alt={author.name} />
            ) : (
              <div class="photo-placeholder">
                <span class="initials">
                  {author.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
                </span>
              </div>
            )}
          </div>
          <div class="author-link-info">
            <h3>{author.name}</h3>
            <p class="author-link-role">{author.role}</p>
            <p class="author-link-bio">{author.bio}</p>
          </div>
          <span class="arrow">→</span>
        </a>
      ))}
    </div>
    <p class="full-team-link"><a href="/about/authors">View full author profiles →</a></p>
  </section>

  <section class="why-matters">
    <h2>Why Author Credentials Matter</h2>
    <p>For YMYL (Your Money Your Life) content like cannabis business guidance, Google's quality raters specifically check:</p>
    <ul>
      <li><strong>Experience</strong> — Do authors have real-world Maine cannabis industry experience?</li>
      <li><strong>Expertise</strong> — Is there evidence of professional knowledge in cannabis compliance?</li>
      <li><strong>Authoritativeness</strong> — Does the publication demonstrate recognized industry knowledge?</li>
      <li><strong>Trustworthiness</strong> — Is the information accurate and sourced properly?</li>
    </ul>
    <p>Our author infrastructure is designed to demonstrate all four of these qualities to both search engines and human readers.</p>
  </section>

  <section class="cta-section">
    <h3>Ready to Start Your Maine Cannabis Business?</h3>
    <p>Use our comprehensive guides, license tools, and compliance resources to build your operation the right way.</p>
    <div class="cta-buttons">
      <a href="/launch-checklist" class="btn-main">Launch Checklist</a>
      <a href="/all-guides" class="btn-secondary">Browse All Guides</a>
    </div>
  </section>
</Layout>

<style>
  .article-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .lead {
    font-size: 1.25rem;
    color: var(--color-text-light);
    margin-top: 1.5rem;
  }

  section {
    margin-bottom: 3rem;
  }

  h2 {
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    color: var(--color-primary);
  }

  .intro p {
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .team-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: box-shadow 0.3s ease;
  }

  .team-card:hover {
    box-shadow: 0 6px 20px rgba(13, 78, 80, 0.08);
  }

  .card-icon {
    font-size: 1.5rem;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .team-card h3 {
    margin: 0 0 0.75rem 0;
    font-size: 1.125rem;
    color: var(--color-primary);
  }

  .team-card p {
    margin: 0 0 1rem 0;
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .credential-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .credential-list li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .credential-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  .process-list {
    padding-left: 1.5rem;
    margin-top: 1rem;
  }

  .process-list li {
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .author-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .author-link-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.25rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .author-link-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 12px rgba(13, 78, 80, 0.08);
    transform: translateX(4px);
  }

  .author-link-photo {
    flex-shrink: 0;
  }

  .author-link-photo img {
    width: 60px;
    height: 60px;
    border-radius: 0.75rem;
    object-fit: cover;
  }

  .photo-placeholder {
    width: 60px;
    height: 60px;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .initials {
    color: white;
    font-size: 1.25rem;
    font-weight: 700;
    font-family: var(--font-serif);
  }

  .author-link-info {
    flex: 1;
  }

  .author-link-info h3 {
    margin: 0;
    font-size: 1rem;
    color: var(--color-primary);
  }

  .author-link-role {
    margin: 0.25rem 0 0.5rem 0;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    font-weight: 600;
  }

  .author-link-bio {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.5;
  }

  .arrow {
    color: var(--color-accent);
    font-size: 1.25rem;
    font-weight: 700;
  }

  .full-team-link {
    margin-top: 1rem;
    text-align: center;
  }

  .full-team-link a {
    color: var(--color-primary);
    font-weight: 600;
  }

  .why-matters ul {
    padding-left: 1.5rem;
    margin: 1rem 0;
  }

  .why-matters li {
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .cta-section {
    background: linear-gradient(135deg, rgba(13, 78, 80, 0.06) 0%, rgba(88, 129, 87, 0.08) 100%);
    border-radius: 1.5rem;
    padding: 3rem 2rem;
    text-align: center;
    margin-top: 3rem;
  }

  .cta-section h3 {
    margin: 0 0 1rem 0;
    font-size: 1.5rem;
    color: var(--color-primary);
  }

  .cta-section p {
    margin: 0 0 1.5rem 0;
    color: var(--color-text-light);
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-main {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: var(--color-primary);
    color: white;
    text-decoration: none;
    border-radius: 0.75rem;
    font-weight: 600;
    transition: background 0.3s ease;
  }

  .btn-main:hover {
    background: var(--color-accent);
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: transparent;
    color: var(--color-primary);
    text-decoration: none;
    border-radius: 0.75rem;
    font-weight: 600;
    border: 2px solid var(--color-primary);
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background: var(--color-primary);
    color: white;
  }

  @media (max-width: 768px) {
    .author-link-card {
      flex-direction: column;
      text-align: center;
    }

    .author-link-info h3 {
      margin-top: 0.75rem;
    }

    .arrow {
      display: none;
    }
  }
</style>
