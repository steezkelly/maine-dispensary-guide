  { title: "Westbrook Dispensary Guide", href: "/guides/westbrook-dispensary-guide/", topics: ["city", "market"], section: "City Guide" },
  { title: "Old Orchard Beach Guide", href: "/guides/old-orchard-beach-dispensary-guide/", topics: ["city", "market"], section: "City Guide" },
  { title: "Kittery Dispensary Guide", href: "/guides/kittery-dispensary-guide/", topics: ["city", "market"], section: "City Guide" },
  { title: "Maine Dispensary License Guide", href: "/guides/maine-dispensary-license/", topics: ["licensing"], section: "Licensing" },
  { title: "Dispensary Business Plan", href: "/guides/maine-dispensary-business-plan/", topics: ["business"], section: "Business" },
  { title: "Startup Costs & Investment", href: "/guides/maine-dispensary-costs/", topics: ["finance"], section: "Finance" },
  { title: "Maine Cannabis Market Analysis", href: "/guides/maine-cannabis-market/", topics: ["market"], section: "Market" },
  { title: "Cannabis Zoning & Real Estate", href: "/guides/maine-cannabis-real-estate/", topics: ["real-estate"], section: "Real Estate" },
  { title: "280E & State Taxation", href: "/guides/maine-cannabis-taxation-280e/", topics: ["finance"], section: "Taxation" },
  { title: "Dispensary Security Requirements", href: "/guides/maine-dispensary-security/", topics: ["real-estate"], section: "Operations" },
  { title: "Inventory & Metrc Management", href: "/guides/maine-cannabis-inventory-management/", topics: ["operations"], section: "Operations" },
  { title: "Dispensary POS Systems", href: "/guides/maine-dispensary-pos/", topics: ["operations"], section: "Operations" },
