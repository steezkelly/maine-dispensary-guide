  currentTopics: string[];
  section?: string;
}

const { currentPath, currentTopics = [], section = 'Technical Guides' } = Astro.props;

const allGuides: RelatedGuide[] = [
  { title: "Portland Dispensary Guide", href: "/guides/portland-dispensary-guide/", topics: ["city", "market"], section: "City Guide" },
