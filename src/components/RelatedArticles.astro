  { title: "Lewiston Dispensary Guide", href: "/guides/lewiston-dispensary-guide/", topics: ["city", "market"], section: "City Guide" },
  { title: "South Portland Dispensary Guide", href: "/guides/south-portland-dispensary-guide/", topics: ["city", "market"], section: "City Guide" },
  { title: "Augusta Dispensary Guide", href: "/guides/augusta-dispensary-guide/", topics: ["city", "market"], section: "City Guide" },
