---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PineTree from '../components/PineTree.astro';
import Leaf from '../components/Leaf.astro';
import GuideSidebar from '../components/GuideSidebar.astro';
import Search from '../components/Search.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface ArticleData {
  author?: string;
  publishDate?: string;
  modifiedDate?: string;
  section?: string;
}

interface Breadcrumb {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  stateName?: string;
  isHub?: boolean;
  heroImage?: string;
  article?: ArticleData;
  breadcrumbs?: Breadcrumb[];
  noindex?: boolean;
  topics?: string[];
}

const { 
  title, 
  description = "Your complete guide to opening and operating a cannabis dispensary.",
  stateName = "Maine",
  isHub = false,
  heroImage,
  article,
  breadcrumbs = [],
  noindex = false,
  topics = []
} = Astro.props;

// Site Metadata & State
const siteName = isHub ? "Dispensary Guide" : `${stateName} Dispensary Guide`;
const siteUrl = "https://mainedispensaryguide.com";
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const isGuide = Astro.url.pathname.startsWith('/guides/') && Astro.url.pathname !== '/guides';
const isContent = isGuide || Astro.url.pathname.startsWith('/founders/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="kxuboyfrGyvC1jEBEVl15CyxvUMDQTy-iWUrtps2XyY" />
    <meta name="msvalidate.01" content="F79201CCB2812011C9EB1EA042399CD3" />
    <title>{fullTitle}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    {heroImage && <link rel="preload" as="image" href={heroImage} />}
    
    <link rel="canonical" href={Astro.url} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="sitemap" href="/sitemap-index.xml" />
    
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    {heroImage && <meta property="og:image" content={heroImage} />}
    {heroImage && <meta name="twitter:image" content={heroImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    
    <!-- HARD-CODED STRUCTURED DATA FOR ACCURACY -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Maine Dispensary Guide",
        "url": "https://mainedispensaryguide.com",
        "description": "Your complete guide to opening and operating a cannabis dispensary.",
        "publisher": {
          "@type": "Organization",
          "name": "Maine Dispensary Guide",
          "logo": {
            "@type": "ImageObject",
            "url": "https://mainedispensaryguide.com/favicon.svg"
          }
        }
      }
    </script>

    {isContent && article && !noindex && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "image": heroImage,
        "author": {
          "@type": "Organization",
          "name": article.author || "Maine Dispensary Guide"
        },
        "publisher": {
          "@type": "Organization",
          "name": "Maine Dispensary Guide",
          "logo": {
            "@type": "ImageObject",
            "url": "https://mainedispensaryguide.com/favicon.svg"
          }
        },
        "datePublished": article.publishDate,
        "dateModified": article.modifiedDate || article.publishDate,
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": Astro.url.href
        },
        "articleSection": article.section
      })} />
    )}

    {isContent && breadcrumbs && breadcrumbs.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": siteUrl
          },
          ...breadcrumbs.map((crumb, index) => ({
            "@type": "ListItem",
            "position": index + 2,
            "name": crumb.label,
            "item": siteUrl + crumb.href
          }))
        ]
      })} />
    )}

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) return localStorage.getItem('theme');
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) return 'dark';
        return 'light';
      })();
      document.documentElement.setAttribute('data-theme', theme);
      
      window.toggleTheme = function() {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      };
    </script>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only skip-link">Skip to main content</a>
    <div class="grain-overlay"></div>
    
    <!-- GLOBAL BOTANICAL ORNAMENTS -->
    <div class="bg-ornament p1"><PineTree size={40} color="var(--color-primary)" /></div>
    <div class="bg-ornament p2"><Leaf size={30} color="var(--color-accent)" /></div>
    <div class="bg-ornament p3"><PineTree size={50} color="var(--color-primary)" /></div>
    <div class="bg-ornament p4"><Leaf size={35} color="var(--color-accent)" /></div>
    <div class="bg-ornament p5"><Leaf size={25} color="var(--color-accent)" /></div>
    <div class="bg-ornament p6"><PineTree size={45} color="var(--color-primary)" /></div>
    <div class="bg-ornament p7"><Leaf size={30} color="var(--color-accent)" /></div>
    <div class="bg-ornament p8"><PineTree size={55} color="var(--color-primary)" /></div>
    <div class="bg-ornament p9"><Leaf size={40} color="var(--color-accent)" /></div>
    <div class="bg-ornament p10"><Leaf size={30} color="var(--color-accent)" /></div>
    <div class="bg-ornament p11"><PineTree size={35} color="var(--color-primary)" /></div>
    <div class="bg-ornament p12"><Leaf size={45} color="var(--color-accent)" /></div>

    <header id="site-header" role="banner">
      <div id="progress-container"><div id="progress-bar"></div></div>
      <nav id="site-nav" aria-label="Main Navigation">
        <a href="/" class="logo" aria-label="Maine Dispensary Guide Home">
          <div class="logo-icons">
            <PineTree size={24} color="var(--color-primary)" class="logo-pine" />
            <Leaf size={20} color="var(--color-accent)" class="logo-leaf" />
          </div>
          <span>{siteName}</span>
        </a>

        <div class="nav-search-desktop"><Search /></div>

        <div class="nav-actions">
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle Dark Mode" onclick="window.toggleTheme()">
            <div class="toggle-track">
              <div class="toggle-thumb">
                <span class="sun" aria-hidden="true">☀️</span>
                <span class="moon" aria-hidden="true">🌙</span>
              </div>
            </div>
          </button>
          <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Toggle mobile menu" />
          <label for="nav-toggle" class="nav-toggle-label" aria-hidden="true" id="mobile-menu-trigger"><span></span></label>
        </div>

        <div class="nav-links" id="navigation-menu" role="navigation">
          <div class="nav-search-mobile"><Search /></div>
          <div class="nav-dropdown">
            <button class="dropbtn" aria-haspopup="true" aria-expanded="false" aria-label="Guides ▾ Submenu">Guides ▾</button>
            <div class="dropdown-content">
              <a href="/all-guides">All Guides</a>
              <a href="/launch-checklist">Launch Checklist</a>
              <a href="/find-a-dispensary">Find a Store</a>
            </div>
          </div>
          <div class="nav-dropdown">
            <button class="dropbtn" aria-haspopup="true" aria-expanded="false" aria-label="Business Tools ▾ Submenu">Business Tools ▾</button>
            <div class="dropdown-content">
              <a href="/roi-calculator">ROI Calculator</a>
              <a href="/market-stats">Market Stats</a>
              <a href="/glossary">Technical Glossary</a>
              <a href="/resources/maine-cannabis-official-resources">Official Resource Links</a>
              <a href="/resources/maine-cannabis-education">Education & Training</a>
            </div>
          </div>
          <a href="/resources">Vendor Directory</a>
          <a href="/about">About</a>
        </div>
      </nav>
    </header>
    
    <main id="main-content" role="main" tabIndex="-1">
      <Breadcrumbs />
      {isGuide ? (
        <div class="guide-layout">
          <div class="guide-content">
            {heroImage && <div class="guide-hero"><img src={heroImage} alt={title} width={1200} height={400} loading="eager" /></div>}
            <slot />
            {article && (
              <div class="article-meta">
                <span class="article-byline">By {article.author || "Maine Dispensary Guide Editorial Team"}</span>
                {article.publishDate && (
                  <span class="article-date">Published {new Date(article.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                )}
                {article.modifiedDate && article.modifiedDate !== article.publishDate && (
                  <span class="article-updated">Updated {new Date(article.modifiedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                )}
              </div>
            )}
            <div class="lead-capture-box">
              <h3>Get the 2026 Maine Launch Checklist</h3>
              <p>Download our step-by-step roadmap. 100% Free.</p>
              <a href="/download-checklist" class="btn-cta">Download PDF Checklist &rarr;</a>
            </div>
            <RelatedArticles currentPath={Astro.url.pathname} currentTopics={topics} section={article?.section} />
          </div>
          <aside class="guide-sidebar-container" aria-label="Guide Navigation"><GuideSidebar /></aside>
        </div>
      ) : (
        <>
          <slot />
          {article && (
            <div class="article-meta">
              <span class="article-byline">By {article.author || "Maine Dispensary Guide Editorial Team"}</span>
              {article.publishDate && (
                <span class="article-date">Published {new Date(article.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              )}
              {article.modifiedDate && article.modifiedDate !== article.publishDate && (
                <span class="article-updated">Updated {new Date(article.modifiedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              )}
            </div>
          )}
        </>
      )}
    </main>
    
    <button id="back-to-top" class="back-to-top" aria-label="↑ Back to Top">&uarr;</button>

    <Analytics />
    <SpeedInsights />
    
    <div id="theater-overlay" class="theater-overlay" aria-hidden="true"></div>

    <footer role="contentinfo">
      <div class="footer-content">
        <p>&copy; {new Date().getFullYear()} {siteName}. v1.0.4 All rights reserved.</p>
        <nav class="footer-links" aria-label="Legal and Contact Links">
          <a href="/privacy">Privacy Policy</a>
          <a href="/contact">Contact Us</a>
          <a href="/about">About</a>
        </nav>
        <p class="disclaimer">Informational purposes only. Consult with professionals.</p>
      </div>
    </footer>

    <script is:inline>
      window.onscroll = function() {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        const pb = document.getElementById("progress-bar");
        if (pb) pb.style.width = scrolled + "%";
        const btt = document.getElementById('back-to-top');
        if (btt) btt.style.display = winScroll > 500 ? "block" : "none";
      };
      const bttBtn = document.getElementById('back-to-top');
      if (bttBtn) bttBtn.onclick = () => window.scrollTo({top: 0, behavior: 'smooth'});

      // Scroll-triggered reveal animation
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -80px 0px',
        threshold: 0.1
      };

      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry, index) => {
          if (entry.isIntersecting) {
            const delay = entry.target.style.animationDelay || '0s';
            entry.target.style.transitionDelay = delay;
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, observerOptions);

      document.querySelectorAll('.reveal').forEach(el => {
        revealObserver.observe(el);
      });
    </script>
  </body>
</html>

<style is:global>
  /**
   * Layout.astro
   * The structural "DNA" of the Maine Dispensary Guide.
   */
  :root {
    --color-primary: #0D4E50;
    --color-primary-dark: #083638;
    --color-secondary: #101820; /* Deepest Navy/Charcoal */
    --color-accent: #588157;    /* Leaf Green */
    --color-soft-green: #A3B18A; /* Sage */
    --color-background: #F2F2E2; /* Warm Bone */
    --color-surface: #ffffff;
    --color-text: #101820;      /* Maximum Contrast Text */
    --color-text-light: #4A5568; 
    --color-border: #D1D1C1;
    --font-family: 'Plus Jakarta Sans', sans-serif;
    --font-serif: 'Fraunces', serif;
    --max-width: 1200px;
    --radius: 1.5rem;
  }

  [data-theme="dark"] {
    --color-primary: #C4D4B6;
    --color-primary-dark: #F2F2E2;
    --color-background: #061A1B;
    --color-surface: #0A2829;
    --color-text: #F2F2E2;
    --color-text-light: #B8C9B0;
    --color-border: #1D3D3D;
  }

  [data-theme="dark"] #site-header { background-color: rgba(5, 26, 27, 0.9); }
  [data-theme="dark"] .nav-links a, [data-theme="dark"] .dropbtn { color: var(--color-text); }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { font-family: var(--font-family); background-color: var(--color-background); color: var(--color-text); line-height: 1.6; scroll-padding-top: 100px; overflow-x: hidden; }
  body { min-height: 100vh; display: flex; flex-direction: column; overflow-x: hidden; width: 100%; }
  
  /* Skip Navigation */
  .skip-link {
    position: absolute;
    top: -100px;
    left: 0;
    background: var(--color-primary);
    color: white;
    padding: 1rem;
    z-index: 9999;
    transition: top 0.3s;
  }
  .skip-link:focus { top: 0; }

  .grain-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png"); opacity: 0.3; pointer-events: none; z-index: 9999; }

  /* Botanical Atmosphere (Dense & Tiny) */
  .bg-ornament {
    position: fixed;
    pointer-events: none;
    z-index: -1;
    opacity: 0.06;
    filter: blur(0.5px);
  }

  [data-theme="dark"] .bg-ornament { opacity: 0.08; }

  .p1 { top: 10%; left: 5%; transform: rotate(-15deg); }
  .p2 { top: 25%; right: 8%; transform: rotate(20deg); }
  .p3 { top: 45%; left: 12%; transform: rotate(10deg); }
  .p4 { top: 65%; right: 15%; transform: rotate(-30deg); }
  .p5 { bottom: 15%; left: 8%; transform: rotate(45deg); }
  .p6 { bottom: 25%; right: 5%; transform: rotate(-10deg); }
  .p7 { top: 5%; right: 25%; transform: rotate(15deg); }
  .p8 { bottom: 5%; right: 20%; transform: rotate(-20deg); }
  .p9 { top: 80%; left: 25%; transform: rotate(5deg); }
  .p10 { top: 35%; right: 2%; transform: rotate(-15deg); }
  .p11 { bottom: 40%; left: 2%; transform: rotate(30deg); }
  .p12 { top: 55%; left: 25%; transform: rotate(-45deg); }

  #site-header { background-color: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border-bottom: 1px solid var(--color-border); padding: 0.75rem 0; position: sticky; top: 0; z-index: 1000; }
  #progress-container { position: absolute; top: 0; left: 0; width: 100%; height: 3px; }
  #progress-bar { height: 100%; background: var(--color-accent); width: 0%; transition: width 0.1s; }
  
  #site-nav { max-width: var(--max-width); margin: 0 auto; padding: 0 1.5rem; display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; }
  .logo { display: flex; align-items: center; gap: 1rem; font-family: var(--font-serif); font-size: 1.25rem; font-weight: 700; color: var(--color-primary); text-decoration: none; flex-shrink: 0; }
  .logo-icons { display: flex; align-items: center; }
  .logo-leaf { margin-left: -10px; margin-bottom: -8px; }

  .nav-search-desktop { flex: 1; max-width: 280px; min-width: 150px; display: block; }

  .nav-actions { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }
  .nav-toggle { display: none; }
  .theme-toggle { background: transparent; border: none; cursor: pointer; }
  .toggle-track { width: 52px; height: 26px; background: var(--color-border); border-radius: 13px; position: relative; }
  .toggle-thumb { width: 20px; height: 20px; background: white; border-radius: 50%; position: absolute; top: 3px; left: 3px; transition: transform 0.3s; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; }
  [data-theme="dark"] .toggle-thumb { transform: translateX(26px); background: var(--color-primary); }
  .sun, .moon { position: absolute; }
  [data-theme="dark"] .sun { opacity: 0; }
  [data-theme="dark"] .moon { opacity: 1; }
  .sun { opacity: 1; }
  .moon { opacity: 0; }

  .nav-links { display: flex; gap: 1rem; align-items: center; flex-shrink: 0; }
  .nav-links a, .dropbtn { color: var(--color-text); text-decoration: none; font-weight: 600; padding: 0.5rem 0.75rem; border-radius: var(--radius); font-size: 0.875rem; white-space: nowrap; background: transparent; border: none; cursor: pointer; }
  .nav-links a:hover, .nav-dropdown:hover .dropbtn { background: var(--color-soft-green); color: white; }

  .nav-dropdown { position: relative; }
  .dropdown-content { display: none; position: absolute; top: 100%; left: 0; background: white; min-width: 220px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border-radius: 1rem; padding: 0.5rem; border: 1px solid var(--color-border); }
  .nav-dropdown:hover .dropdown-content { display: block; }
  .dropdown-content a { color: var(--color-text); padding: 0.75rem 1rem; display: block; font-size: 0.875rem; border-radius: 0.5rem; }
  .nav-dropdown::after { content: ''; position: absolute; top: 100%; left: 0; width: 100%; height: 20px; }

  .nav-search-mobile { display: none; }
  .nav-toggle-label { display: none; width: 30px; height: 30px; position: relative; cursor: pointer; }
  .nav-toggle-label span, .nav-toggle-label span::before, .nav-toggle-label span::after { display: block; background: var(--color-primary); height: 2px; width: 100%; position: absolute; left: 0; transition: transform 0.3s; }
  .nav-toggle-label span { top: 50%; transform: translateY(-50%); }
  .nav-toggle-label span::before { content: ''; top: -8px; }
  .nav-toggle-label span::after { content: ''; top: 8px; }

  .theater-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); z-index: 8000; opacity: 0; pointer-events: none; transition: opacity 0.4s; }
  :global(body.theater-active) .theater-overlay { opacity: 1; pointer-events: auto; }

  @media (max-width: 1200px) {
    .nav-toggle-label { display: block; }
    .nav-search-desktop { display: none; }
    .nav-search-mobile { display: block; width: 100%; margin-bottom: 2rem; }
    .nav-links { 
      position: fixed; 
      top: 0; 
      left: 0; 
      width: 100%; 
      height: 100vh; 
      background: var(--color-background);
      transform: translateX(100%); 
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); 
      flex-direction: column; 
      justify-content: flex-start; 
      padding-top: 100px;
      align-items: center; 
      z-index: 999; 
      overflow-y: auto;
    }
    .nav-links a, .dropbtn { font-size: 1.25rem; width: auto; padding: 1rem 2rem; }
    .nav-dropdown { width: 100%; text-align: center; }
    .dropdown-content { 
      display: block; 
      position: static; 
      box-shadow: none; 
      border: none; 
      background: transparent;
      padding: 0.5rem 0;
    }
    .dropdown-content a { 
      padding: 0.75rem 1rem; 
      font-size: 1rem;
      opacity: 0.8;
    }
    .nav-toggle:checked ~ .nav-links { transform: translateX(0); }
    
    /* Mobile Menu Close Animation */
    .nav-toggle:not(:checked) ~ .nav-links { transform: translateX(100%); }
    
    /* Slide-in animation for menu items */
    .nav-links a, .nav-dropdown .dropbtn {
      opacity: 0;
      transform: translateX(20px);
      transition: opacity 0.3s, transform 0.3s;
    }
    .nav-toggle:checked ~ .nav-links a,
    .nav-toggle:checked ~ .nav-links .nav-dropdown .dropbtn {
      opacity: 1;
      transform: translateX(0);
    }
    .nav-toggle:checked ~ .nav-links > *:nth-child(1) a, .nav-toggle:checked ~ .nav-links > *:nth-child(1) .dropbtn { transition-delay: 0.05s; }
    .nav-toggle:checked ~ .nav-links > *:nth-child(2) a, .nav-toggle:checked ~ .nav-links > *:nth-child(2) .dropbtn { transition-delay: 0.1s; }
    .nav-toggle:checked ~ .nav-links > *:nth-child(3) a { transition-delay: 0.15s; }
    .nav-toggle:checked ~ .nav-links > *:nth-child(4) a { transition-delay: 0.2s; }
  }

  main { flex: 1; max-width: var(--max-width); width: 100%; margin: 0 auto; padding: 3rem 1.5rem; }
  footer { background: var(--color-surface); padding: 5rem 1.5rem; text-align: center; }
  .footer-links { display: flex; justify-content: center; gap: 2rem; margin: 1.5rem 0; }
  .footer-links a { color: var(--color-text-light); font-size: 0.875rem; font-weight: 600; text-decoration: none; }
  .footer-links a:hover { color: var(--color-primary); text-decoration: underline; }
  
  .back-to-top { position: fixed; bottom: 2rem; right: 2rem; background: var(--color-primary); color: white; width: 50px; height: 50px; border-radius: 50%; border: none; display: none; z-index: 999; }
  h1 { font-family: var(--font-serif); font-size: 3rem; color: var(--color-primary); }
  h2 { font-family: var(--font-serif); font-size: 2rem; margin-top: 3rem; color: var(--color-primary); }
  table { width: 100%; border-collapse: collapse; display: block; overflow-x: auto; }
  th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid var(--color-border); min-width: 120px; }
  
