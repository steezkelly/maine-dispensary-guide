---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PineTree from '../components/PineTree.astro';
import Leaf from '../components/Leaf.astro';
import GuideSidebar from '../components/GuideSidebar.astro';
import Search from '../components/Search.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
  stateName?: string;
  isHub?: boolean;
  heroImage?: string;
}

/**
 * Layout.astro
 * The structural "DNA" of the Maine Dispensary Guide.
 * 
 * DESIGN PRINCIPLE: "Modern Maine / Refined Rustic"
 * - Deep Spruce (#0D4E50) for authority.
 * - Warm Bone (#F2F2E2) for readability.
 * 
 * FEATURES:
 * - SEO/GEO Optimized JSON-LD metadata.
 * - Glassmorphism Navigation with Dropdowns.
 * - Conditional Sidebar rendering for Guides.
 */

const { 
  title, 
  description = "Your complete guide to opening and operating a cannabis dispensary.",
  stateName = "Maine",
  isHub = false,
  heroImage
} = Astro.props;

// Logic to identify if current page is a technical guide (triggers sidebar/hero)
const isGuide = Astro.url.pathname.startsWith('/guides/') && Astro.url.pathname !== '/guides/';
const siteName = isHub ? "Dispensary Guide" : `${stateName} Dispensary Guide`;
const fullTitle = `${title} | ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    
    <!-- Search Engine Verifications -->
    <meta name="google-site-verification" content="kxuboyfrGyvC1jEBEVl15CyxvUMDQTy-iWUrtps2XyY" />
    <meta name="msvalidate.01" content="ADD_BING_CODE_HERE" />
    
    <title>{fullTitle}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="canonical" href={Astro.url} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    
    <!-- JSON-LD Structured Data for SEO/GEO -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": isGuide ? "Article" : "WebSite",
      "headline": title,
      "description": description,
      "image": heroImage || "https://mainedispensaryguide.com/favicon.svg",
      "author": {
        "@type": "Organization",
        "name": "Maine Dispensary Guide",
        "url": "https://mainedispensaryguide.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Maine Dispensary Guide",
        "logo": {
          "@type": "ImageObject",
          "url": "https://mainedispensaryguide.com/favicon.svg"
        }
      },
      "dateModified": new Date().toISOString()
    })} />
  </head>
  <body class="bg-maine">
    <header id="site-header">
      <div id="progress-container">
        <div id="progress-bar"></div>
      </div>
      <nav id="site-nav">
        <a href="/" class="logo">
          <div class="logo-icons">
            <PineTree size={24} color="var(--color-primary)" className="logo-pine" />
            <Leaf size={20} color="var(--color-accent)" className="logo-leaf" />
          </div>
          <span>{siteName}</span>
        </a>

        <div class="nav-search-desktop">
          <Search />
        </div>

        <div class="nav-actions">
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle Dark Mode">
            <span class="sun">☀️</span>
            <span class="moon">🌙</span>
          </button>
          
          <!-- Mobile Menu Toggle -->
          <input type="checkbox" id="nav-toggle" class="nav-toggle" />
          <label for="nav-toggle" class="nav-toggle-label">
            <span></span>
          </label>
        </div>

        <div class="nav-links">
          <div class="nav-search-mobile">
            <Search />
          </div>
          
          <div class="nav-dropdown">
            <button class="dropbtn">Guides ▾</button>
            <div class="dropdown-content">
              <a href="/all-guides/">All State Guides</a>
              <a href="/launch-checklist/">Launch Checklist</a>
              <a href="/find-a-dispensary/">Find a Store</a>
            </div>
          </div>

          <div class="nav-dropdown">
            <button class="dropbtn">Business Tools ▾</button>
            <div class="dropdown-content">
              <a href="/roi-calculator/">ROI Calculator</a>
              <a href="/market-stats/">Market Stats</a>
              <a href="/glossary/">Technical Glossary</a>
            </div>
          </div>

          <a href="/resources/">Vendor Directory</a>
          <a href="/about/">About</a>
        </div>
      </nav>
    </header>
    
    <main>
      <Breadcrumbs />
      
      {isGuide ? (
        <div class="guide-layout">
          <div class="guide-content">
            {heroImage && (
              <div class="guide-hero">
                <img 
                  src={heroImage} 
                  alt={title} 
                  width={1200} 
                  height={400}
                  loading="eager"
                  decoding="async"
                />
              </div>
            )}
            <slot />

            <div class="lead-capture-box">
              <h3>Get the 2026 Maine Launch Checklist</h3>
              <p>Download our step-by-step roadmap for Maine cannabis entrepreneurs. 100% Free.</p>
              <a href="/download-checklist/" class="btn-cta">Download PDF Checklist &rarr;</a>
            </div>
          </div>
          <div class="guide-sidebar-container">
            <GuideSidebar />
          </div>
        </div>
      ) : (
        <slot />
      )}
    </main>
    
    <button id="back-to-top" class="back-to-top" aria-label="Back to Top">
      &uarr;
    </button>

    <Analytics />
    <SpeedInsights />
    
    <footer>
      <div class="footer-content">
        <div class="footer-icons">
          <PineTree size={32} color="var(--color-border)" />
          <Leaf size={28} color="var(--color-border)" />
        </div>
        <p>&copy; {new Date().getFullYear()} {siteName}. All rights reserved.</p>
        <p class="disclaimer">This site is for informational purposes and does not constitute legal, financial, or business advice. Consult with qualified professionals before making business decisions.</p>
        {!isHub && (
          <p class="state-link">
            Looking for other states? <a href="/all-guides/">Visit our National Hub</a>
          </p>
        )}
      </div>
    </footer>

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
    
      if (theme === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
      }

      window.localStorage.setItem('theme', theme);

      const handleToggleClick = () => {
        const element = document.documentElement;
        element.setAttribute('data-theme', element.getAttribute('data-theme') === "dark" ? "light" : "dark");
        const isDark = element.getAttribute('data-theme') === "dark";
        localStorage.setItem("theme", isDark ? "dark" : "light");
      }

      document.addEventListener('DOMContentLoaded', () => {
        document.getElementById("theme-toggle").addEventListener("click", handleToggleClick);
      });
    </script>

    <script>
      // Reading Progress Logic
      window.onscroll = function() {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        const progressBar = document.getElementById("progress-bar");
        if (progressBar) progressBar.style.width = scrolled + "%";

        // Back to Top Visibility
        const backToTop = document.getElementById('back-to-top');
        if (backToTop) {
          if (winScroll > 500) {
            backToTop.style.display = "block";
          } else {
            backToTop.style.display = "none";
          }
        }
      };

      const btt = document.getElementById('back-to-top');
      if (btt) {
        btt.onclick = function() {
          window.scrollTo({top: 0, behavior: 'smooth'});
        };
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #0D4E50; /* Deep Spruce */
    --color-primary-dark: #083638;
    --color-secondary: #334A36; /* Pine Needle */
    --color-accent: #588157;    /* Leaf Green */
    --color-soft-green: #A3B18A; /* Sage */
    --color-background: #F2F2E2; /* Warm Bone/Paper */
    --color-surface: #ffffff;
    --color-text: #1a1a1a;
    --color-text-light: #555555;
    --color-border: #d1d1c1;
    --font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-serif: 'Libre Baskerville', serif;
    --max-width: 1100px;
    --radius: 1rem;
  }

  [data-theme="dark"] {
    --color-primary: #74A16F;
    --color-primary-dark: #A3B18A;
    --color-background: #052627;
    --color-surface: #0D3335;
    --color-text: #F2F2E2;
    --color-text-light: #A3B18A;
    --color-border: #1D3D3D;
  }
  
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  
  html {
    font-family: var(--font-family);
    background-color: var(--color-background);
    color: var(--color-text);
    line-height: 1.6;
    scroll-padding-top: 100px;
    overflow-x: hidden;
  }
  
  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-image: radial-gradient(#d1d1c1 0.5px, transparent 0.5px);
    background-size: 24px 24px;
    overflow-x: hidden;
    width: 100%;
  }
  
  #site-header {
    background-color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }

  #progress-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: transparent;
  }

  #progress-bar {
    height: 100%;
    background: var(--color-accent);
    width: 0%;
    transition: width 0.1s ease-out;
  }
  
  #site-nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    z-index: 1001;
    white-space: nowrap;
  }

  .logo-icons {
    display: flex;
    align-items: center;
    gap: -0.5rem;
  }

  .logo-leaf {
    margin-left: -10px;
    margin-bottom: -8px;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .theme-toggle {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    padding: 0.5rem;
    border-radius: 50%;
    cursor: pointer;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    transition: all 0.3s;
  }

  .theme-toggle:hover {
    transform: scale(1.1);
    background: var(--color-surface);
  }

  [data-theme="dark"] .sun { display: block; }
  [data-theme="dark"] .moon { display: none; }
  .sun { display: none; }
  .moon { display: block; }

  /* Responsive Nav Toggle */
  .nav-toggle { display: none; }
  .nav-toggle-label {
    display: none;
    cursor: pointer;
    padding: 1rem;
    z-index: 1001;
  }
  .nav-toggle-label span,
  .nav-toggle-label span::before,
  .nav-toggle-label span::after {
    display: block;
    background: var(--color-primary);
    height: 2px;
    width: 2rem;
    border-radius: 2px;
    position: relative;
    transition: all 0.3s;
  }
  .nav-toggle-label span::before,
  .nav-toggle-label span::after { content: ''; position: absolute; }
  .nav-toggle-label span::before { bottom: 7px; }
  .nav-toggle-label span::after { top: 7px; }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }
  
  .nav-links a, .dropbtn {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    font-size: 0.9375rem;
    white-space: nowrap;
    background: transparent;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }
  
  .nav-links a:hover, .nav-dropdown:hover .dropbtn {
    background: var(--color-soft-green);
    color: white;
  }

  /* Dropdown Logic */
  .nav-dropdown {
    position: relative;
    display: inline-block;
  }

  .dropdown-content {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background-color: white;
    min-width: 220px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    border-radius: 1rem;
    padding: 0.5rem;
    z-index: 2000;
    border: 1px solid var(--color-border);
  }

  /* The "Bridge" to prevent hover loss */
  .nav-dropdown::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    height: 20px;
  }

  .dropdown-content a {
    color: var(--color-text);
    padding: 0.75rem 1rem;
    text-decoration: none;
    display: block;
    font-size: 0.875rem;
    border-radius: 0.5rem;
  }

  .dropdown-content a:hover {
    background-color: var(--color-background);
    color: var(--color-primary);
  }

  .nav-dropdown:hover .dropdown-content {
    display: block;
  }

  .nav-search-mobile { display: none; }

  @media (max-width: 950px) {
    .nav-toggle-label { display: block; }
    .nav-search-desktop { display: none; }
    .nav-search-mobile { display: block; width: 100%; margin-bottom: 2rem; }
    .nav-links {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(15px);
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 2rem;
      gap: 1rem;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.77,0.2,0.05,1.0);
      opacity: 0;
      z-index: 999;
    }
    .nav-links a, .dropbtn { 
      font-size: 1.5rem;
      width: auto;
      text-align: center;
      font-family: var(--font-serif);
      padding: 0.75rem 1rem;
    }
    .nav-dropdown { width: 100%; text-align: center; margin-bottom: 0.5rem; }
    .dropdown-content {
      display: block;
      position: static;
      box-shadow: none;
      border: none;
      background: rgba(13, 78, 80, 0.03);
      padding: 0.5rem;
      border-radius: 1rem;
      margin-top: 0.25rem;
    }
    .dropdown-content a { 
      font-size: 1rem; 
      font-family: var(--font-family); 
      opacity: 0.8;
      padding: 0.5rem !important;
    }
    .nav-toggle:checked ~ .nav-links {
      transform: translateX(0);
      opacity: 1;
    }
    /* Hamburger to X */
    .nav-toggle:checked + .nav-toggle-label span { background: transparent; }
    .nav-toggle:checked + .nav-toggle-label span::before { transform: rotate(45deg); bottom: 0; }
    .nav-toggle:checked + .nav-toggle-label span::after { transform: rotate(-45deg); top: 0; }
  }
  
  main {
    flex: 1;
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  
  footer {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 5rem 1.5rem;
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.875rem;
  }

  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: var(--color-primary);
    color: white;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    display: none;
    z-index: 999;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 3rem;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
    line-height: 1.1;
  }

  @media (max-width: 600px) {
    h1 { font-size: 2.25rem; }
    main { padding: 2rem 1.25rem; }
    body { background-size: 16px 24px; }
  }
  
  h2 {
    font-family: var(--font-serif);
    font-size: 2rem;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }
  
  h3 {
    font-weight: 700;
    font-size: 1.35rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }
  
  p {
    margin-bottom: 1.5rem;
    font-size: 1.0625rem;
  }
  
  a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s;
  }
  
  a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }
  
  ul, ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  
  li {
    margin-bottom: 0.75rem;
  }
  
  code {
    background-color: rgba(163, 177, 138, 0.2);
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
    font-size: 0.875em;
    color: var(--color-primary-dark);
  }
  
  pre {
    background-color: #1e2a2a;
    color: #d4d4d4;
    padding: 2rem;
    border-radius: var(--radius);
    overflow-x: auto;
    margin-bottom: 2rem;
    border: 1px solid #2d3d3d;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  
  pre code {
    background: none;
    padding: 0;
  }

  /* Guide Layout Specifics */
  .guide-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 5rem;
    align-items: start;
  }

  .guide-hero {
    width: 100%;
    height: 400px;
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 4rem;
    border: 1px solid var(--color-border);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .guide-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 1000px) {
    .guide-layout {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .guide-sidebar-container {
      order: 2;
    }
    .guide-hero { height: 300px; margin-bottom: 3rem; }
  }

  /* Lead Capture Styling */
  .lead-capture-box {
    margin-top: 5rem;
    padding: 3rem;
    background: white;
    border: 2px solid var(--color-primary);
    border-radius: 2rem;
    text-align: center;
    box-shadow: 0 20px 40px rgba(13, 78, 80, 0.05);
  }

  @media (max-width: 600px) {
    .lead-capture-box { padding: 2rem 1.5rem; margin-top: 3rem; }
    .lead-capture-box h3 { font-size: 1.5rem; }
  }
</style>
