---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PineTree from '../components/PineTree.astro';
import Leaf from '../components/Leaf.astro';
import GuideSidebar from '../components/GuideSidebar.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
  stateName?: string;
  isHub?: boolean;
  heroImage?: string;
}

const { 
  title, 
  description = "Your complete guide to opening and operating a cannabis dispensary.",
  stateName = "Maine",
  isHub = false,
  heroImage
} = Astro.props;

const isGuide = Astro.url.pathname.startsWith('/guides/') && Astro.url.pathname !== '/guides/';
const siteName = isHub ? "Dispensary Guide" : `${stateName} Dispensary Guide`;
const fullTitle = `${title} | ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="kxuboyfrGyvC1jEBEVl15CyxvUMDQTy-iWUrtps2XyY" />
    <title>{fullTitle}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="canonical" href={Astro.url} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    
    <!-- JSON-LD Structured Data for SEO/GEO -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": isGuide ? "Article" : "WebSite",
      "headline": title,
      "description": description,
      "image": heroImage || "https://mainedispensaryguide.com/favicon.svg",
      "author": {
        "@type": "Organization",
        "name": "Maine Dispensary Guide",
        "url": "https://mainedispensaryguide.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Maine Dispensary Guide",
        "logo": {
          "@type": "ImageObject",
          "url": "https://mainedispensaryguide.com/favicon.svg"
        }
      }
    })} />
  </head>
  <body class="bg-maine">
    <header id="site-header">
      <nav id="site-nav">
        <a href="/" class="logo">
          <div class="logo-icons">
            <PineTree size={24} color="var(--color-primary)" className="logo-pine" />
            <Leaf size={20} color="var(--color-accent)" className="logo-leaf" />
          </div>
          <span>{siteName}</span>
        </a>
        <div class="nav-links">
          <a href="/guides/">Guides</a>
          <a href="/resources/">Resources</a>
          <a href="/about/">About</a>
        </div>
      </nav>
    </header>
    
    <main>
      <Breadcrumbs />
      
      {isGuide ? (
        <div class="guide-layout">
          <div class="guide-content">
            {heroImage && (
              <div class="guide-hero">
                <img src={heroImage} alt={title} loading="lazy" />
              </div>
            )}
            <slot />
          </div>
          <div class="guide-sidebar-container">
            <GuideSidebar />
          </div>
        </div>
      ) : (
        <slot />
      )}
    </main>
    
    <Analytics />
    <SpeedInsights />
    
    <footer>
      <div class="footer-content">
        <div class="footer-icons">
          <PineTree size={32} color="var(--color-border)" />
          <Leaf size={28} color="var(--color-border)" />
        </div>
        <p>&copy; {new Date().getFullYear()} {siteName}. All rights reserved.</p>
        <p class="disclaimer">This site is for informational purposes and does not constitute legal, financial, or business advice. Consult with qualified professionals before making business decisions.</p>
        {!isHub && (
          <p class="state-link">
            Looking for other states? <a href="#">Visit our National Hub</a>
          </p>
        )}
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #0D4E50; /* Deep Spruce */
    --color-primary-dark: #083638;
    --color-secondary: #334A36; /* Pine Needle */
    --color-accent: #588157;    /* Leaf Green */
    --color-soft-green: #A3B18A; /* Sage */
    --color-background: #F2F2E2; /* Warm Bone/Paper */
    --color-surface: #ffffff;
    --color-text: #1a1a1a;
    --color-text-light: #555555;
    --color-border: #d1d1c1;
    --font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-serif: 'Libre Baskerville', serif;
    --max-width: 1100px;
    --radius: 1rem;
  }
  
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  
  html {
    font-family: var(--font-family);
    background-color: var(--color-background);
    color: var(--color-text);
    line-height: 1.6;
    scroll-padding-top: 100px;
  }
  
  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-image: radial-gradient(#d1d1c1 0.5px, transparent 0.5px);
    background-size: 24px 24px;
  }
  
  #site-header {
    background-color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }
  
  #site-nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
  }

  .logo-icons {
    display: flex;
    align-items: center;
    gap: -0.5rem;
  }

  .logo-leaf {
    margin-left: -10px;
    margin-bottom: -8px;
  }
  
  .nav-links {
    display: flex;
    gap: 1.5rem;
  }
  
  .nav-links a {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
  }
  
  .nav-links a:hover {
    background: var(--color-soft-green);
    color: white;
  }
  
  main {
    flex: 1;
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  
  footer {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 5rem 1.5rem;
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.875rem;
  }

  .footer-icons {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
    opacity: 0.4;
  }

  .footer-content {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .disclaimer {
    font-size: 0.75rem;
    margin-top: 1.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.8;
  }

  .state-link {
    margin-top: 2rem;
    font-weight: 600;
  }
  
  h1 {
    font-family: var(--font-serif);
    font-size: 3rem;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
    line-height: 1.1;
  }
  
  h2 {
    font-family: var(--font-serif);
    font-size: 2rem;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }
  
  h3 {
    font-weight: 700;
    font-size: 1.35rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }
  
  p {
    margin-bottom: 1.5rem;
    font-size: 1.0625rem;
  }
  
  a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s;
  }
  
  a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }
  
  ul, ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  
  li {
    margin-bottom: 0.75rem;
  }
  
  code {
    background-color: rgba(163, 177, 138, 0.2);
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
    font-size: 0.875em;
    color: var(--color-primary-dark);
  }
  
  pre {
    background-color: #1e2a2a;
    color: #d4d4d4;
    padding: 2rem;
    border-radius: var(--radius);
    overflow-x: auto;
    margin-bottom: 2rem;
    border: 1px solid #2d3d3d;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  
  pre code {
    background: none;
    padding: 0;
  }

  /* Guide Layout Specifics */
  .guide-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 5rem;
    align-items: start;
  }

  .guide-hero {
    width: 100%;
    height: 400px;
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 4rem;
    border: 1px solid var(--color-border);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .guide-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 1000px) {
    .guide-layout {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .guide-sidebar-container {
      order: 2;
    }
  }
</style>
