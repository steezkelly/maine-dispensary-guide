---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PineTree from '../components/PineTree.astro';
import Leaf from '../components/Leaf.astro';
import GuideSidebar from '../components/GuideSidebar.astro';
import Search from '../components/Search.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
  stateName?: string;
  isHub?: boolean;
  heroImage?: string;
}

const { 
  title, 
  description = "Your complete guide to opening and operating a cannabis dispensary.",
  stateName = "Maine",
  isHub = false,
  heroImage
} = Astro.props;

const isGuide = Astro.url.pathname.startsWith('/guides/') && Astro.url.pathname !== '/guides/';
const siteName = isHub ? "Dispensary Guide" : `${stateName} Dispensary Guide`;
const fullTitle = `${title} | ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="kxuboyfrGyvC1jEBEVl15CyxvUMDQTy-iWUrtps2XyY" />
    <title>{fullTitle}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="canonical" href={Astro.url} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta name="twitter:card" content="summary_large_image" />
    
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": isGuide ? "Article" : "WebSite",
      "headline": title,
      "description": description,
      "image": heroImage || "https://mainedispensaryguide.com/favicon.svg",
      "author": { "@type": "Organization", "name": "Maine Dispensary Guide" }
    })} />

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) return localStorage.getItem('theme');
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) return 'dark';
        return 'light';
      })();
      document.documentElement.setAttribute('data-theme', theme);
      
      window.toggleTheme = function() {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      };
    </script>
  </head>
  <body>
    <div class="grain-overlay"></div>
    <header id="site-header">
      <div id="progress-container"><div id="progress-bar"></div></div>
      <nav id="site-nav">
        <a href="/" class="logo">
          <div class="logo-icons">
            <PineTree size={24} color="var(--color-primary)" class="logo-pine" />
            <Leaf size={20} color="var(--color-accent)" class="logo-leaf" />
          </div>
          <span>{siteName}</span>
        </a>

        <div class="nav-search-desktop"><Search /></div>

        <div class="nav-actions">
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle Dark Mode" onclick="window.toggleTheme()">
            <div class="toggle-track">
              <div class="toggle-thumb">
                <span class="sun">☀️</span>
                <span class="moon">🌙</span>
              </div>
            </div>
          </button>
          <input type="checkbox" id="nav-toggle" class="nav-toggle" />
          <label for="nav-toggle" class="nav-toggle-label"><span></span></label>
        </div>

        <div class="nav-links">
          <div class="nav-search-mobile"><Search /></div>
          <div class="nav-dropdown">
            <button class="dropbtn">Guides ▾</button>
            <div class="dropdown-content">
              <a href="/all-guides/">All State Guides</a>
              <a href="/launch-checklist/">Launch Checklist</a>
              <a href="/find-a-dispensary/">Find a Store</a>
            </div>
          </div>
          <div class="nav-dropdown">
            <button class="dropbtn">Business Tools ▾</button>
            <div class="dropdown-content">
              <a href="/roi-calculator/">ROI Calculator</a>
              <a href="/market-stats/">Market Stats</a>
              <a href="/glossary/">Technical Glossary</a>
            </div>
          </div>
          <a href="/resources/">Vendor Directory</a>
          <a href="/about/">About</a>
        </div>
      </nav>
    </header>
    
    <main>
      <Breadcrumbs />
      {isGuide ? (
        <div class="guide-layout">
          <div class="guide-content">
            {heroImage && <div class="guide-hero"><img src={heroImage} alt={title} width={1200} height={400} loading="eager" /></div>}
            <slot />
            <div class="lead-capture-box">
              <h3>Get the 2026 Maine Launch Checklist</h3>
              <p>Download our step-by-step roadmap. 100% Free.</p>
              <a href="/download-checklist/" class="btn-cta">Download PDF Checklist &rarr;</a>
            </div>
          </div>
          <div class="guide-sidebar-container"><GuideSidebar /></div>
        </div>
      ) : <slot />}
    </main>
    
    <button id="back-to-top" class="back-to-top">&uarr;</button>

    <Analytics />
    <SpeedInsights />
    
    <div id="theater-overlay" class="theater-overlay"></div>

    <footer>
      <div class="footer-content">
        <p>&copy; {new Date().getFullYear()} {siteName}. All rights reserved.</p>
        <p class="disclaimer">Informational purposes only. Consult with professionals.</p>
      </div>
    </footer>

    <script is:inline>
      window.onscroll = function() {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        const pb = document.getElementById("progress-bar");
        if (pb) pb.style.width = scrolled + "%";
        const btt = document.getElementById('back-to-top');
        if (btt) btt.style.display = winScroll > 500 ? "block" : "none";
      };
      const bttBtn = document.getElementById('back-to-top');
      if (bttBtn) bttBtn.onclick = () => window.scrollTo({top: 0, behavior: 'smooth'});
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #0D4E50;
    --color-primary-dark: #083638;
    --color-secondary: #334A36;
    --color-accent: #588157;
    --color-soft-green: #A3B18A;
    --color-background: #F2F2E2;
    --color-surface: #ffffff;
    --color-text: #1a1a1a;
    --color-text-light: #555555;
    --color-border: #d1d1c1;
    --font-family: 'Plus Jakarta Sans', sans-serif;
    --font-serif: 'Fraunces', serif;
    --max-width: 1100px;
    --radius: 1.5rem;
  }

  [data-theme="dark"] {
    --color-primary: #A3B18A;
    --color-primary-dark: #DAD7CD;
    --color-background: #051A1B;
    --color-surface: #0D2628;
    --color-text: #F2F2E2;
    --color-text-light: #A3B18A;
    --color-border: #1D3D3D;
  }

  [data-theme="dark"] #site-header { background-color: rgba(5, 26, 27, 0.9); }
  [data-theme="dark"] .nav-links a, [data-theme="dark"] .dropbtn { color: var(--color-text); }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { font-family: var(--font-family); background-color: var(--color-background); color: var(--color-text); line-height: 1.6; scroll-padding-top: 100px; overflow-x: hidden; }
  body { min-height: 100vh; display: flex; flex-direction: column; overflow-x: hidden; width: 100%; }
  
  .grain-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png"); opacity: 0.3; pointer-events: none; z-index: 9999; }

  #site-header { background-color: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border-bottom: 1px solid var(--color-border); padding: 0.75rem 0; position: sticky; top: 0; z-index: 1000; }
  #progress-container { position: absolute; top: 0; left: 0; width: 100%; height: 3px; }
  #progress-bar { height: 100%; background: var(--color-accent); width: 0%; transition: width 0.1s; }
  
  #site-nav { max-width: var(--max-width); margin: 0 auto; padding: 0 1.5rem; display: flex; justify-content: space-between; align-items: center; gap: 2rem; }
  .logo { display: flex; align-items: center; gap: 1rem; font-family: var(--font-serif); font-size: 1.25rem; font-weight: 700; color: var(--color-primary); text-decoration: none; }
  .logo-icons { display: flex; align-items: center; }
  .logo-leaf { margin-left: -10px; margin-bottom: -8px; }

  .nav-actions { display: flex; align-items: center; gap: 1rem; }
  .theme-toggle { background: transparent; border: none; cursor: pointer; }
  .toggle-track { width: 52px; height: 26px; background: var(--color-border); border-radius: 13px; position: relative; }
  .toggle-thumb { width: 20px; height: 20px; background: white; border-radius: 50%; position: absolute; top: 3px; left: 3px; transition: transform 0.3s; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; }
  [data-theme="dark"] .toggle-thumb { transform: translateX(26px); background: var(--color-primary); }
  .sun, .moon { position: absolute; }
  [data-theme="dark"] .sun { opacity: 0; }
  [data-theme="dark"] .moon { opacity: 1; }
  .sun { opacity: 1; }
  .moon { opacity: 0; }

  .nav-links { display: flex; gap: 1.5rem; align-items: center; }
  .nav-links a, .dropbtn { color: var(--color-text); text-decoration: none; font-weight: 600; padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; white-space: nowrap; background: transparent; border: none; cursor: pointer; }
  .nav-links a:hover, .nav-dropdown:hover .dropbtn { background: var(--color-soft-green); color: white; }

  .nav-dropdown { position: relative; }
  .dropdown-content { display: none; position: absolute; top: 100%; left: 0; background: white; min-width: 220px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border-radius: 1rem; padding: 0.5rem; border: 1px solid var(--color-border); }
  .nav-dropdown:hover .dropdown-content { display: block; }
  .dropdown-content a { color: var(--color-text); padding: 0.75rem 1rem; display: block; font-size: 0.875rem; border-radius: 0.5rem; }
  .nav-dropdown::after { content: ''; position: absolute; top: 100%; left: 0; width: 100%; height: 20px; }

  .theater-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); z-index: 8000; opacity: 0; pointer-events: none; transition: opacity 0.4s; }
  :global(body.theater-active) .theater-overlay { opacity: 1; pointer-events: auto; }

  @media (max-width: 1200px) {
    .nav-toggle-label { display: block; }
    .nav-search-desktop { display: none; }
    .nav-links { position: fixed; top: 0; left: 0; width: 100%; height: 100vh; background: rgba(255,255,255,0.98); transform: translateX(100%); transition: transform 0.4s; flex-direction: column; justify-content: center; z-index: 999; }
    .nav-toggle:checked ~ .nav-links { transform: translateX(0); }
  }

  main { flex: 1; max-width: var(--max-width); width: 100%; margin: 0 auto; padding: 3rem 1.5rem; }
  footer { background: var(--color-surface); padding: 5rem 1.5rem; text-align: center; }
  .back-to-top { position: fixed; bottom: 2rem; right: 2rem; background: var(--color-primary); color: white; width: 50px; height: 50px; border-radius: 50%; border: none; display: none; z-index: 999; }
  h1 { font-family: var(--font-serif); font-size: 3rem; color: var(--color-primary); }
  h2 { font-family: var(--font-serif); font-size: 2rem; margin-top: 3rem; color: var(--color-primary); }
  table { width: 100%; border-collapse: collapse; display: block; overflow-x: auto; }
  th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid var(--color-border); min-width: 120px; }
</style>
